---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = "ABKHD | store", description = "Premium tech at smarter prices" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <script is:inline>
      // Initialize dark mode before page renders
      (function() {
        const savedTheme = localStorage.getItem('darkMode')
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        
        const isDark = savedTheme !== null 
          ? savedTheme === 'true' 
          : systemPrefersDark

        if (isDark) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <slot name="header" />
      <main class="flex-1">
        <slot />
      </main>
      <slot name="footer" />
    </div>
    <script>
      // Import Appwrite client to trigger initialization and verification ping
      import { client } from '../lib/appwrite';
    </script>
  </body>
</html>