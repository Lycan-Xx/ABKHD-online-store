---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "ABKHD Admin", 
  description = "Admin panel for ABKHD store" 
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { path: '/admin', label: 'Dashboard', icon: 'bi-grid-1x2-fill', exact: true },
  { path: '/admin/products', label: 'Products', icon: 'bi-box-seam-fill' },
  { path: '/admin/orders', label: 'Orders', icon: 'bi-bag-check-fill' }
];

const isActive = (path: string, exact = false) => {
  if (exact) {
    return currentPath === path;
  }
  return currentPath.startsWith(path);
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Cloudflare Insights Beacon -->
    <script
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "8c78df7c7c0f484497ecbca7046644da1771523124516"}'
      integrity="sha512-8DS7rgIrAmghBFwoOTujcf6D9rXvH8xm8JQ1Ja01h9QX8EzXldiszufYa4IFfKdLUKTTrnSFXLDkUEOTrZQ8Qg=="
      crossorigin="anonymous"
    ></script>
    
    <title>{title}</title>
    <ViewTransitions />
    <script is:inline>
      // Initialize dark mode BEFORE page renders to prevent flash
      (function() {
        const savedTheme = localStorage.getItem('darkMode');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = savedTheme !== null ? savedTheme === 'true' : systemPrefersDark;
        if (isDark) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Loading Screen -->
    <div id="loading-screen" class="fixed inset-0 z-[100] bg-background flex flex-col items-center justify-center">
      <div class="text-center space-y-4">
        <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-primary border-t-transparent"></div>
        <p class="text-muted-foreground text-sm">Loading please wait or if you can't, GIVE UP. Nigerian network is not for the weak ✌️...</p>
      </div>
    </div>

    <!-- Hide content initially so unauthorized users never see a flash of the dashboard -->
    <div id="admin-root" class="min-h-screen bg-background" style="display: none; opacity: 0; transition: opacity 0.4s ease;">
      <!-- Admin Header -->
      <header class="sticky top-0 z-50 border-b bg-card/95 backdrop-blur supports-[backdrop-filter]:bg-card/80">
        <div class="container flex h-16 items-center justify-between">
          <div class="flex items-center gap-6">
            <a href="/admin" class="flex items-center gap-2">
              <span class="text-xl font-bold text-primary">ABKHD</span>
              <span class="text-sm font-medium text-muted-foreground">Admin</span>
            </a>
            
            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center gap-1">
              {navItems.map(item => (
                <a
                  href={item.path}
                  class={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                    isActive(item.path, item.exact)
                      ? 'text-primary bg-primary/10' 
                      : 'text-muted-foreground hover:text-foreground hover:bg-muted'
                  }`}
                >
                  <i class={item.icon}></i>
                  {item.label}
                </a>
              ))}
            </nav>
          </div>

          <div class="flex items-center gap-4">
            <div id="user-info" class="flex items-center gap-2 text-sm">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
                <i class="bi bi-person-fill text-primary"></i>
              </div>
              <span id="user-name" class="hidden md:inline font-medium"></span>
            </div>
            
            <a 
              href="/" 
              class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
              <i class="bi bi-arrow-left"></i>
              <span class="hidden md:inline">Back to Store</span>
            </a>
            
            <button 
              id="logout-btn"
              class="flex items-center gap-2 text-sm text-red-500 hover:text-red-600 transition-colors"
            >
              <i class="bi bi-box-arrow-right"></i>
              <span class="hidden md:inline">Logout</span>
            </button>
          </div>
        </div>
      </header>

      <!-- Mobile Navigation -->
      <nav class="md:hidden sticky top-16 z-40 border-b bg-card/95 backdrop-blur">
        <div class="container flex items-center gap-2 py-2 overflow-x-auto">
          {navItems.map(item => (
            <a
              href={item.path}
              class={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors ${
                isActive(item.path, item.exact)
                  ? 'text-primary bg-primary/10' 
                  : 'text-muted-foreground hover:text-foreground hover:bg-muted'
              }`}
            >
              <i class={item.icon}></i>
              {item.label}
            </a>
          ))}
        </div>
      </nav>

      <!-- Main Content -->
      <main class="container py-6 md:py-8">
        <slot />
      </main>
    </div>
    <script>
      // Initialize dark mode
      const setDarkMode = () => {
        const savedTheme = localStorage.getItem('darkMode')
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        
        const isDark = savedTheme !== null 
          ? savedTheme === 'true' 
          : systemPrefersDark

        if (isDark) {
          document.documentElement.classList.add('dark')
        } else {
          document.documentElement.classList.remove('dark')
        }
      }

      // Initialize on page load
      setDarkMode()

      // Re-initialize after view transitions
      document.addEventListener('astro:after-swap', setDarkMode)
    </script>
    <script>
      import { account, teams } from '../lib/appwrite';

      // Global store for current admin user
      (window as any).adminUser = null;

      const checkAuth = async () => {
        // Skip check on login page - hide loading immediately
        if (window.location.pathname === '/login') {
          const loadingScreen = document.getElementById('loading-screen');
          if (loadingScreen) loadingScreen.style.display = 'none';
          return;
        }

        console.log('--- Admin Auth Check ---');
        console.log('Path:', window.location.pathname);

        try {
          // 1. Check if logged in
          const user = await account.get();
          console.log('User found:', user.email, user.$id);
          
          // 2. Check if in admin team OR has admin label
          const userTeams = await teams.list();
          console.log('User teams:', userTeams.teams.map(t => ({ id: t.$id, name: t.name })));

          const labels = (user as any).labels || [];
          const isAdmin = labels.includes('admin') || 
                        userTeams.teams.some(t => t.$id === 'admin' || t.name.toLowerCase() === 'admin');
          console.log('Is Admin (Labels + Teams):', isAdmin);
          
          if (!isAdmin) {
            console.warn('User is logged in but not an admin. Redirecting to storefront...');
            window.location.href = '/';
            return;
          }

          // Store user info globally for child pages
          (window as any).adminUser = {
            id: user.$id,
            name: user.name || user.email,
            email: user.email
          };

          // Update UI with user name
          const userNameEl = document.getElementById('user-name');
          if (userNameEl) {
            userNameEl.textContent = user.name || user.email;
          }

          // Hide loading screen and reveal dashboard
          const loadingScreen = document.getElementById('loading-screen');
          const root = document.getElementById('admin-root');
          
          if (loadingScreen) {
            loadingScreen.style.opacity = '0';
            loadingScreen.style.transition = 'opacity 0.3s ease';
            setTimeout(() => {
              loadingScreen.style.display = 'none';
            }, 300);
          }
          
          if (root) {
            root.style.display = 'block';
            // Allow display change to apply before fading in
            setTimeout(() => root.style.opacity = '1', 50);
          }
        } catch (error) {
          console.error('Auth check failed or not logged in:', error);
          // Hide loading screen before redirect
          const loadingScreen = document.getElementById('loading-screen');
          if (loadingScreen) {
            loadingScreen.style.display = 'none';
          }
          window.location.href = '/login';
        }
      };

      const handleLogout = async () => {
        try {
          await account.deleteSession('current');
          window.location.href = '/login';
        } catch (error) {
          console.error('Logout failed:', error);
        }
      };

      // Run on initial load
      checkAuth();

      // Setup logout button
      document.getElementById('logout-btn')?.addEventListener('click', handleLogout);

      // Re-run after view transitions
      document.addEventListener('astro:after-swap', () => {
        checkAuth();
        document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
      });
    </script>
  </body>
</html>