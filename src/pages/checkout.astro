    transition: border-color 0.18s, color 0.18s;
  }
  .co-back-link:hover { border-color: var(--cop); color: var(--cof); }
  .co-desk-title { font-size: 21px; font-weight: 800; color: var(--cof); margin: 0; }

  /* ═══ STEPS BAR ═══ */
  .co-steps { display: flex; align-items: center; margin-bottom: 30px; }
  .co-step  { display: flex; flex-direction: column; align-items: center; gap: 5px; flex-shrink: 0; }
  .co-step-circle {
    width: 34px; height: 34px;
