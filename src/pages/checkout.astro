  .qty-btn:hover:not(:disabled) {
    background: color-mix(in srgb, var(--co-primary) 22%, var(--co-bg));
    transform: scale(1.05);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--co-primary) 25%, transparent);
