  }
  .cart-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .cart-title { font-size: 16px; font-weight: 700; color: var(--co-fg); margin: 0; }
  .cart-item-count { font-size: 12px; color: var(--co-muted-fg); }

  /* ── Cart items grid (always single column in cart pane) ── */
  .cart-items-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-bottom: 20px;
  }

  .cart-item {
    border: 1.5px solid var(--co-border);
    border-radius: var(--r-md);
