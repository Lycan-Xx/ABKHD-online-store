    font-size: 12px; font-weight: 700;
    color: var(--comf);
    transition: all 0.28s ease;
  }
  .co-step--active .co-step-circle {
    border-color: var(--cop);
    background: var(--cop);
    color: var(--copf);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--cop) 14%, transparent);
  }
  .co-step--done .co-step-circle {
    border-color: var(--cos);
    background: var(--cos);
    color: #fff;
  }
  .co-step--done .co-step-num  { display: none; }
  .co-step--done .co-step-check { display: block !important; }
  .co-step-lbl {
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--comf);
  }
  .co-step--active .co-step-lbl { color: var(--cop); }
  .co-step--done   .co-step-lbl { color: var(--cos); }
  .co-step-line {
    flex: 1; height: 2px;
    background: var(--cobr);
    margin: 0 6px 18px;
    transition: background 0.35s ease;
  }
  .co-step-line--done { background: var(--cos); }

  /* ═══ PANELS ═══ */
  .co-panel { animation: co-up 0.26s ease; }
  @keyframes co-up {
    from { opacity:0; transform:translateY(8px); }
    to   { opacity:1; transform:translateY(0);   }
  }
  .co-panel-hdr { margin-bottom: 20px; }
  .co-panel-title { font-size: 19px; font-weight: 700; color: var(--cof); margin: 0 0 4px; }
  .co-panel-sub   { font-size: 13px; color: var(--comf); margin: 0; }

  /* ═══ FORM ═══ */
  #co-details-form { display: flex; flex-direction: column; gap: 14px; }
  .co-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 520px) { .co-field-row { grid-template-columns: 1fr; } }

  .co-field { display: flex; flex-direction: column; gap: 5px; }
