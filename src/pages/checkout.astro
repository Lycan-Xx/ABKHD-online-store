  }
  .co-qty-btn:hover:not(:disabled) {
    background: color-mix(in srgb, var(--cop) 24%, var(--cob)) !important;
    transform: scale(1.07) !important;
  }
  .co-qty-btn:active:not(:disabled) { transform: scale(0.96) !important; }
  .co-qty-btn:disabled { opacity: 0.3 !important; cursor: not-allowed !important; }
  .co-qty-val {
    font-size: 13px !important;
