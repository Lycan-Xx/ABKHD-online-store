---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Checkout — ABKHD Store">
  <Header slot="header" />

  <div class="co-root">

    <!-- ── Mobile sticky progress header ─────────────────────── -->
    <div class="mobile-header" id="mobile-header">
      <div class="mobile-header-inner">
        <a href="/shop" class="mobile-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          Shop
        </a>
        <span class="mobile-title">Checkout</span>
        <div style="width:60px"></div>
      </div>
      <!-- Mobile progress bar -->
      <div class="mobile-progress" id="mobile-progress">
        <div class="mobile-progress-info">
          <span class="mobile-step-label" id="mobile-step-label">Shipping Details</span>
          <span class="mobile-step-count" id="mobile-step-count">1 / 3</span>
        </div>
        <div class="mobile-progress-track">
          <div class="mobile-progress-fill" id="mobile-progress-fill" style="width: 8%"></div>
        </div>
        <div class="mobile-progress-dots">
          <div class="mobile-dot active" data-step="1"></div>
          <div class="mobile-dot" data-step="2"></div>
          <div class="mobile-dot" data-step="3"></div>
        </div>
      </div>
    </div>

    <!-- ── Empty cart state ───────────────────────────────────── -->
    <div id="empty-state" class="empty-state hidden">
      <div class="empty-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
      <h2>Your cart is empty</h2>
      <p>Add some items before checking out.</p>
      <a href="/shop" class="btn-primary">Browse Products</a>
    </div>

    <!-- ── Checkout layout ────────────────────────────────────── -->
    <div id="checkout-layout" class="checkout-layout hidden">

      <!-- ───── LEFT: wizard pane ───────────────────────────── -->
      <div class="wizard-pane" id="wizard-pane">

        <!-- Desktop topbar -->
        <div class="desktop-topbar">
          <a href="/shop" class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            Continue Shopping
          </a>
          <h1 class="desktop-title">Checkout</h1>
        </div>

        <!-- Step indicator (desktop horizontal) -->
        <div class="steps-bar" id="steps-bar">
          <div class="step-item active" data-step="1">
            <div class="step-circle">
              <span class="step-num">1</span>
              <svg class="step-check hidden" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="step-label">Details</span>
          </div>
          <div class="step-line" data-line="1"></div>
          <div class="step-item" data-step="2">
            <div class="step-circle">
              <span class="step-num">2</span>
              <svg class="step-check hidden" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="step-label">Payment</span>
          </div>
          <div class="step-line" data-line="2"></div>
          <div class="step-item" data-step="3">
            <div class="step-circle">
              <span class="step-num">3</span>
              <svg class="step-check hidden" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="step-label">Confirmed</span>
          </div>
        </div>

        <!-- ─── TAB 1: Details ──────────────────────────── -->
        <div class="tab-panel active" id="tab-details">
          <div class="panel-header">
            <h2 class="panel-title">Shipping Details</h2>
            <p class="panel-sub">Where should we deliver your order?</p>
          </div>

          <form id="details-form" novalidate>
            <div class="field-row">
              <div class="field">
                <label for="fullName">Full Name <span class="req">*</span></label>
                <input type="text" id="fullName" name="fullName" placeholder="Amina Yusuf" required />
              </div>
              <div class="field">
                <label for="email">Email <span class="req">*</span></label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required />
              </div>
            </div>

            <div class="field">
              <label for="phone">Phone Number <span class="req">*</span></label>
              <input type="tel" id="phone" name="phone" placeholder="+2348012345678" required />
            </div>

            <div class="field">
              <label for="address">Delivery Address <span class="req">*</span></label>
              <input type="text" id="address" name="address" placeholder="No. 12, Galadima Road" required />
            </div>

            <div class="field-row">
              <div class="field">
                <label for="city">City <span class="req">*</span></label>
                <div class="select-wrap">
                  <select id="city" name="city" required>
                    <option value="" disabled selected>Select city</option>
                    <option value="Yola">Yola</option>
                    <option value="Jimeta">Jimeta</option>
                  </select>
                  <svg class="select-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div class="field">
                <label for="state">State</label>
                <div class="select-wrap">
                  <select id="state" name="state" disabled>
                    <option value="Adamawa">Adamawa</option>
                  </select>
                  <svg class="select-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
            </div>

            <div class="field">
              <label for="postalCode">Postal Code <span class="optional">(optional)</span></label>
              <input type="text" id="postalCode" name="postalCode" placeholder="640001" />
            </div>

            <!-- Delivery fee callout -->
            <div class="delivery-callout hidden" id="delivery-callout">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              <span id="delivery-callout-text">Delivery to Yola: ₦1,000</span>
            </div>

            <button type="submit" class="btn-primary btn-full">
              Proceed to Payment
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </form>
        </div>

        <!-- ─── TAB 2: Payment ──────────────────────────── -->
        <div class="tab-panel hidden" id="tab-payment">
          <div class="panel-header">
            <h2 class="panel-title">Choose Payment</h2>
            <p class="panel-sub">Select how you'd like to complete your purchase.</p>
          </div>

          <!-- Order summary mini (payment tab) -->
          <div class="payment-summary-strip" id="payment-summary-strip">
            <div class="pss-row">
              <span>Subtotal</span>
              <span id="pss-subtotal">₦0</span>
            </div>
            <div class="pss-row">
              <span>Delivery</span>
              <span id="pss-shipping">—</span>
            </div>
            <div class="pss-row pss-total">
              <span>Total due</span>
              <span id="pss-total">₦0</span>
            </div>
          </div>

          <div class="payment-methods">
            <!-- Squad -->
            <button id="squad-btn" class="pm-card">
              <div class="pm-logo">
                <svg width="30" height="30" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="40" height="40" rx="10" fill="#FF6B00"/>
                  <path d="M10 28L20 12L30 28H10Z" fill="white" opacity="0.9"/>
                </svg>
              </div>
              <div class="pm-info">
                <span class="pm-name">Squad</span>
                <span class="pm-desc">Card, bank transfer, or USSD</span>
              </div>
              <div class="pm-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            </button>

            <!-- Paystack — coming soon -->
            <div class="pm-card pm-disabled">
              <div class="pm-logo">
                <svg width="30" height="30" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="40" height="40" rx="10" fill="#00C3F7"/>
                  <rect x="8" y="15" width="24" height="4" rx="2" fill="white"/>
                  <rect x="8" y="22" width="16" height="4" rx="2" fill="white" opacity="0.6"/>
                </svg>
              </div>
              <div class="pm-info">
                <span class="pm-name">Paystack</span>
                <span class="pm-desc">Cards, bank transfer & more</span>
              </div>
              <div class="pm-badge">Soon</div>
            </div>
          </div>

          <!-- WhatsApp — secondary option -->
          <div class="whatsapp-section">
            <p class="whatsapp-label">Prefer to order manually?</p>
            <a id="whatsapp-link" href="#" target="_blank" rel="noopener" class="whatsapp-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              Chat via WhatsApp
            </a>
          </div>

          <button class="btn-ghost" id="back-to-details">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Details
          </button>
        </div>

        <!-- ─── TAB 3: Confirmed ─────────────────────────── -->
        <div class="tab-panel hidden" id="tab-confirmed">
          <div class="success-wrap">
            <div class="success-icon-ring">
              <div class="success-ring-bg"></div>
              <svg class="success-check" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h2 class="success-title">Order Confirmed!</h2>
            <p class="success-msg">Thank you for your purchase. We've received your order and will process it within 1–2 business days.</p>

            <div class="order-ref-card">
              <span class="ref-label">Order Reference</span>
              <span class="ref-value" id="order-ref-display">—</span>
            </div>

            <div class="next-steps">
              <div class="next-step">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>Confirmation sent to <strong id="confirm-email">—</strong></span>
              </div>
              <div class="next-step">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                <span>Processed within 1–2 business days</span>
              </div>
              <div class="next-step">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Tracking info sent once dispatched</span>
              </div>
            </div>

            <!-- Future: receipt download will go here -->
            <div id="receipt-slot"></div>

            <div class="success-actions">
              <a href="/shop" class="btn-primary">Continue Shopping</a>
              <a href="/" class="btn-ghost">Back to Home</a>
            </div>
          </div>
        </div>

      </div>
      <!-- /wizard-pane -->

      <!-- ───── RIGHT: cart pane ────────────────────────────── -->
      <div class="cart-pane" id="cart-pane">
        <div class="cart-inner">
          <div class="cart-header-row">
            <h3 class="cart-title" id="cart-pane-title">Your Cart</h3>
            <span class="cart-item-count" id="cart-item-count">0 items</span>
          </div>

          <!-- Cart items grid (JS rendered) -->
          <div id="cart-items-grid" class="cart-items-grid"></div>

          <!-- Order summary -->
          <div id="price-summary" class="price-summary">
            <div class="summary-row">
              <span>Subtotal</span>
              <span id="summary-subtotal">₦0</span>
            </div>
            <div class="summary-row">
              <span>Delivery</span>
              <span id="summary-shipping">Select city</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-row summary-total">
              <span>Total</span>
              <span id="summary-total">₦0</span>
            </div>
          </div>

          <!-- Paid state (hidden until step 3) -->
          <div id="paid-banner" class="paid-banner hidden">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Payment successful</span>
          </div>

          <!-- WhatsApp — tertiary in cart pane -->
          <a id="whatsapp-cart-btn" href="#" target="_blank" rel="noopener" class="whatsapp-cart-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Order via WhatsApp instead
          </a>
        </div>
      </div>

    </div>
    <!-- /checkout-layout -->

  </div>
  <!-- /co-root -->

  <Footer slot="footer" />
</Layout>

<!-- ── Styles ─────────────────────────────────────────────────────── -->
<style>
  /* ── Design tokens (inherit from site, override locally) ── */
  .co-root {
    --co-bg:          hsl(var(--background));
    --co-card:        hsl(var(--card));
    --co-border:      hsl(var(--border));
    --co-primary:     hsl(var(--primary));
    --co-primary-fg:  hsl(var(--primary-foreground));
    --co-muted:       hsl(var(--muted));
    --co-muted-fg:    hsl(var(--muted-foreground));
    --co-fg:          hsl(var(--foreground));
    --co-success:     #16a34a;
    --co-success-bg:  #f0fdf4;
    --co-success-bd:  #bbf7d0;
    --r-lg: 14px;
    --r-md: 10px;
    --shadow: 0 2px 20px rgba(0,0,0,0.08);

    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px 80px;
    min-height: 70vh;
  }

  /* ── Mobile header ── */
  .mobile-header {
    display: none;
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--co-bg) 95%, transparent);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--co-border);
    padding-bottom: 14px;
  }
  .mobile-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px 10px;
  }
  .mobile-back-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 500;
    color: var(--co-muted-fg);
    text-decoration: none;
  }
  .mobile-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--co-fg);
  }
  .mobile-progress { padding: 0 20px; }
  .mobile-progress-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .mobile-step-label { font-size: 13px; font-weight: 600; color: var(--co-fg); }
  .mobile-step-count { font-size: 12px; color: var(--co-muted-fg); }
  .mobile-progress-track {
    height: 3px;
    border-radius: 2px;
    background: var(--co-border);
    overflow: hidden;
    margin-bottom: 8px;
  }
  .mobile-progress-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--co-primary);
    transition: width 0.4s ease;
  }
  .mobile-progress-dots { display: flex; gap: 6px; }
  .mobile-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--co-border);
    transition: background 0.3s ease, width 0.3s ease;
  }
  .mobile-dot.active { background: var(--co-primary); width: 18px; border-radius: 3px; }
  .mobile-dot.done { background: var(--co-success); }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 100px 24px;
  }
  .empty-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--co-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: var(--co-muted-fg);
  }
  .empty-state h2 { font-size: 20px; font-weight: 700; margin-bottom: 8px; color: var(--co-fg); }
  .empty-state p { color: var(--co-muted-fg); font-size: 14px; margin-bottom: 24px; }

  /* ── Layout ── */
  .checkout-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 28px;
    align-items: start;
    padding-top: 32px;
  }
  @media (max-width: 960px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .cart-pane { order: -1; }
    .mobile-header { display: block; }
    .desktop-topbar { display: none; }
    .co-root { padding-top: 0; }
    .checkout-layout { padding-top: 20px; }
  }

  /* ── Wizard pane ── */
  .wizard-pane {
    background: var(--co-card);
    border: 1px solid var(--co-border);
    border-radius: var(--r-lg);
    padding: 32px;
    box-shadow: var(--shadow);
  }
  @media (max-width: 600px) { .wizard-pane { padding: 20px 16px; border-radius: 12px; } }

  /* Desktop topbar */
  .desktop-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--r-md);
    border: 1px solid var(--co-border);
    background: var(--co-bg);
    font-size: 13px;
    font-weight: 500;
    color: var(--co-muted-fg);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .back-link:hover { border-color: var(--co-primary); color: var(--co-fg); }
  .desktop-title { font-size: 22px; font-weight: 800; color: var(--co-fg); margin: 0; }

  /* ── Steps bar ── */
  .steps-bar {
    display: flex;
    align-items: center;
    margin-bottom: 32px;
  }
  .step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }
  .step-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--co-border);
    background: var(--co-bg);
