  /* ── Utilities ── */
  .hidden { display: none !important; }
</style>

<!-- ── Script ─────────────────────────────────────────────────────── -->
<script>
  // Wrap everything in an async IIFE so top-level await works safely
  // and any parse error doesn't kill the whole page script
  (async () => {

    /* ── Lazy import (Appwrite only needed on payment return) ── */
    let databases: any = null;
    let APPWRITE_DB_ID = '';
    let APPWRITE_ORDERS_COLLECTION_ID = '';
    let ID: any = null;

    /* ─────────────────────────────────────────────────────────────
       CONSTANTS
    ───────────────────────────────────────────────────────────── */
    const SHIPPING_FEES: Record<string, number> = {
      Yola: 1000,
      Jimeta: 2000,
    };
    const WHATSAPP_NUMBER = '2348085657927';

    const STEP_LABELS = ['Shipping Details', 'Choose Payment', 'Order Confirmed'];
    const STEP_PROGRESS = ['8%', '50%', '100%'];

    /* ─────────────────────────────────────────────────────────────
       STATE
    ───────────────────────────────────────────────────────────── */
    let currentStep = 1;
    let confirmedEmail = '';
    let currentTxRef = '';

    /* ─────────────────────────────────────────────────────────────
       CART HELPERS
    ───────────────────────────────────────────────────────────── */
    function getCart(): any[] {
      try { return JSON.parse(localStorage.getItem('cart') || '[]'); }
      catch { return []; }
    }

    function saveCart(items: any[]) {
      localStorage.setItem('cart', JSON.stringify(items));
      window.dispatchEvent(new Event('cart-updated'));
    }

    function fmt(n: number) {
      return '₦' + Number(n).toLocaleString('en-NG');
    }

    function subtotal(items: any[]) {
      return items.reduce((s, i) => s + (i.price * i.quantity), 0);
    }

    function getCity(): string {
      return (document.getElementById('city') as HTMLSelectElement)?.value || '';
    }

    function shippingFee(): number {
      return SHIPPING_FEES[getCity()] ?? 0;
    }

    /* ─────────────────────────────────────────────────────────────
       WHATSAPP LINK
    ───────────────────────────────────────────────────────────── */
    function buildWhatsAppHref(): string {
      const items = getCart();
      if (!items.length) return `https://wa.me/${WHATSAPP_NUMBER}`;
      const total = subtotal(items) + shippingFee();
      let msg = 'Hello ABKHD, I want to order:%0A%0A';
      items.forEach(i => {
        msg += `- ${encodeURIComponent(i.name)} x${i.quantity} = ${fmt(i.price * i.quantity)}%0A`;
      });
      const city = getCity();
      msg += `%0ADelivery (${city || 'TBD'}): ${city ? fmt(shippingFee()) : 'TBD'}`;
      msg += `%0ATotal: ${fmt(total)}%0A%0APlease confirm availability.`;
      return `https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`;
    }

    function updateWhatsAppLinks() {
      const href = buildWhatsAppHref();
      const el1 = document.getElementById('whatsapp-link') as HTMLAnchorElement;
      const el2 = document.getElementById('whatsapp-cart-btn') as HTMLAnchorElement;
      if (el1) el1.href = href;
      if (el2) el2.href = href;
    }

    /* ─────────────────────────────────────────────────────────────
       RENDER CART
    ───────────────────────────────────────────────────────────── */
    function renderCart(successMode = false) {
      const items = getCart();
      const grid   = document.getElementById('cart-items-grid')!;
      const empty  = document.getElementById('empty-state')!;
      const layout = document.getElementById('checkout-layout')!;

      if (!successMode && items.length === 0) {
        empty.classList.remove('hidden');
        layout.classList.add('hidden');
        return;
      }

      empty.classList.add('hidden');
      layout.classList.remove('hidden');

      // item count badge
      const totalQty = items.reduce((s: number, i: any) => s + i.quantity, 0);
      const countEl = document.getElementById('cart-item-count');
      if (countEl) countEl.textContent = `${totalQty} item${totalQty !== 1 ? 's' : ''}`;

      if (!grid) return;

      grid.innerHTML = items.map((item: any) => `
        <div class="cart-item ${successMode ? 'success-item' : ''}" data-cart-id="${item.cartId}">
          <img
            class="cart-item-img"
            src="${item.image}"
            alt="${item.name}"
            crossorigin="anonymous"
            onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22120%22 height=%2290%22%3E%3Crect fill=%22%23ddd%22 width=%22120%22 height=%2290%22/%3E%3C/svg%3E'"
          />
          <div class="cart-item-body">
            <div class="cart-item-name" title="${item.name}">${item.name}</div>
            <div class="cart-item-meta">${fmt(item.price)} each</div>
            <div class="cart-item-subtotal">${fmt(item.price * item.quantity)}</div>
            ${!successMode ? `
              <div class="qty-controls">
                <button class="qty-btn qty-dec" data-cart-id="${item.cartId}" ${item.quantity <= 1 ? 'disabled' : ''}>−</button>
                <span class="qty-value">${item.quantity}</span>
                <button class="qty-btn qty-inc" data-cart-id="${item.cartId}">+</button>
                <button class="remove-btn" data-cart-id="${item.cartId}">Remove</button>
              </div>
            ` : ''}
          </div>
        </div>
      `).join('');

      if (!successMode) {
        grid.querySelectorAll('.qty-dec').forEach(btn => {
          btn.addEventListener('click', () => adjustQty((btn as HTMLElement).dataset.cartId!, -1));
        });
        grid.querySelectorAll('.qty-inc').forEach(btn => {
          btn.addEventListener('click', () => adjustQty((btn as HTMLElement).dataset.cartId!, 1));
        });
        grid.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', () => removeItem((btn as HTMLElement).dataset.cartId!));
        });
      }

      updateSummary(successMode);
      updateWhatsAppLinks();
    }

    function adjustQty(cartId: string, delta: number) {
      const items = getCart().map((i: any) =>
        i.cartId === cartId ? { ...i, quantity: Math.max(1, i.quantity + delta) } : i
      );
      saveCart(items);
      renderCart();
    }

    function removeItem(cartId: string) {
      const items = getCart().filter((i: any) => i.cartId !== cartId);
      saveCart(items);
      renderCart();
      if (items.length === 0) goToTab(1);
    }

    function updateSummary(successMode = false) {
      const items = getCart();
      const sub = subtotal(items);
      const ship = shippingFee();
      const city = getCity();
      const total = sub + ship;

      const summaryEl = document.getElementById('price-summary');
      const paidEl    = document.getElementById('paid-banner');
      if (!summaryEl || !paidEl) return;

      if (successMode) {
        summaryEl.classList.add('hidden');
        paidEl.classList.remove('hidden');
        return;
      }

      summaryEl.classList.remove('hidden');
      paidEl.classList.add('hidden');

      const subEl   = document.getElementById('summary-subtotal');
      const shipEl  = document.getElementById('summary-shipping');
      const totalEl = document.getElementById('summary-total');
      if (subEl) subEl.textContent = fmt(sub);
      if (shipEl) shipEl.textContent = city ? fmt(ship) : 'Select city';
      if (totalEl) totalEl.textContent = city ? fmt(total) : fmt(sub);

      // Payment tab summary strip
      const pssSubEl   = document.getElementById('pss-subtotal');
      const pssShipEl  = document.getElementById('pss-shipping');
      const pssTotalEl = document.getElementById('pss-total');
      if (pssSubEl) pssSubEl.textContent = fmt(sub);
      if (pssShipEl) pssShipEl.textContent = city ? fmt(ship) : '—';
      if (pssTotalEl) pssTotalEl.textContent = city ? fmt(total) : fmt(sub);
    }

    /* ─────────────────────────────────────────────────────────────
       TAB / STEP NAVIGATION
    ───────────────────────────────────────────────────────────── */
    function goToTab(tab: number) {
      currentStep = tab;

      // Tab panels
      document.querySelectorAll<HTMLElement>('.tab-panel').forEach((el, i) => {
        const isActive = i + 1 === tab;
        el.classList.toggle('hidden', !isActive);
        el.classList.toggle('active', isActive);
      });

      // Desktop step circles
      document.querySelectorAll<HTMLElement>('.step-item').forEach(el => {
        const n = parseInt(el.dataset.step || '0');
        el.classList.remove('active', 'done');
        if (n === tab) el.classList.add('active');
        if (n < tab)  el.classList.add('done');
      });

      // Desktop step lines
      document.querySelectorAll<HTMLElement>('.step-line').forEach(el => {
        const n = parseInt(el.dataset.line || '0');
        el.classList.toggle('done', n < tab);
      });

      // Mobile progress
      const labelEl = document.getElementById('mobile-step-label');
      const countEl = document.getElementById('mobile-step-count');
      const fillEl  = document.getElementById('mobile-progress-fill');
      if (labelEl) labelEl.textContent = STEP_LABELS[tab - 1];
      if (countEl) countEl.textContent = `${tab} / 3`;
      if (fillEl)  fillEl.style.width  = STEP_PROGRESS[tab - 1];

      document.querySelectorAll<HTMLElement>('.mobile-dot').forEach(el => {
        const n = parseInt(el.dataset.step || '0');
        el.classList.remove('active', 'done');
        if (n === tab) el.classList.add('active');
        if (n < tab)  el.classList.add('done');
      });

      // Scroll to top of wizard on mobile
      if (window.innerWidth < 960) {
        document.getElementById('wizard-pane')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      if (tab === 3) renderCart(true);
    }

    /* ─────────────────────────────────────────────────────────────
       DELIVERY CALLOUT
    ───────────────────────────────────────────────────────────── */
    function updateDeliveryCallout() {
      const city = getCity();
      const callout = document.getElementById('delivery-callout');
      const text    = document.getElementById('delivery-callout-text');
      if (!callout || !text) return;
      if (city && SHIPPING_FEES[city] !== undefined) {
        text.textContent = `Delivery to ${city}: ${fmt(SHIPPING_FEES[city])}`;
        callout.classList.remove('hidden');
      } else {
        callout.classList.add('hidden');
      }
    }

    /* ─────────────────────────────────────────────────────────────
       FORM EVENTS
    ───────────────────────────────────────────────────────────── */
    document.getElementById('details-form')?.addEventListener('submit', e => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      let valid = true;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]').forEach(el => {
        if (!el.value.trim()) { el.classList.add('invalid'); valid = false; }
        else el.classList.remove('invalid');
      });
      if (!valid) return;
      updateSummary();
      goToTab(2);
    });

    document.querySelectorAll('.details-form input, .details-form select, #details-form input, #details-form select')
      .forEach(el => el.addEventListener('input', () => (el as HTMLElement).classList.remove('invalid')));

    document.getElementById('city')?.addEventListener('change', () => {
      updateSummary();
      updateDeliveryCallout();
      updateWhatsAppLinks();
    });

    document.getElementById('back-to-details')?.addEventListener('click', () => goToTab(1));

    /* ─────────────────────────────────────────────────────────────
       SQUAD PAYMENT
    ───────────────────────────────────────────────────────────── */
    document.getElementById('squad-btn')?.addEventListener('click', async () => {
      const items = getCart();
      if (!items.length) return;

      const email   = (document.getElementById('email') as HTMLInputElement).value;
      const phone   = (document.getElementById('phone') as HTMLInputElement).value;
      const name    = (document.getElementById('fullName') as HTMLInputElement).value;
      const address = (document.getElementById('address') as HTMLInputElement).value;
      const city    = (document.getElementById('city') as HTMLSelectElement).value;
      const state   = (document.getElementById('state') as HTMLSelectElement).value;
      const postal  = (document.getElementById('postalCode') as HTMLInputElement).value;
      const ship    = shippingFee();
      const total   = subtotal(items) + ship;

      currentTxRef   = `ABKHD-${Date.now()}`;
      confirmedEmail = email;

      const btn = document.getElementById('squad-btn') as HTMLButtonElement;
      if (!btn) return;
      btn.disabled = true;
      const pmName = btn.querySelector('.pm-name');
      if (pmName) pmName.textContent = 'Initializing…';

      try {
        const response = await fetch('/api/squad-initiate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email, amount: total, customerName: name, phone,
            address, city, state, postalCode: postal || '',
            items, transactionRef: currentTxRef,
          }),
        });

        const result = await response.json();
        if (!response.ok || !result.checkoutUrl) throw new Error(result.error || 'Failed to initialize payment');

        sessionStorage.setItem('pendingOrder', JSON.stringify({
          txRef: currentTxRef, email, name, phone,
          address, city, state, postalCode: postal || '', items, total,
        }));

        window.location.href = result.checkoutUrl;

      } catch (err) {
        console.error('Squad init error:', err);
        alert('Failed to initialize payment gateway. Please try again.');
        btn.disabled = false;
        if (pmName) pmName.textContent = 'Squad';
      }
    });

    /* ─────────────────────────────────────────────────────────────
       CART EVENT LISTENERS (for cross-tab updates)
    ───────────────────────────────────────────────────────────── */
    window.addEventListener('storage', (e) => {
      if (e.key === 'cart' || e.key === null) renderCart();
    });
    window.addEventListener('cart-updated', () => renderCart());

    /* ─────────────────────────────────────────────────────────────
       PAYMENT RETURN (Squad redirect back)
    ───────────────────────────────────────────────────────────── */
    const urlParams   = new URLSearchParams(window.location.search);
    const paymentRef  = urlParams.get('reference');

    if (paymentRef) {
      const emailFromUrl = urlParams.get('email') || '';
      let pendingOrder: any = null;
      try { pendingOrder = JSON.parse(sessionStorage.getItem('pendingOrder') || 'null'); }
      catch {}

      if (pendingOrder) {
        try {
          // Lazy-load Appwrite only when needed
          const appwrite = await import('../lib/appwrite');
          databases = appwrite.databases;
          APPWRITE_DB_ID = appwrite.APPWRITE_DB_ID;
          APPWRITE_ORDERS_COLLECTION_ID = appwrite.APPWRITE_ORDERS_COLLECTION_ID;
          ID = appwrite.ID;

          const orderData = {
            customer:        JSON.stringify({ email: emailFromUrl || pendingOrder.email, name: pendingOrder.name, phone: pendingOrder.phone }),
            customerEmail:   emailFromUrl || pendingOrder.email,
            customerName:    pendingOrder.name,
            items:           JSON.stringify(pendingOrder.items),
            total:           pendingOrder.total,
            totalAmount:     pendingOrder.total,
            paymentRef:      paymentRef,
            customerPhone:   pendingOrder.phone,
            address:         pendingOrder.address,
            city:            pendingOrder.city,
            state:           pendingOrder.state,
            postalCode:      pendingOrder.postalCode || '',
            status:          'paid',
            paymentMethod:   'card',
          };

          await databases.createDocument(APPWRITE_DB_ID, APPWRITE_ORDERS_COLLECTION_ID, ID.unique(), orderData);

          // Stock reduction (non-critical)
          try {
            const { reduceMultipleProductsStock } = await import('../lib/stock-manager');
            await reduceMultipleProductsStock(
              pendingOrder.items.map((i: any) => ({ productId: i.id, quantity: i.quantity }))
            );
          } catch (se) {
            console.error('Stock reduction failed (non-critical):', se);
          }

          localStorage.removeItem('cart');
          window.dispatchEvent(new Event('cart-updated'));

        } catch (err) {
          console.error('Order creation failed:', err);
        }
      }

      // Populate success tab
      const refEl   = document.getElementById('order-ref-display');
      const emailEl = document.getElementById('confirm-email');
      const titleEl = document.getElementById('cart-pane-title');
      if (refEl)   refEl.textContent   = paymentRef;
      if (emailEl) emailEl.textContent = emailFromUrl || pendingOrder?.email || '—';
      if (titleEl) titleEl.textContent = 'Your Order';

      window.history.replaceState({}, '', window.location.pathname);
      sessionStorage.removeItem('pendingOrder');

      goToTab(3);

    } else {
      // Normal page load — render cart
      renderCart();
    }

  })(); // end async IIFE
</script>