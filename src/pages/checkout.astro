<!-- ═══════════════════════════════════════════════════════════════
     SCRIPT
═══════════════════════════════════════════════════════════════ -->
<script>
(async () => {

  /* ── Constants ── */
  const SHIP: Record<string, number> = { Yola: 1000, Jimeta: 2000 };
  const WA = '2348085657927';
  const STEP_LABELS   = ['Shipping Details', 'Choose Payment', 'Order Confirmed'];
  const STEP_PROGRESS = ['8%', '50%', '100%'];

  /* ── Helpers ── */
  const $  = (id: string) => document.getElementById(id);
  const fmt = (n: number) => '₦' + Number(n).toLocaleString('en-NG');

  function getCart(): any[] {
    try { return JSON.parse(localStorage.getItem('cart') || '[]'); }
    catch { return []; }
  }
  function saveCart(items: any[]) {
    localStorage.setItem('cart', JSON.stringify(items));
    window.dispatchEvent(new Event('cart-updated'));
  }
  function sub(items: any[]) {
    return items.reduce((s: number, i: any) => s + i.price * i.quantity, 0);
  }
  function getCity(): string {
    return ($('co-city') as HTMLSelectElement)?.value || '';
  }
  function shipFee(): number { return SHIP[getCity()] ?? 0; }

  /* ── WhatsApp ── */
  function waHref(): string {
    const items = getCart();
    if (!items.length) return `https://wa.me/${WA}`;
    const city  = getCity();
    const total = sub(items) + shipFee();
    let msg = 'Hello ABKHD, I want to order:%0A%0A';
    items.forEach((i: any) => {
      msg += `- ${encodeURIComponent(i.name)} x${i.quantity} = ${fmt(i.price * i.quantity)}%0A`;
    });
    msg += `%0ADelivery (${city || 'TBD'}): ${city ? fmt(shipFee()) : 'TBD'}`;
    msg += `%0ATotal: ${fmt(total)}%0A%0APlease confirm availability.`;
    return `https://wa.me/${WA}?text=${msg}`;
  }
  function updateWA() {
    const h = waHref();
    const a = $('co-wa-link') as HTMLAnchorElement;
    const b = $('co-wa-cart') as HTMLAnchorElement;
    if (a) a.href = h;
    if (b) b.href = h;
  }

  /* ── Render cart items ── */
  function renderCart(successMode = false) {
    const items  = getCart();
    const box    = $('co-items')!;
    const empty  = $('co-empty')!;
    const layout = $('co-layout')!;

    if (!successMode && items.length === 0) {
      empty.classList.remove('co-hidden');
      layout.classList.add('co-hidden');
      return;
    }
    empty.classList.add('co-hidden');
    layout.classList.remove('co-hidden');

    const totalQty = items.reduce((s: number, i: any) => s + i.quantity, 0);
    const countEl  = $('co-cart-count');
    if (countEl) countEl.textContent = `${totalQty} item${totalQty !== 1 ? 's' : ''}`;

    if (!box) return;

    /* 
      Key: all classes here are co-prefixed.
      The image uses class="co-thumb" and is a direct child of .co-item
      so the CSS rule `.co-item > .co-thumb` has maximum specificity.
      No global style targets .co-thumb.
    */
    box.innerHTML = items.map((item: any) => `
      <div class="co-item${successMode ? ' co-item--success' : ''}" data-id="${item.cartId}">
        <img
          class="co-thumb"
          src="${item.image}"
          alt="${item.name}"
          crossorigin="anonymous"
          onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2262%22 height=%2262%22%3E%3Crect fill=%22%23ccc%22 width=%2262%22 height=%2262%22/%3E%3C/svg%3E'"
        />
        <div class="co-item-body">
          <div class="co-item-name" title="${item.name}">${item.name}</div>
          <div class="co-item-meta">${fmt(item.price)} each</div>
          <div class="co-item-sub">${fmt(item.price * item.quantity)}</div>
          ${!successMode ? `
            <div class="co-qty">
              <button class="co-qty-btn co-dec" data-id="${item.cartId}" ${item.quantity <= 1 ? 'disabled' : ''}>−</button>
              <span class="co-qty-val">${item.quantity}</span>
              <button class="co-qty-btn co-inc" data-id="${item.cartId}">+</button>
              <button class="co-rm-btn" data-id="${item.cartId}">Remove</button>
            </div>
          ` : ''}
        </div>
      </div>
    `).join('');

    if (!successMode) {
      box.querySelectorAll<HTMLElement>('.co-dec').forEach(b =>
        b.addEventListener('click', () => adjustQty(b.dataset.id!, -1))
      );
      box.querySelectorAll<HTMLElement>('.co-inc').forEach(b =>
        b.addEventListener('click', () => adjustQty(b.dataset.id!, 1))
      );
      box.querySelectorAll<HTMLElement>('.co-rm-btn').forEach(b =>
        b.addEventListener('click', () => removeItem(b.dataset.id!))
      );
    }

    updateSummary(successMode);
    updateWA();
  }

  function adjustQty(id: string, delta: number) {
    const items = getCart().map((i: any) =>
      i.cartId === id ? { ...i, quantity: Math.max(1, i.quantity + delta) } : i
    );
    saveCart(items);
    renderCart();
  }
  function removeItem(id: string) {
    const items = getCart().filter((i: any) => i.cartId !== id);
    saveCart(items);
    renderCart();
    if (items.length === 0) goToTab(1);
  }

  function updateSummary(successMode = false) {
    const items = getCart();
    const s     = sub(items);
    const ship  = shipFee();
    const city  = getCity();
    const total = s + ship;

    const summEl = $('co-summary');
    const paidEl = $('co-paid');
    if (!summEl || !paidEl) return;

    if (successMode) {
      summEl.classList.add('co-hidden');
      paidEl.classList.remove('co-hidden');
      return;
    }
    summEl.classList.remove('co-hidden');
    paidEl.classList.add('co-hidden');

    const se = $('co-sum-sub');   if (se) se.textContent = fmt(s);
    const he = $('co-sum-ship');  if (he) he.textContent = city ? fmt(ship) : 'Select city';
    const te = $('co-sum-total'); if (te) te.textContent = city ? fmt(total) : fmt(s);

    const ps = $('co-pss-sub');   if (ps) ps.textContent = fmt(s);
    const ph = $('co-pss-ship');  if (ph) ph.textContent = city ? fmt(ship) : '—';
    const pt = $('co-pss-total'); if (pt) pt.textContent = city ? fmt(total) : fmt(s);
  }

  /* ── Step navigation ── */
  function goToTab(tab: number) {
    // Panels
    document.querySelectorAll<HTMLElement>('.co-panel').forEach((el, i) => {
      const active = i + 1 === tab;
      el.classList.toggle('co-hidden', !active);
      el.classList.toggle('co-panel--active', active);
    });

    // Desktop step circles
    document.querySelectorAll<HTMLElement>('.co-step').forEach(el => {
      const n = parseInt(el.dataset.step || '0');
      el.classList.remove('co-step--active', 'co-step--done');
      if (n === tab) el.classList.add('co-step--active');
      if (n < tab)   el.classList.add('co-step--done');
    });

    // Lines
    document.querySelectorAll<HTMLElement>('.co-step-line').forEach(el => {
      const n = parseInt(el.dataset.line || '0');
      el.classList.toggle('co-step-line--done', n < tab);
    });

    // Mobile progress
    const lbl  = $('co-mob-step-lbl');
    const ct   = $('co-mob-step-ct');
    const fill = $('co-mob-fill') as HTMLElement;
    if (lbl)  lbl.textContent  = STEP_LABELS[tab - 1];
    if (ct)   ct.textContent   = `${tab} / 3`;
    if (fill) fill.style.width = STEP_PROGRESS[tab - 1];

    document.querySelectorAll<HTMLElement>('.co-dot').forEach(el => {
      const n = parseInt(el.dataset.step || '0');
      el.classList.remove('co-dot--active', 'co-dot--done');
      if (n === tab) el.classList.add('co-dot--active');
      if (n < tab)   el.classList.add('co-dot--done');
    });

    if (window.innerWidth < 960) {
      $('co-wizard')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    if (tab === 3) renderCart(true);
  }

  /* ── Delivery callout ── */
  function updateDeliveryNote() {
    const city = getCity();
    const el   = $('co-delivery-note');
    const txt  = $('co-delivery-note-text');
    if (!el || !txt) return;
    if (city && SHIP[city] !== undefined) {
      txt.textContent = `Delivery to ${city}: ${fmt(SHIP[city])}`;
      el.classList.remove('co-hidden');
    } else {
      el.classList.add('co-hidden');
    }
  }

  /* ── Form ── */
  $('co-details-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    let ok = true;
    form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]').forEach(el => {
      if (!el.value.trim()) { el.classList.add('co-invalid'); ok = false; }
      else el.classList.remove('co-invalid');
    });
    if (!ok) return;
    updateSummary();
    goToTab(2);
  });

  document.querySelectorAll('#co-details-form .co-input, #co-details-form .co-select').forEach(el =>
    el.addEventListener('input', () => el.classList.remove('co-invalid'))
  );

  $('co-city')?.addEventListener('change', () => {
    updateSummary();
    updateDeliveryNote();
    updateWA();
  });

  $('co-back-btn')?.addEventListener('click', () => goToTab(1));

  /* ── Squad ── */
  $('co-squad-btn')?.addEventListener('click', async () => {
    const items = getCart();
    if (!items.length) return;

    const email   = ($('co-email')   as HTMLInputElement).value;
    const phone   = ($('co-phone')   as HTMLInputElement).value;
    const name    = ($('co-fullName') as HTMLInputElement).value;
    const address = ($('co-address') as HTMLInputElement).value;
    const city    = ($('co-city')    as HTMLSelectElement).value;
    const state   = ($('co-state')   as HTMLSelectElement).value;
    const postal  = ($('co-postal')  as HTMLInputElement).value;
    const ship    = shipFee();
    const total   = sub(items) + ship;
    const txRef   = `ABKHD-${Date.now()}`;

    const btn = $('co-squad-btn') as HTMLButtonElement;
    const nm  = btn?.querySelector('.co-pm-name');
    if (btn) btn.disabled = true;
    if (nm)  nm.textContent = 'Initializing…';

    try {
      const res  = await fetch('/api/squad-initiate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, amount: total, customerName: name, phone, address, city, state, postalCode: postal || '', items, transactionRef: txRef }),
      });
      const data = await res.json();
      if (!res.ok || !data.checkoutUrl) {
        const errorMsg = data.error === 'An unexpected error occurred' && data.message 
          ? `${data.error}: ${data.message}` 
          : (data.error || 'Failed to initialize');
        throw new Error(errorMsg);
      }

      sessionStorage.setItem('pendingOrder', JSON.stringify({ txRef, email, name, phone, address, city, state, postalCode: postal || '', items, total }));
      window.location.href = data.checkoutUrl;

    } catch (err) {
      console.error('Squad init error:', err);
      alert('Failed to initialize payment. Please try again.');
      if (btn) btn.disabled = false;
      if (nm)  nm.textContent = 'Squad';
    }
  });

  /* ── Cross-tab cart sync ── */
  window.addEventListener('storage', e => { if (e.key === 'cart' || !e.key) renderCart(); });
  window.addEventListener('cart-updated', () => renderCart());

  /* ── Payment return ── */
  const params     = new URLSearchParams(window.location.search);
  const paymentRef = params.get('reference');

  if (paymentRef) {
    const emailFromUrl = params.get('email') || '';
    let pending: any = null;
    try { pending = JSON.parse(sessionStorage.getItem('pendingOrder') || 'null'); } catch {}

    if (pending) {
      try {
        const { databases, APPWRITE_DB_ID, APPWRITE_ORDERS_COLLECTION_ID, ID } = await import('../lib/appwrite');
        await databases.createDocument(APPWRITE_DB_ID, APPWRITE_ORDERS_COLLECTION_ID, ID.unique(), {
          customer:       JSON.stringify({ email: emailFromUrl || pending.email, name: pending.name, phone: pending.phone }),
          customerEmail:  emailFromUrl || pending.email,
          customerName:   pending.name,
          items:          JSON.stringify(pending.items),
          total:          pending.total,
          totalAmount:    pending.total,
          paymentRef,
          customerPhone:  pending.phone,
          address:        pending.address,
          city:           pending.city,
          state:          pending.state,
          postalCode:     pending.postalCode || '',
          status:         'paid',
          paymentMethod:  'card',
        });
        try {
          const { reduceMultipleProductsStock } = await import('../lib/stock-manager');
          await reduceMultipleProductsStock(pending.items.map((i: any) => ({ productId: i.id, quantity: i.quantity })));
        } catch (e) { console.error('Stock reduction (non-critical):', e); }
        localStorage.removeItem('cart');
        window.dispatchEvent(new Event('cart-updated'));
      } catch (e) { console.error('Order save error:', e); }
    }

    const refEl   = $('co-order-ref');
    const emailEl = $('co-confirm-email');
    const titleEl = $('co-cart-title');
    if (refEl)   refEl.textContent   = paymentRef;
    if (emailEl) emailEl.textContent = emailFromUrl || pending?.email || '—';
    if (titleEl) titleEl.textContent = 'Your Order';

    window.history.replaceState({}, '', window.location.pathname);
    sessionStorage.removeItem('pendingOrder');
    goToTab(3);

  } else {
    renderCart();
  }

})();
</script>