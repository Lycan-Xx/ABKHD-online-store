---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Checkout — ABKHD Store">
  <Header slot="header" />

  <div class="co-root">

    <!-- ── Mobile sticky progress header ── -->
    <div class="co-mob-hdr" id="co-mob-hdr">
      <div class="co-mob-hdr-inner">
        <a href="/shop" class="co-mob-back">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          Shop
        </a>
        <span class="co-mob-title">Checkout</span>
        <div style="width:52px"></div>
      </div>
      <div class="co-mob-prog">
        <div class="co-mob-prog-row">
          <span class="co-mob-step-lbl" id="co-mob-step-lbl">Shipping Details</span>
          <span class="co-mob-step-ct" id="co-mob-step-ct">1 / 3</span>
        </div>
        <div class="co-mob-track">
          <div class="co-mob-fill" id="co-mob-fill" style="width:8%"></div>
        </div>
        <div class="co-mob-dots">
          <div class="co-dot co-dot--active" data-step="1"></div>
          <div class="co-dot" data-step="2"></div>
          <div class="co-dot" data-step="3"></div>
        </div>
      </div>
    </div>

    <!-- ── Empty state ── -->
    <div id="co-empty" class="co-empty co-hidden">
      <div class="co-empty-icon">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
      <h2 class="co-empty-h">Your cart is empty</h2>
      <p class="co-empty-p">Add some items before checking out.</p>
      <a href="/shop" class="co-cta">Browse Products</a>
    </div>

    <!-- ── Main grid ── -->
    <div id="co-layout" class="co-layout co-hidden">

      <!-- LEFT: wizard -->
      <div class="co-wizard" id="co-wizard">

        <!-- Desktop topbar -->
        <div class="co-desk-bar">
          <a href="/shop" class="co-back-link">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            Continue Shopping
          </a>
          <h1 class="co-desk-title">Checkout</h1>
        </div>

        <!-- Step bar -->
        <div class="co-steps">
          <div class="co-step co-step--active" data-step="1">
            <div class="co-step-circle">
              <span class="co-step-num">1</span>
              <svg class="co-step-check co-hidden" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="co-step-lbl">Details</span>
          </div>
          <div class="co-step-line" data-line="1"></div>
          <div class="co-step" data-step="2">
            <div class="co-step-circle">
              <span class="co-step-num">2</span>
              <svg class="co-step-check co-hidden" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="co-step-lbl">Payment</span>
          </div>
          <div class="co-step-line" data-line="2"></div>
          <div class="co-step" data-step="3">
            <div class="co-step-circle">
              <span class="co-step-num">3</span>
              <svg class="co-step-check co-hidden" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="co-step-lbl">Confirmed</span>
          </div>
        </div>

        <!-- ── TAB 1: Details ── -->
        <div class="co-panel co-panel--active" id="co-tab-details">
          <div class="co-panel-hdr">
            <h2 class="co-panel-title">Shipping Details</h2>
            <p class="co-panel-sub">Where should we deliver your order?</p>
          </div>

          <form id="co-details-form" novalidate>
            <div class="co-field-row">
              <div class="co-field">
                <label class="co-label" for="co-fullName">Full Name <span class="co-req">*</span></label>
                <input class="co-input" type="text" id="co-fullName" name="fullName" placeholder="Amina Yusuf" required />
              </div>
              <div class="co-field">
                <label class="co-label" for="co-email">Email <span class="co-req">*</span></label>
                <input class="co-input" type="email" id="co-email" name="email" placeholder="you@example.com" required />
              </div>
            </div>

            <div class="co-field">
              <label class="co-label" for="co-phone">Phone Number <span class="co-req">*</span></label>
              <input class="co-input" type="tel" id="co-phone" name="phone" placeholder="+2348012345678" required />
            </div>

            <div class="co-field">
              <label class="co-label" for="co-address">Delivery Address <span class="co-req">*</span></label>
              <input class="co-input" type="text" id="co-address" name="address" placeholder="No. 12, Galadima Road" required />
            </div>

            <div class="co-field-row">
              <div class="co-field">
                <label class="co-label" for="co-city">City <span class="co-req">*</span></label>
                <div class="co-select-wrap">
                  <select class="co-select" id="co-city" name="city" required>
                    <option value="" disabled selected>Select city</option>
                    <option value="Yola">Yola</option>
                    <option value="Jimeta">Jimeta</option>
                  </select>
                  <svg class="co-select-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div class="co-field">
                <label class="co-label" for="co-state">State</label>
                <div class="co-select-wrap">
                  <select class="co-select" id="co-state" name="state" disabled>
                    <option value="Adamawa">Adamawa</option>
                  </select>
                  <svg class="co-select-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
            </div>

            <div class="co-field">
              <label class="co-label" for="co-postal">Postal Code <span class="co-optional">(optional)</span></label>
              <input class="co-input" type="text" id="co-postal" name="postalCode" placeholder="640001" />
            </div>

            <!-- Delivery callout -->
            <div class="co-delivery-note co-hidden" id="co-delivery-note">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              <span id="co-delivery-note-text">Delivery to Yola: ₦1,000</span>
            </div>

            <button type="submit" class="co-cta co-cta--full">
              Proceed to Payment
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </form>
        </div>

        <!-- ── TAB 2: Payment ── -->
        <div class="co-panel co-hidden" id="co-tab-payment">
          <div class="co-panel-hdr">
            <h2 class="co-panel-title">Choose Payment</h2>
            <p class="co-panel-sub">Select how you'd like to complete your purchase.</p>
          </div>

          <!-- Mini order summary -->
          <div class="co-mini-summary">
            <div class="co-mini-row">
              <span>Subtotal</span><span id="co-pss-sub">₦0</span>
            </div>
            <div class="co-mini-row">
              <span>Delivery</span><span id="co-pss-ship">—</span>
            </div>
            <div class="co-mini-row co-mini-row--total">
              <span>Total due</span><span id="co-pss-total">₦0</span>
            </div>
          </div>

          <!-- Payment options -->
          <div class="co-pm-list">
            <button id="co-squad-btn" class="co-pm-card">
              <span class="co-pm-logo">
                <svg width="28" height="28" viewBox="0 0 40 40" fill="none">
                  <rect width="40" height="40" rx="10" fill="#FF6B00"/>
                  <path d="M10 28L20 12L30 28H10Z" fill="white" opacity="0.9"/>
                </svg>
              </span>
              <span class="co-pm-info">
                <span class="co-pm-name">Squad</span>
                <span class="co-pm-desc">Card, bank transfer, or USSD</span>
              </span>
              <svg class="co-pm-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>

            <div class="co-pm-card co-pm-card--disabled">
              <span class="co-pm-logo">
                <svg width="28" height="28" viewBox="0 0 40 40" fill="none">
                  <rect width="40" height="40" rx="10" fill="#00C3F7"/>
                  <rect x="8" y="15" width="24" height="4" rx="2" fill="white"/>
                  <rect x="8" y="22" width="16" height="4" rx="2" fill="white" opacity="0.6"/>
                </svg>
              </span>
              <span class="co-pm-info">
                <span class="co-pm-name">Paystack</span>
                <span class="co-pm-desc">Cards, bank transfer & more</span>
              </span>
              <span class="co-pm-badge">Soon</span>
            </div>
          </div>

          <!-- WhatsApp fallback -->
          <div class="co-wa-section">
            <p class="co-wa-label">Prefer to order manually?</p>
            <a id="co-wa-link" href="#" target="_blank" rel="noopener" class="co-wa-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              Chat via WhatsApp
            </a>
          </div>

          <button class="co-ghost-btn" id="co-back-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Details
          </button>
        </div>

        <!-- ── TAB 3: Confirmed ── -->
        <div class="co-panel co-hidden" id="co-tab-confirmed">
          <div class="co-success">
            <div class="co-success-ring">
              <div class="co-success-ring-bg"></div>
              <svg class="co-success-ico" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h2 class="co-success-title">Order Confirmed!</h2>
            <p class="co-success-msg">Thank you for your purchase. We'll process your order within 1–2 business days.</p>

            <div class="co-ref-card">
              <span class="co-ref-label">Order Reference</span>
              <span class="co-ref-val" id="co-order-ref">—</span>
            </div>

            <div class="co-next-steps">
              <div class="co-next-step">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>Confirmation sent to <strong id="co-confirm-email">—</strong></span>
              </div>
              <div class="co-next-step">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                <span>Processed within 1–2 business days</span>
              </div>
              <div class="co-next-step">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Tracking info sent once dispatched</span>
              </div>
            </div>

            <!-- Receipt slot — drop a <button> or <a> here when ready -->
            <div id="co-receipt-slot"></div>

            <div class="co-success-actions">
              <a href="/shop" class="co-cta">Continue Shopping</a>
              <a href="/" class="co-ghost-btn" style="margin-top:0">Back to Home</a>
            </div>
          </div>
        </div>

      </div><!-- /co-wizard -->

      <!-- RIGHT: cart panel -->
      <div class="co-cart-pane" id="co-cart-pane">
        <div class="co-cart-box">
          <div class="co-cart-hdr">
            <h3 class="co-cart-title" id="co-cart-title">Your Cart</h3>
            <span class="co-cart-count" id="co-cart-count">0 items</span>
          </div>

          <!-- Items rendered by JS -->
          <div id="co-items" class="co-items"></div>

          <!-- Summary -->
          <div id="co-summary" class="co-summary">
            <div class="co-sum-row">
              <span>Subtotal</span>
              <span id="co-sum-sub">₦0</span>
            </div>
            <div class="co-sum-row">
              <span>Delivery</span>
              <span id="co-sum-ship">Select city</span>
            </div>
            <div class="co-sum-divider"></div>
            <div class="co-sum-row co-sum-row--total">
              <span>Total</span>
              <span id="co-sum-total">₦0</span>
            </div>
          </div>

          <!-- Paid banner -->
          <div id="co-paid" class="co-paid co-hidden">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Payment successful</span>
          </div>

          <!-- WhatsApp tertiary -->
          <a id="co-wa-cart" href="#" target="_blank" rel="noopener" class="co-wa-cart">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Order via WhatsApp instead
          </a>
        </div>
      </div>

    </div><!-- /co-layout -->

  </div><!-- /co-root -->

  <Footer slot="footer" />
</Layout>

<!-- ═══════════════════════════════════════════════════════════════
     STYLES — all selectors prefixed co- to avoid any global clash
     Bootstrap Icons, Tailwind, and global.css cannot override these
═══════════════════════════════════════════════════════════════ -->
<style is:global>
  /* ── Tokens ── */
  .co-root {
    --cob: hsl(var(--background));
    --coc: hsl(var(--card));
    --cobr: hsl(var(--border));
    --cop: hsl(var(--primary));
    --copf: hsl(var(--primary-foreground));
    --com: hsl(var(--muted));
    --comf: hsl(var(--muted-foreground));
    --cof: hsl(var(--foreground));
    --cos: #16a34a;
    --cos-bg: #f0fdf4;
    --cos-bd: #bbf7d0;
    --co-r: 10px;
    --co-rl: 14px;

    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px 80px;
    min-height: 70vh;
    box-sizing: border-box;
  }

  /* ── Utility ── */
  .co-root .co-hidden, .co-hidden { display: none !important; }

  /* ═══ MOBILE HEADER ═══ */
  .co-mob-hdr {
    display: none;
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--cob) 96%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--cobr);
    padding-bottom: 12px;
  }
  .co-mob-hdr-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px 8px;
  }
  .co-mob-back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
    color: var(--comf);
    text-decoration: none;
  }
  .co-mob-title { font-size: 15px; font-weight: 700; color: var(--cof); }
  .co-mob-prog { padding: 0 20px; }
  .co-mob-prog-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
  }
  .co-mob-step-lbl { font-size: 12px; font-weight: 600; color: var(--cof); }
  .co-mob-step-ct  { font-size: 11px; color: var(--comf); }
  .co-mob-track {
    height: 3px;
    border-radius: 2px;
    background: var(--cobr);
    overflow: hidden;
    margin-bottom: 7px;
  }
  .co-mob-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--cop);
    transition: width 0.4s ease;
  }
  .co-mob-dots { display: flex; gap: 5px; }
  .co-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cobr);
    transition: background 0.3s, width 0.3s;
  }
  .co-dot--active { background: var(--cop); width: 18px; border-radius: 3px; }
  .co-dot--done   { background: var(--cos); }

  /* ═══ EMPTY STATE ═══ */
  .co-empty { text-align: center; padding: 90px 24px; }
  .co-empty-icon {
    width: 76px; height: 76px;
    border-radius: 50%;
    background: var(--com);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 18px;
    color: var(--comf);
  }
  .co-empty-h { font-size: 19px; font-weight: 700; margin: 0 0 8px; color: var(--cof); }
  .co-empty-p { font-size: 14px; color: var(--comf); margin: 0 0 22px; }

  /* ═══ LAYOUT GRID ═══ */
  .co-layout {
    display: grid;
    grid-template-columns: 1fr 390px;
    gap: 26px;
    align-items: start;
    padding-top: 30px;
  }
  @media (max-width: 960px) {
    .co-layout { grid-template-columns: 1fr; padding-top: 18px; }
    .co-cart-pane { order: -1; }
    .co-mob-hdr { display: block; }
    .co-desk-bar { display: none; }
    .co-root { padding-top: 0; }
  }

  /* ═══ WIZARD PANE ═══ */
  .co-wizard {
    background: var(--coc);
    border: 1px solid var(--cobr);
    border-radius: var(--co-rl);
    padding: 30px;
    box-shadow: 0 2px 18px rgba(0,0,0,0.07);
  }
  @media (max-width: 600px) { .co-wizard { padding: 18px 14px; } }

  /* Desktop topbar */
  .co-desk-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 26px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .co-back-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 13px;
    border-radius: var(--co-r);
    border: 1px solid var(--cobr);
    background: var(--cob);
    font-size: 12px;
    font-weight: 500;
    color: var(--comf);
