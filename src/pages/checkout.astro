  .qty-btn:active:not(:disabled) { transform: scale(0.98); }
  .qty-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .qty-value { font-size: 13px; font-weight: 700; min-width: 20px; text-align: center; color: var(--co-fg); }
  .remove-btn {
