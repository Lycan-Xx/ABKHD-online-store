---
const SQUAD_PUBLIC_KEY = import.meta.env.PUBLIC_SQUAD_PUBLIC_KEY;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Squad Payment Test</title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      max-width: 600px;
      margin: 50px auto;
      padding: 20px;
    }
    button {
      background: #4CAF50;
      color: white;
      padding: 15px 30px;
      border: none;
      border-radius: 5px;
      font-size: 16px;
      cursor: pointer;
    }
    button:hover {
      background: #45a049;
    }
    .info {
      background: #f0f0f0;
      padding: 15px;
      border-radius: 5px;
      margin: 20px 0;
    }
    .log {
      background: #1e1e1e;
      color: #00ff00;
      padding: 15px;
      border-radius: 5px;
      font-family: monospace;
      font-size: 12px;
      max-height: 300px;
      overflow-y: auto;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <h1>Squad Payment SDK Test</h1>
  
  <div class="info">
    <p><strong>Public Key:</strong> {SQUAD_PUBLIC_KEY?.substring(0, 20)}...</p>
    <p><strong>Test Amount:</strong> ₦1,000 (NGN 100000 kobo)</p>
  </div>

  <button id="test-payment">Test Squad Payment</button>

  <div class="log" id="console-log">
    <div>Console Output:</div>
  </div>

  <script is:inline src="https://checkout.squadco.com/widget/squad.min.js"></script>
  
  <script is:inline define:vars={{ SQUAD_PUBLIC_KEY }}>
    const log = (message) => {
      const logEl = document.getElementById('console-log');
      const time = new Date().toLocaleTimeString();
      logEl.innerHTML += `\n[${time}] ${message}`;
      logEl.scrollTop = logEl.scrollHeight;
      console.log(message);
    };

    window.PUBLIC_SQUAD_KEY = SQUAD_PUBLIC_KEY;

    document.getElementById('test-payment').addEventListener('click', () => {
      log('Button clicked, initializing payment...');
      log('Public Key: ' + SQUAD_PUBLIC_KEY.substring(0, 20) + '...');
      
      try {
        log('Checking if squad is available: ' + (typeof window.squad));
        
        if (typeof window.squad === 'undefined') {
          log('ERROR: Squad SDK not loaded!');
          alert('Squad SDK not loaded. Check console.');
          return;
        }

        log('Creating Squad instance...');
        const squadInstance = new window.squad({
          onClose: () => {
            log('Payment modal closed');
          },
          onLoad: () => {
            log('Payment modal loaded successfully');
          },
          onSuccess: (data) => {
            log('Payment successful!');
            log('Transaction Ref: ' + data.transaction_ref);
            log('Full response: ' + JSON.stringify(data, null, 2));
            alert('Payment successful! Check console for details.');
          },
          key: SQUAD_PUBLIC_KEY,
          email: "test@abkhd.com",
          amount: 100000, // NGN 1,000 in kobo
          currency_code: "NGN",
          transaction_ref: "TEST-" + Date.now(),
          customer_name: "Test Customer",
          pass_charge: false
        });

        log('Squad instance created successfully');
        log('Calling setup()...');
        squadInstance.setup();
        
        log('Setup complete, calling open()...');
        squadInstance.open();
        log('Open called - modal should appear now');
        
      } catch (error) {
        log('ERROR: ' + error.message);
        log('Stack: ' + error.stack);
        alert('Error: ' + error.message);
      }
    });

    // Check SDK on load
    window.addEventListener('load', () => {
      setTimeout(() => {
        log('Page loaded');
        log('Squad SDK available: ' + (typeof window.squad !== 'undefined' ? 'YES' : 'NO'));
        if (typeof window.squad !== 'undefined') {
          log('Squad constructor: ' + typeof window.squad);
        }
      }, 1000);
    });
  </script>
</body>
</html>
