---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductGrid from '../components/ProductGrid.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../lib/appwrite';
import { Query } from 'appwrite';

// Get query parameters for filtering
const url = Astro.url;
const selectedCategory = url.searchParams.get('category');

// Fetch products from Appwrite
let products = [];
try {
  const response = await databases.listDocuments(
    APPWRITE_DB_ID,
    APPWRITE_PRODUCTS_COLLECTION_ID,
    [
      Query.equal('isActive', true),
      Query.equal('isArchived', false),
      Query.limit(100)
    ]
  );
  products = response.documents.map(doc => ({
    ...doc,
    id: doc.$id // Use Appwrite Document ID
  }));
} catch (error) {
  console.error('Error fetching products from Appwrite:', error);
}

// Filter products based on category (Server-side for initial load)
const filteredProducts = selectedCategory && selectedCategory !== 'all'
  ? products.filter(product => product.category === selectedCategory)
  : products;

// Categories with icons for filtering
const categoryFilters = [
  { name: 'Computers', icon: 'bi bi-laptop', value: 'computers' },
  { name: 'Mobile Phones', icon: 'bi bi-phone', value: 'mobile phones' },
  { name: 'Accessories', icon: 'bi bi-headphones', value: 'accessories' }
];
---

<Layout title="Shop - ABKHD Store">
  <Header slot="header" />
  
  <div class="container py-8 md:py-12">
    <!-- Navigation -->
    <div class="mb-12">
      <nav class="flex items-center space-x-2 text-sm text-muted-foreground mb-4">
        <a href="/" class="hover:text-foreground">Home</a>
        <i class="bi bi-chevron-right"></i>
        <span class="text-foreground">Shop</span>
      </nav>
      <a href="/" class="inline-flex items-center space-x-2 px-4 py-2 rounded-lg border border-border bg-card hover:border-primary/50 transition-colors">
        <i class="bi bi-arrow-left text-lg"></i>
        <span class="text-sm font-medium">Back to Home</span>
      </a>
    </div>
    
    <!-- Content Container -->
    <div class="max-w-6xl mx-auto">
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold mb-2">Shop</h1>
            <p class="text-muted-foreground products-count-text">
              {filteredProducts.length} {filteredProducts.length === 1 ? 'product' : 'products'} found
            </p>
          </div>
          
          <button
            id="mobile-filter-btn"
            class="lg:hidden flex items-center space-x-2 px-4 py-2 border border-border rounded-lg bg-card hover:border-primary/50 transition-colors"
          >
            <i class="bi bi-funnel text-primary"></i>
            <span class="text-sm font-medium">Filters</span>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Filter Sidebar (Drawer on Mobile, Sidebar on Desktop) -->
        <aside 
          id="filter-sidebar"
          class="fixed inset-y-0 left-0 z-50 w-80 bg-background border-r p-6 transform -translate-x-full transition-transform duration-300 ease-in-out lg:relative lg:translate-x-0 lg:z-0 lg:w-full lg:p-0 lg:border-r-0 lg:block lg:col-span-1 shadow-2xl lg:shadow-none"
        >
          <div class="lg:sticky lg:top-24 space-y-6">
            <!-- Mobile Header -->
            <div class="flex items-center justify-between lg:hidden mb-6">
              <h2 class="text-xl font-bold">Filters</h2>
              <button id="close-filter-btn" class="p-2 hover:bg-muted rounded-full">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>

            <!-- Categories Header -->
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-2 text-sm font-medium">
                <i class="bi bi-funnel text-primary"></i>
                <span>Filter by Category</span>
              </div>
              <button
                id="clear-filters"
                class={`text-xs text-primary hover:underline ${!selectedCategory ? 'hidden' : ''}`}
              >
                Clear
              </button>
            </div>

            <div class="space-y-3">
              <!-- All Products Button -->
              <button
                data-category="all"
                class={`category-btn w-full flex items-center justify-between p-4 rounded-lg border transition-all text-left group ${
                  !selectedCategory || selectedCategory === 'all' 
                    ? 'border-primary bg-primary/5 text-primary' 
                    : 'border-border bg-card hover:border-primary/50'
                }`}
              >
                <div class="flex items-center space-x-3">
                  <i class={`bi bi-grid text-lg transition-colors ${
                    !selectedCategory || selectedCategory === 'all' ? 'text-primary' : 'text-muted-foreground group-hover:text-primary'
                  }`}></i>
                  <span class="font-medium">All Products</span>
                </div>
              </button>

              {categoryFilters.map((category) => {
                const isActive = selectedCategory === category.value;
                return (
                  <button
                    data-category={category.value}
                    class={`category-btn w-full flex items-center justify-between p-4 rounded-lg border transition-all text-left group ${
                      isActive 
                        ? 'border-primary bg-primary/5 text-primary' 
                        : 'border-border bg-card hover:border-primary/50'
                    }`}
                  >
                    <div class="flex items-center space-x-3">
                      <i class={`${category.icon} text-lg transition-colors ${
                        isActive ? 'text-primary' : 'text-muted-foreground group-hover:text-primary'
                      }`}></i>
                      <span class={`font-medium ${isActive ? 'text-primary' : ''}`}>
                        {category.name}
                      </span>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        </aside>

        <!-- Overlay for mobile drawer -->
        <div 
          id="filter-overlay"
          class="fixed inset-0 bg-black/50 z-40 transition-opacity duration-300 opacity-0 pointer-events-none lg:hidden"
        ></div>

        <!-- Products Grid -->
          <main class="lg:col-span-3">
            <div id="products-container">
              {filteredProducts.length === 0 ? (
                <div class="text-center py-12 border border-dashed rounded-xl">
                  <i class="bi bi-inbox text-4xl text-muted-foreground mb-4"></i>
                  <p class="text-lg font-medium mb-2">No products found</p>
                  <p class="text-sm text-muted-foreground mb-6">
                    Try adjusting your filters
                  </p>
                  <button
                    id="clear-filters-btn"
                    class="btn-secondary px-6 py-2"
                  >
                    Clear Filters
                  </button>
                </div>
              ) : (
                <ProductGrid id="products-grid" products={filteredProducts} />
              )}
            </div>
          </main>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>



<script is:inline define:vars={{ initialProducts: products }}>
  // Initialize products from server-side data
  const products = initialProducts;

  const formatPrice = (price) => {
    return new Intl.NumberFormat('en-NG', {
      style: 'currency',
      currency: 'NGN',
      minimumFractionDigits: 0
    }).format(price);
  };

  // Get elements
  const categoryButtons = document.querySelectorAll('.category-btn');
  const clearFiltersBtn = document.getElementById('clear-filters');
  const clearFiltersBtn2 = document.getElementById('clear-filters-btn');
  const productsContainer = document.getElementById('products-container');
  const productsCountEl = document.querySelector('.products-count');

  // Track selected category
  let selectedCategory = 'all';

  // Format currency
  function formatNaira(amount) {
    return '₦' + amount.toLocaleString();
  }

  // Render products grid
  function renderProducts(productsToRender) {
    if (productsToRender.length === 0) {
      productsContainer.innerHTML = `
        <div class="text-center py-12 border border-dashed rounded-xl">
          <i class="bi bi-inbox text-4xl text-muted-foreground mb-4"></i>
          <p class="text-lg font-medium mb-2">No products found</p>
          <p class="text-sm text-muted-foreground mb-6">
            Try adjusting your filters
          </p>
          <button id="clear-filters-btn2" class="btn-secondary px-6 py-2">
            Clear Filters
          </button>
        </div>
      `;
      document.getElementById('clear-filters-btn2')?.addEventListener('click', () => filterProducts('all'));
      return;
    }

    const productsHTML = productsToRender.map(product => `
      <a href="/products/${product.id}" class="group">
        <div class="rounded-xl border bg-card overflow-hidden transition-all hover:shadow-lg hover:border-primary/50">
          <div class="aspect-square overflow-hidden bg-muted">
            <img 
              src="${product.image}" 
              alt="${product.name}" 
              class="w-full h-full object-cover transition-transform group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-lg mb-1 group-hover:text-primary transition-colors">${product.name}</h3>
            <p class="text-sm text-muted-foreground line-clamp-2 mb-3">${product.description}</p>
            <div class="flex items-center gap-2">
              <span class="text-lg font-bold">${formatNaira(product.price)}</span>
              ${product.originalPrice ? `<span class="text-sm text-muted-foreground line-through">${formatNaira(product.originalPrice)}</span>` : ''}
            </div>
          </div>
        </div>
      </a>
    `).join('');

    productsContainer.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        ${productsHTML}
      </div>
    `;
  }

  // Update button states
  function updateButtonStates() {
    categoryButtons.forEach(btn => {
      const category = btn.dataset.category;
      const isSelected = category === selectedCategory;
      
      const icon = btn.querySelector('i');
      const text = btn.querySelector('span.font-medium');
      
      if (isSelected) {
        btn.classList.add('border-primary', 'bg-primary/5', 'text-primary');
        btn.classList.remove('border-border', 'bg-card', 'hover:border-primary/50');
        if (icon) {
          icon.classList.add('text-primary');
          icon.classList.remove('text-muted-foreground');
        }
        if (text) text.classList.add('text-primary');
      } else {
        btn.classList.remove('border-primary', 'bg-primary/5', 'text-primary');
        btn.classList.add('border-border', 'bg-card', 'hover:border-primary/50');
        if (icon) {
          icon.classList.remove('text-primary');
          icon.classList.add('text-muted-foreground');
        }
        if (text) text.classList.remove('text-primary');
      }
    });

    // Show/hide clear button
    if (clearFiltersBtn) {
      if (selectedCategory === 'all') {
        clearFiltersBtn.classList.add('hidden');
      } else {
        clearFiltersBtn.classList.remove('hidden');
      }
    }
  }

  // Filter products
  function filterProducts(category) {
    selectedCategory = category;
    
    const filtered = category === 'all' 
      ? products 
      : products.filter(p => p.category === category);
    
    // Update URL without reload
    if (category === 'all') {
      window.history.pushState({}, '', '/shop');
    } else {
      window.history.pushState({}, '', `/shop?category=${encodeURIComponent(category)}`);
    }
    
    // Update products count
    const countEl = document.querySelector('.products-count-text');
    if (countEl) {
      countEl.textContent = `${filtered.length} ${filtered.length === 1 ? 'product' : 'products'} found`;
    }
    
    renderProducts(filtered);
    updateButtonStates();
  }

  // Add click handlers to category buttons
  categoryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      filterProducts(category);
    });
  });

  // Clear filters button
  clearFiltersBtn?.addEventListener('click', () => filterProducts('all'));
  clearFiltersBtn2?.addEventListener('click', () => filterProducts('all'));

  // Check URL for category on load
  const urlParams = new URLSearchParams(window.location.search);
  const urlCategory = urlParams.get('category');
  if (urlCategory) {
    filterProducts(urlCategory);
  }

  // Mobile Filter Functionality
  const mobileFilterBtn = document.getElementById('mobile-filter-btn');
  const closeFilterBtn = document.getElementById('close-filter-btn');
  const filterSidebar = document.getElementById('filter-sidebar');
  const filterOverlay = document.getElementById('filter-overlay');

  function openFilters() {
    filterSidebar?.classList.remove('-translate-x-full');
    filterOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  }

  function closeFilters() {
    filterSidebar?.classList.add('-translate-x-full');
    filterOverlay?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  mobileFilterBtn?.addEventListener('click', openFilters);
  closeFilterBtn?.addEventListener('click', closeFilters);
  filterOverlay?.addEventListener('click', closeFilters);

  // Close filters when a category is selected on mobile
  categoryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (window.innerWidth < 1024) {
        closeFilters();
      }
    });
  });
</script>