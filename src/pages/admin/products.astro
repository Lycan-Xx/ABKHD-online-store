---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../../lib/appwrite';
import { Query } from 'appwrite';
import { formatPrice } from '../../lib/utils';

// Get query parameters
const url = Astro.url;
const searchQuery = url.searchParams.get('search') || '';
const filterCategory = url.searchParams.get('category') || 'all';

// Fetch all products for filtering/stats
let products = [];
try {
  const response = await databases.listDocuments(
    APPWRITE_DB_ID,
    APPWRITE_PRODUCTS_COLLECTION_ID,
    [Query.limit(100), Query.orderDesc('$createdAt')]
  );
  products = response.documents.map(doc => ({
    ...doc,
    id: doc.$id
  }));
} catch (error) {
  console.error('Error fetching admin products:', error);
}

// Filter products based on search and category
let filteredProducts = products;

if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredProducts = filteredProducts.filter(p => 
    p.name.toLowerCase().includes(query) || 
    p.description?.toLowerCase().includes(query)
  );
}

if (filterCategory !== 'all') {
  filteredProducts = filteredProducts.filter(p => p.category === filterCategory);
}

// Get unique categories
const categories = [...new Set(products.map(p => p.category))];
---

<AdminLayout title="Products - ABKHD Admin">
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">Products</h1>
        <p class="text-muted-foreground mt-1">
          {filteredProducts.length} products found
        </p>
      </div>
      <a href="/admin/products/new" class="btn-primary">
        <i class="bi bi-plus-lg mr-2"></i>
        Add New
      </a>
    </div>

    <!-- Filters -->
    <div class="flex flex-col sm:flex-row gap-4">
      <!-- Search -->
      <div class="relative flex-1">
        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
        <form method="get">
          <input
            type="text"
            name="search"
            value={searchQuery}
            placeholder="Search products..."
            class="w-full pl-10 pr-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
          />
          {filterCategory !== 'all' && (
            <input type="hidden" name="category" value={filterCategory} />
          )}
          {filterStatus !== 'all' && (
            <input type="hidden" name="status" value={filterStatus} />
          )}
        </form>
      </div>

      <!-- Category Filter -->
      <form method="get">
        <select
          name="category"
          onchange="this.form.submit()"
          class="px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
        >
          <option value="all">All Categories</option>
          {categories.map(cat => (
            <option value={cat} selected={filterCategory === cat}>
              {cat}
            </option>
          ))}
        </select>
        {searchQuery && (
          <input type="hidden" name="search" value={searchQuery} />
        )}
      </form>
    </div>

    <!-- Products Table -->
    <div class="rounded-xl border bg-card overflow-hidden">
      <!-- Desktop Table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b bg-muted/50">
              <th class="w-10 px-4 py-3">
                <input 
                  type="checkbox" 
                  id="select-all-checkbox"
                  class="w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary"
                />
              </th>
              <th class="text-left text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Product
              </th>
              <th class="text-left text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Price
              </th>
              <th class="text-left text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Category
              </th>
              <th class="text-center text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Featured
              </th>
              <th class="text-center text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Listed
              </th>
              <th class="text-right text-xs font-medium text-muted-foreground uppercase tracking-wider px-4 py-3">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="divide-y">
            {filteredProducts.map(product => (
              <tr class="hover:bg-muted/30 transition-colors" data-product-id={product.id}>
                <!-- Selection -->
                <td class="px-4 py-3">
                  <input 
                    type="checkbox" 
                    class="product-checkbox w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary"
                    data-product-id={product.id}
                  />
                </td>
                <!-- Product -->
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-lg bg-muted overflow-hidden flex-shrink-0">
                      <img 
                        src={product.image} 
                        alt={product.name}
                        class="w-full h-full object-cover"
                      />
                    </div>
                    <div class="min-w-0">
                      <a 
                        href={`/admin/products/${product.id}`}
                        class="font-medium hover:text-primary transition-colors truncate block"
                      >
                        {product.name}
                      </a>
                      <p class="text-xs text-muted-foreground truncate max-w-xs">
                        {product.description}
                      </p>
                    </div>
                  </div>
                </td>

                <!-- Price -->
                <td class="px-4 py-3">
                  <div>
                    <span class="font-medium">{formatPrice(product.price)}</span>
                    {product.originalPrice && (
                      <span class="text-xs text-muted-foreground line-through ml-2">
                        {formatPrice(product.originalPrice)}
                      </span>
                    )}
                  </div>
                </td>

                <!-- Category -->
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-muted capitalize">
                    {product.category}
                  </span>
                </td>

                <!-- Featured -->
                <td class="px-4 py-3 text-center">
                  <input 
                    type="checkbox" 
                    class="featured-checkbox w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary"
                    data-product-id={product.id}
                    checked={product.featured}
                  />
                </td>

                <!-- Listed (Active Toggle) -->
                <td class="px-4 py-3 text-center">
                  <button 
                    class="toggle-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                    data-product-id={product.id}
                    data-current-status={product.isActive !== false ? 'active' : 'inactive'}
                  >
                    <span class="toggle-indicator inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform"></span>
                  </button>
                </td>

                <!-- Actions -->
                <td class="px-4 py-3">
                  <div class="flex items-center justify-end gap-2">
                    <a
                      href={`/admin/products/${product.id}`}
                      class="p-2 rounded-lg hover:bg-muted transition-colors"
                      title="Edit"
                    >
                      <i class="bi bi-pencil"></i>
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile Cards -->
      <div class="md:hidden divide-y">
        {filteredProducts.map(product => (
          <div class="p-4" data-product-id={product.id}>
            <div class="flex items-start gap-3">
              <div class="w-16 h-16 rounded-lg bg-muted overflow-hidden flex-shrink-0">
                <img 
                  src={product.image} 
                  alt={product.name}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <a 
                      href={`/admin/products/${product.id}`}
                      class="font-medium hover:text-primary transition-colors"
                    >
                      {product.name}
                    </a>
                    <p class="text-sm text-muted-foreground mt-0.5">
                      {formatPrice(product.price)}
                    </p>
                  </div>
                  <div class="flex flex-col items-center gap-1">
                    <span class="text-[10px] text-muted-foreground font-medium uppercase tracking-wider">Featured</span>
                    <input 
                      type="checkbox" 
                      class="featured-checkbox-mobile w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
                      data-product-id={product.id}
                      checked={product.featured}
                    />
                  </div>
                </div>
                <div class="flex items-center justify-between mt-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-muted capitalize">
                    {product.category}
                  </span>
                  <div class="flex items-center gap-3">
                    <!-- Mobile Toggle -->
                    <button 
                      class="toggle-btn-mobile relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
                      data-product-id={product.id}
                      data-current-status={product.isActive !== false ? 'active' : 'inactive'}
                    >
                      <span class="toggle-indicator inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform"></span>
                    </button>
                    <a
                      href={`/admin/products/${product.id}`}
                      class="p-2 rounded-lg hover:bg-muted transition-colors"
                    >
                      <i class="bi bi-pencil"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {filteredProducts.length === 0 && (
        <div class="p-12 text-center">
          <div class="text-muted-foreground">
            <i class="bi bi-box-seam text-4xl mb-4 block"></i>
            <p class="text-lg font-medium">No products found</p>
            <p class="text-sm mt-1">Try adjusting your filters or add a new product</p>
          </div>
          <a href="/admin/products/new" class="btn-primary mt-4 inline-flex">
            <i class="bi bi-plus-lg mr-2"></i>
            Add Product
          </a>
        </div>
      )}
    </div>

    <!-- Bulk Actions Bar -->
    <div 
      id="bulk-actions-bar"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 bg-background border shadow-2xl rounded-2xl px-6 py-4 flex items-center gap-6 transition-all duration-300 translate-y-24 opacity-0 pointer-events-none"
    >
      <div class="flex items-center gap-2 border-r pr-6">
        <span id="selected-count" class="font-bold text-primary">0</span>
        <span class="text-sm font-medium text-muted-foreground">selected</span>
      </div>
      
      <div class="flex items-center gap-2">
        <button id="bulk-export-btn" class="p-2 rounded-lg hover:bg-muted transition-colors text-muted-foreground hover:text-foreground" title="Export to CSV">
          <i class="bi bi-download"></i>
        </button>
        <button id="bulk-duplicate-btn" class="p-2 rounded-lg hover:bg-muted transition-colors text-muted-foreground hover:text-foreground" title="Duplicate">
          <i class="bi bi-copy"></i>
        </button>
        <div class="w-px h-4 bg-border mx-2"></div>
        <button id="bulk-delete-btn" class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-destructive/10 text-destructive transition-colors font-medium text-sm" title="Delete">
          <i class="bi bi-trash"></i>
          Delete
        </button>
      </div>

      <button id="cancel-selection" class="ml-4 text-xs font-medium text-muted-foreground hover:text-foreground">
        Cancel
      </button>
    </div>
  </div>
</AdminLayout>

<style>
  .btn-primary {
    @apply inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium transition-colors hover:bg-primary/90;
  }
  
  .toggle-btn.active {
    @apply bg-primary;
  }
  
  .toggle-btn.inactive {
    @apply bg-muted;
  }
  
  .toggle-btn.active .toggle-indicator {
    @apply translate-x-6;
  }
  
  .toggle-btn.inactive .toggle-indicator {
    @apply translate-x-1;
  }
  
  .toggle-btn-mobile.active {
    @apply bg-primary;
  }
  
  .toggle-btn-mobile.inactive {
    @apply bg-muted;
  }
  
  .toggle-btn-mobile.active .toggle-indicator {
    @apply translate-x-6;
  }
  
  .toggle-btn-mobile.inactive .toggle-indicator {
    @apply translate-x-1;
  }
</style>

<script>
  import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../../lib/appwrite';

  const initProductsPage = () => {
    // Selection Logic
    const selectAllCheckbox = document.getElementById('select-all-checkbox') as HTMLInputElement;
    const bulkActionsBar = document.getElementById('bulk-actions-bar');
    const selectedCountEl = document.getElementById('selected-count');
    const cancelSelectionBtn = document.getElementById('cancel-selection');

    if (!selectAllCheckbox || !bulkActionsBar) return;

    const updateBulkBar = () => {
      const selectedCheckboxes = document.querySelectorAll('.product-checkbox:checked');
      const selectedCount = selectedCheckboxes.length;
      
      if (selectedCount > 0) {
        bulkActionsBar.classList.remove('translate-y-24', 'opacity-0', 'pointer-events-none');
        if (selectedCountEl) selectedCountEl.textContent = selectedCount.toString();
      } else {
        bulkActionsBar.classList.add('translate-y-24', 'opacity-0', 'pointer-events-none');
      }

      const totalCheckboxes = document.querySelectorAll('.product-checkbox').length;
      selectAllCheckbox.checked = selectedCount === totalCheckboxes && totalCheckboxes > 0;
      selectAllCheckbox.indeterminate = selectedCount > 0 && selectedCount < totalCheckboxes;
    };

    // Toggle logic with Appwrite integration
    const initializeToggles = () => {
      document.querySelectorAll('.toggle-btn, .toggle-btn-mobile').forEach((btn) => {
        const button = btn as HTMLButtonElement;
        const isActive = button.dataset.currentStatus === 'active';
        
        button.classList.toggle('active', isActive);
        button.classList.toggle('inactive', !isActive);
        
        button.onclick = async () => {
          const productId = button.dataset.productId;
          const currentlyActive = button.classList.contains('active');
          const newStatus = !currentlyActive;
          
          button.disabled = true;
          button.style.opacity = '0.5';

          try {
            await databases.updateDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, productId, {
              isActive: newStatus
            });
            
            // Sync all toggles for this product
            document.querySelectorAll(`[data-product-id="${productId}"].toggle-btn, [data-product-id="${productId}"].toggle-btn-mobile`).forEach(el => {
              const b = el as HTMLButtonElement;
              b.classList.toggle('active', newStatus);
              b.classList.toggle('inactive', !newStatus);
              b.dataset.currentStatus = newStatus ? 'active' : 'inactive';
            });
          } catch (error) {
            console.error('Failed to toggle active status:', error);
            alert('Failed to update product status');
          } finally {
            button.disabled = false;
            button.style.opacity = '1';
          }
        };
      });
    };

    // Featured toggle with Appwrite integration
    const initializeFeaturedToggles = () => {
      document.querySelectorAll('.featured-checkbox, .featured-checkbox-mobile').forEach((cb) => {
        const checkbox = cb as HTMLInputElement;
        
        checkbox.onchange = async () => {
          const productId = checkbox.dataset.productId;
          const isFeatured = checkbox.checked;
          
          checkbox.disabled = true;

          try {
            await databases.updateDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, productId, {
              featured: isFeatured
            });
            
            // Sync all featured checkboxes for this product
            document.querySelectorAll(`[data-product-id="${productId}"].featured-checkbox, [data-product-id="${productId}"].featured-checkbox-mobile`).forEach(el => {
              const oc = el as HTMLInputElement;
              if (oc !== checkbox) oc.checked = isFeatured;
            });
          } catch (error) {
            console.error('Failed to update featured status:', error);
            alert('Failed to update featured status');
            checkbox.checked = !isFeatured; // Revert
          } finally {
            checkbox.disabled = false;
          }
        };
      });
    };

    // Bulk Delete
    const bulkDeleteBtn = document.getElementById('bulk-delete-btn');
    bulkDeleteBtn?.addEventListener('click', async () => {
      const selectedCheckboxes = document.querySelectorAll('.product-checkbox:checked');
      const selectedCount = selectedCheckboxes.length;
      if (selectedCount === 0) return;

      if (confirm(`Delete ${selectedCount} product(s)?`)) {
        for (const cb of selectedCheckboxes) {
          const productId = (cb as HTMLInputElement).dataset.productId;
          try {
            await databases.deleteDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, productId);
            document.querySelectorAll(`[data-product-id="${productId}"]`).forEach(el => (el as HTMLElement).style.display = 'none');
          } catch (e) {
            console.error(`Failed to delete product ${productId}:`, e);
          }
        }
        updateBulkBar();
      }
    });

    selectAllCheckbox.addEventListener('change', () => {
      document.querySelectorAll('.product-checkbox').forEach((cb) => {
        (cb as HTMLInputElement).checked = selectAllCheckbox.checked;
      });
      updateBulkBar();
    });

    document.querySelectorAll('.product-checkbox').forEach((cb) => {
      cb.addEventListener('change', updateBulkBar);
    });

    cancelSelectionBtn?.addEventListener('click', () => {
      document.querySelectorAll('.product-checkbox').forEach((cb) => {
        (cb as HTMLInputElement).checked = false;
      });
      selectAllCheckbox.checked = false;
      updateBulkBar();
    });

    initializeToggles();
    initializeFeaturedToggles();
  };

  initProductsPage();
  document.addEventListener('astro:after-swap', initProductsPage);
</script>
