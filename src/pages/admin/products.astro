---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { formatPrice } from '../../lib/utils';
---

<AdminLayout title="Products - ABKHD Admin">
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">Products</h1>
        <p class="text-muted-foreground mt-1">Manage your product catalog</p>
      </div>
      <button id="add-new-btn" class="btn-primary">
        <i class="bi bi-plus-lg mr-2"></i>
        Add New Product
      </button>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
      <p class="mt-4 text-muted-foreground">Loading products...</p>
    </div>

    <!-- Filters -->
    <div id="filters-section" class="hidden flex flex-col sm:flex-row gap-4">
      <div class="relative flex-1">
        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"></i>
        <input
          type="text"
          id="search-input"
          placeholder="Search products..."
          class="w-full pl-10 pr-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
        />
      </div>
      <select
        id="category-filter"
        class="px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
      >
        <option value="all">All Categories</option>
      </select>
    </div>

    <!-- Selection Toolbar -->
    <div id="selection-toolbar" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div class="flex items-center gap-3">
          <span id="selected-count" class="text-sm font-medium text-blue-700 dark:text-blue-300">0 selected</span>
          <button id="select-all-btn" type="button" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">
            Select All
          </button>
          <button id="deselect-all-btn" type="button" class="text-xs text-blue-600 dark:text-blue-400 hover:underline hidden">
            Deselect All
          </button>
        </div>
        <div class="flex items-center gap-2">
          <button id="export-selected-btn" type="button" class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg border bg-background hover:bg-muted transition-colors">
            <i class="bi bi-download mr-1.5"></i>
            Export
          </button>
          <button id="delete-selected-btn" type="button" class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-red-500 text-white hover:bg-red-600 transition-colors">
            <i class="bi bi-trash mr-1.5"></i>
            Delete
          </button>
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
      <div class="bg-card rounded-xl border shadow-xl max-w-md w-full p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center">
            <i class="bi bi-exclamation-triangle text-xl text-red-500"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold">Delete Products</h3>
            <p class="text-sm text-muted-foreground">This action cannot be undone</p>
          </div>
        </div>
        <p id="delete-modal-text" class="text-sm text-muted-foreground mb-6">
          Are you sure you want to delete <span id="delete-count" class="font-medium text-foreground">0</span> products? This will permanently remove them from the database.
        </p>
        <div class="flex gap-3 justify-end">
          <button id="cancel-delete-btn" type="button" class="px-4 py-2 text-sm font-medium rounded-lg border bg-background hover:bg-muted transition-colors">
            Cancel
          </button>
          <button id="confirm-delete-btn" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-red-500 text-white hover:bg-red-600 transition-colors">
            Delete
          </button>
        </div>
      </div>
    </div>

    <!-- Products Table -->
    <div id="products-section" class="hidden rounded-xl border bg-card overflow-hidden">
      <div id="products-container"></div>
    </div>


    <!-- Product Edit/Create Slide-in Panel -->
    <div id="product-panel" class="fixed inset-y-0 right-0 w-full max-w-3xl bg-card shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
      <div class="sticky top-0 bg-card border-b p-6 flex items-center justify-between z-10">
        <div>
          <h2 id="panel-title" class="text-xl font-bold">Add New Product</h2>
          <p class="text-sm text-muted-foreground">Fill in the product details</p>
        </div>
        <button id="close-panel" class="p-2 hover:bg-muted rounded-lg transition-colors">
          <i class="bi bi-x text-2xl"></i>
        </button>
      </div>
      
      <form id="product-form" class="p-6 space-y-6">
        <!-- Basic Info -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold">Basic Information</h3>
          
          <div>
            <label for="name" class="block text-sm font-medium mb-2">
              Product Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Enter product name"
            />
          </div>

          <div>
            <label for="description" class="block text-sm font-medium mb-2">Description</label>
            <textarea
              id="description"
              name="description"
              rows="4"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring resize-none"
              placeholder="Enter product description"
            ></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="category" class="block text-sm font-medium mb-2">
                Category <span class="text-red-500">*</span>
              </label>
              <select
                id="category"
                name="category"
                required
                class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              >
                <option value="">Select category</option>
              </select>
            </div>

            <div>
              <label for="brand" class="block text-sm font-medium mb-2">Brand</label>
              <input
                type="text"
                id="brand"
                name="brand"
                class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="Enter brand name"
              />
            </div>
          </div>
        </div>

        <!-- Pricing -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold">Pricing</h3>
          
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label for="price" class="block text-sm font-medium mb-2">
                Price (₦) <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="price"
                name="price"
                required
                min="0"
                step="0.01"
                class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="0.00"
              />
            </div>

            <div>
              <label for="originalPrice" class="block text-sm font-medium mb-2">Original Price (₦)</label>
              <input
                type="number"
                id="originalPrice"
                name="originalPrice"
                min="0"
                step="0.01"
                class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="0.00"
              />
            </div>

            <div>
              <label for="stock" class="block text-sm font-medium mb-2">Stock</label>
              <input
                type="number"
                id="stock"
                name="stock"
                min="0"
                class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                placeholder="0"
              />
            </div>
          </div>
        </div>


        <!-- Images & Videos -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold">Images & Videos</h3>
          
          <div id="compression-stats" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3">
            <div class="flex items-center gap-2 text-green-700 dark:text-green-400 text-sm">
              <i class="bi bi-check-circle-fill"></i>
              <span id="compression-text">Images compressed successfully</span>
            </div>
          </div>

          <div id="upload-loading" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
            <div class="flex items-center gap-2 text-blue-700 dark:text-blue-400 text-sm">
              <i class="bi bi-arrow-repeat animate-spin"></i>
              <span>Processing media...</span>
            </div>
          </div>

          <!-- Upload Progress -->
          <div id="upload-progress" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-blue-700 dark:text-blue-400">
                <i class="bi bi-cloud-arrow-up mr-1 animate-pulse"></i>
                <span id="upload-progress-text">Uploading...</span>
              </span>
              <span id="upload-progress-count" class="text-xs text-blue-600 dark:text-blue-300"></span>
            </div>
            <div class="w-full bg-blue-200 dark:bg-blue-800 rounded-full h-2">
              <div id="upload-progress-bar" class="bg-blue-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
          </div>

          <!-- Pending Uploads Alert -->
          <div id="pending-uploads-alert" class="hidden bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-amber-700 dark:text-amber-400">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span class="text-sm">You have pending uploads from a previous session</span>
              </div>
              <button id="retry-upload-btn" type="button" class="text-xs px-3 py-1 bg-amber-500 text-white rounded hover:bg-amber-600 transition-colors">
                Resume Upload
              </button>
            </div>
          </div>

          <div id="media-grid" class="grid grid-cols-3 gap-4"></div>

          <div
            id="upload-area"
            class="border-2 border-dashed rounded-lg p-8 text-center cursor-pointer transition-colors hover:border-primary hover:bg-primary/5"
          >
            <input
              type="file"
              id="file-input"
              accept="image/*,video/*"
              multiple
              class="hidden"
            />
            <div class="text-muted-foreground">
              <i class="bi bi-cloud-arrow-up text-3xl mb-3 block"></i>
              <p class="text-sm font-medium">Click to upload or drag and drop</p>
              <p class="text-xs mt-1">Images (PNG, JPG, WEBP) and Videos up to 50MB</p>
              <p class="text-xs mt-2 text-blue-600 dark:text-blue-400">
                <i class="bi bi-lightning-charge mr-1"></i>
                Files are automatically compressed
              </p>
            </div>
          </div>
        </div>

        <!-- Status -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold">Status</h3>
          
          <div class="flex items-center gap-3">
            <button
              type="button"
              id="isActive"
              class="toggle-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 bg-primary"
              data-current-status="active"
            >
              <span class="toggle-indicator inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform translate-x-6"></span>
            </button>
            <div>
              <label for="isActive" class="text-sm font-medium cursor-pointer">List product in shop</label>
              <p class="text-xs text-muted-foreground">If OFF, product will not be shown</p>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <input
              type="checkbox"
              id="featured"
              name="featured"
              class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
            />
            <label for="featured" class="text-sm font-medium">Featured Product</label>
          </div>

          <div class="flex items-center gap-3">
            <input
              type="checkbox"
              id="verified"
              name="verified"
              class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
            />
            <div>
              <label for="verified" class="text-sm font-medium">Verified Product</label>
              <p class="text-xs text-muted-foreground">Shows verified badge in shop</p>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <input
              type="checkbox"
              id="isUnique"
              name="isUnique"
              class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
            />
            <div>
              <label for="isUnique" class="text-sm font-medium">Unique Item</label>
              <p class="text-xs text-muted-foreground">Auto-deactivates when purchased (for used items)</p>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="flex items-center gap-4 pt-4 border-t">
          <button
            type="submit"
            class="btn-primary flex-1"
          >
            <i class="bi bi-check-lg mr-2"></i>
            <span id="submit-text">Create Product</span>
          </button>
          <button
            type="button"
            id="cancel-btn"
            class="btn-secondary flex-1"
          >
            Cancel
          </button>
        </div>
      </form>
    </div>

    <!-- Overlay for slide-in panel -->
    <div id="panel-overlay" class="fixed inset-0 bg-black/50 z-40 hidden"></div>

    <!-- Error State -->
    <div id="error-state" class="hidden p-12 text-center rounded-xl border bg-card">
      <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="bi bi-exclamation-triangle text-3xl text-red-500"></i>
      </div>
      <h3 class="text-lg font-semibold mb-2">Failed to load products</h3>
      <p class="text-muted-foreground mb-4" id="error-message"></p>
      <button onclick="location.reload()" class="btn-primary px-6 py-2">Retry</button>
    </div>
  </div>
</AdminLayout>

<style>
  .btn-primary {
    @apply inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium transition-colors hover:bg-primary/90;
  }
  
  .btn-secondary {
    @apply inline-flex items-center justify-center px-4 py-2.5 rounded-lg border bg-background font-medium transition-colors hover:bg-muted;
  }

  .toggle-btn.active {
    @apply bg-primary;
  }
  
  .toggle-btn.inactive {
    @apply bg-muted;
  }
  
  .toggle-btn.active .toggle-indicator {
    @apply translate-x-6;
  }
  
  .toggle-btn.inactive .toggle-indicator {
    @apply translate-x-1;
  }
</style>


<script>
  import { databases, storage, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, APPWRITE_IMAGES_BUCKET_ID, ID } from '../../lib/appwrite';
  import { Query } from 'appwrite';
  import { compressImage, compressVideo } from '../../lib/utils';
  import { 
    saveToCache, 
    loadFromCache, 
    clearCache, 
    createCachedFile,
    uploadFilesSequentially,
    hasPendingUploads,
    getPendingCount
  } from '../../lib/upload-cache';

  let products = [];
  let categories = [];
  let mediaFiles = []; // { type, data, file?, isPrimary, url? }
  let currentProductId = null;
  let searchQuery = '';
  let categoryFilter = 'all';
  let selectedProducts = new Set(); // Track selected product IDs

  function formatPrice(price: number): string {
    return '₦' + price.toLocaleString();
  }

  function showPanel(product = null) {
    const panel = document.getElementById('product-panel');
    const overlay = document.getElementById('panel-overlay');
    const form = document.getElementById('product-form') as HTMLFormElement;
    const panelTitle = document.getElementById('panel-title');
    const submitText = document.getElementById('submit-text');
    const isActiveToggle = document.getElementById('isActive') as HTMLButtonElement;

    if (!panel || !overlay || !form) return;

    currentProductId = product?.$id || null;
    
    // Check for pending uploads
    checkPendingUploads();

    // Reset form
    form.reset();
    
    // Update title
    if (panelTitle) panelTitle.textContent = product ? 'Edit Product' : 'Add New Product';
    if (submitText) submitText.textContent = product ? 'Update Product' : 'Create Product';

    // Populate form if editing
    if (product) {
      (document.getElementById('name') as HTMLInputElement).value = product.name || '';
      (document.getElementById('description') as HTMLTextAreaElement).value = product.description || '';
      (document.getElementById('category') as HTMLSelectElement).value = product.category || '';
      (document.getElementById('brand') as HTMLInputElement).value = product.brand || '';
      (document.getElementById('price') as HTMLInputElement).value = product.price || '';
      (document.getElementById('originalPrice') as HTMLInputElement).value = product.originalPrice || '';
      (document.getElementById('stock') as HTMLInputElement).value = product.stock || 0;
      (document.getElementById('featured') as HTMLInputElement).checked = product.featured || false;
      (document.getElementById('verified') as HTMLInputElement).checked = product.verified || false;
      (document.getElementById('isUnique') as HTMLInputElement).checked = product.isUnique || false;

      // Set active toggle
      const isActive = product.isActive !== false;
      isActiveToggle.dataset.currentStatus = isActive ? 'active' : 'inactive';
      isActiveToggle.classList.toggle('bg-primary', isActive);
      isActiveToggle.classList.toggle('bg-muted', !isActive);
      isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-6', isActive);
      isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-1', !isActive);

      // Load existing media
      const images = product.images || (product.image ? [product.image] : []);
      mediaFiles = images.map((url: string, i: number) => ({ 
        type: 'image', 
        data: url, 
        url: url,
        isPrimary: i === 0,
        status: 'completed' as const,
        createdAt: Date.now()
      }));

      if (product.video) {
        mediaFiles.push({
          type: 'video',
          data: product.video,
          url: product.video,
          thumbnail: product.videoThumbnail,
          isPrimary: false,
          status: 'completed' as const,
          createdAt: Date.now()
        });
      }

      renderMediaGrid();
    } else {
      // Reset toggle for new product
      isActiveToggle.dataset.currentStatus = 'active';
      isActiveToggle.classList.add('bg-primary');
      isActiveToggle.classList.remove('bg-muted');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.add('translate-x-6');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.remove('translate-x-1');
      
      // Load cached files for new products
      const cachedFiles = loadFromCache();
      if (cachedFiles.length > 0) {
        mediaFiles = cachedFiles;
        renderMediaGrid();
      }
    }

    // Show panel
    overlay.classList.remove('hidden');
    setTimeout(() => {
      panel.classList.remove('translate-x-full');
    }, 10);
  }

  function hidePanel() {
    const panel = document.getElementById('product-panel');
    const overlay = document.getElementById('panel-overlay');

    if (panel && overlay) {
      panel.classList.add('translate-x-full');
      setTimeout(() => {
        overlay.classList.add('hidden');
        mediaFiles = [];
        currentProductId = null;
        renderMediaGrid();
      }, 300);
    }
  }


  function renderMediaGrid() {
    const mediaGrid = document.getElementById('media-grid');
    if (!mediaGrid) return;

    mediaGrid.innerHTML = '';
    mediaFiles.forEach((file, index) => {
      const item = document.createElement('div');
      item.className = 'relative group aspect-square rounded-lg overflow-hidden border bg-muted';
      
      // Status indicator
      let statusBadge = '';
      if (file.status === 'uploading') {
        statusBadge = '<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-blue-500 text-white rounded animate-pulse">Uploading...</span>';
      } else if (file.status === 'failed') {
        statusBadge = `<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-red-500 text-white rounded cursor-pointer hover:bg-red-600 retry-item" data-index="${index}">Retry</span>`;
      } else if (file.status === 'completed') {
        statusBadge = '<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-green-500 text-white rounded">Uploaded</span>';
      }
      
      if (file.type === 'video') {
        item.innerHTML = `
          <div class="relative w-full h-full">
            <img src="${file.thumbnail || file.data}" class="w-full h-full object-cover" crossorigin="anonymous" />
            <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
              <i class="bi bi-play-circle-fill text-3xl text-white"></i>
            </div>
            <span class="absolute bottom-2 right-2 px-1.5 py-0.5 text-[10px] font-bold bg-black/60 text-white rounded">VIDEO</span>
            ${statusBadge}
          </div>
          <button type="button" class="remove-btn absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-background/90 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background">
            <i class="bi bi-x-lg text-sm"></i>
          </button>
        `;
      } else {
        item.innerHTML = `
          <img src="${file.data}" class="w-full h-full object-cover" crossorigin="anonymous" />
          ${file.isPrimary ? '<span class="absolute bottom-2 left-2 px-2 py-0.5 text-xs font-medium bg-primary text-primary-foreground rounded">Main</span>' : ''}
          ${statusBadge}
          <button type="button" class="remove-btn absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-background/90 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background">
            <i class="bi bi-x-lg text-sm"></i>
          </button>
        `;
      }
      
      item.querySelector('.remove-btn')!.addEventListener('click', () => {
        mediaFiles.splice(index, 1);
        if (file.isPrimary && mediaFiles.length > 0) {
          mediaFiles[0].isPrimary = true;
        }
        saveToCache(mediaFiles);
        renderMediaGrid();
      });

      // Retry failed upload
      const retryBtn = item.querySelector('.retry-item');
      if (retryBtn) {
        retryBtn.addEventListener('click', async (e) => {
          e.stopPropagation();
          await retryUpload(index);
        });
      }

      if (!file.isPrimary && file.type === 'image') {
        const setMain = document.createElement('button');
        setMain.type = 'button';
        setMain.className = 'absolute bottom-2 right-2 px-2 py-0.5 text-xs font-medium bg-background/90 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background';
        setMain.textContent = 'Set Main';
        setMain.addEventListener('click', () => {
          mediaFiles.forEach(f => f.isPrimary = false);
          file.isPrimary = true;
          saveToCache(mediaFiles);
          renderMediaGrid();
        });
        item.appendChild(setMain);
      }
      
      mediaGrid.appendChild(item);
    });
  }

  async function loadProducts() {
    const loadingState = document.getElementById('loading-state');
    const filtersSection = document.getElementById('filters-section');
    const productsSection = document.getElementById('products-section');
    const errorState = document.getElementById('error-state');
    const productsContainer = document.getElementById('products-container');
    const categoryFilterSelect = document.getElementById('category-filter') as HTMLSelectElement;
    const categorySelect = document.getElementById('category') as HTMLSelectElement;

    try {
      console.log('Fetching products...');
      const response = await databases.listDocuments(
        APPWRITE_DB_ID,
        APPWRITE_PRODUCTS_COLLECTION_ID,
        [Query.orderDesc('$createdAt'), Query.limit(100)]
      );

      products = response.documents;
      console.log('Products fetched:', products.length);

      // Define default categories
      const DEFAULT_CATEGORIES = ['Computers', 'Mobile Phones', 'Accessories'];

      // Extract categories from products and merge with defaults
      const existingCategories = [...new Set(products.map((p: any) => p.category).filter((cat: any) => cat))];
      categories = [...new Set([...DEFAULT_CATEGORIES, ...existingCategories])];
      
      // Populate category filters
      if (categoryFilterSelect) {
        categories.forEach(cat => {
          const option = document.createElement('option');
          option.value = cat;
          option.textContent = cat;
          categoryFilterSelect.appendChild(option);
        });
      }

      if (categorySelect) {
        categorySelect.innerHTML = '<option value="">Select category</option>';
        categories.forEach(cat => {
          const option = document.createElement('option');
          option.value = cat;
          option.textContent = cat;
          categorySelect.appendChild(option);
        });
      }

      // Hide loading
      loadingState?.classList.add('hidden');
      filtersSection?.classList.remove('hidden');
      productsSection?.classList.remove('hidden');

      // Clear selection when loading new products
      selectedProducts.clear();
      
      renderProducts();
      updateSelectionUI();

    } catch (error) {
      console.error('Error loading products:', error);
      loadingState?.classList.add('hidden');
      errorState?.classList.remove('hidden');
      
      const errorMessage = document.getElementById('error-message');
      if (errorMessage) {
        errorMessage.textContent = error instanceof Error ? error.message : 'Unknown error occurred';
      }
    }
  }


  function renderProducts() {
    const productsContainer = document.getElementById('products-container');
    if (!productsContainer) return;

    // Filter products
    let filtered = products.filter((p: any) => {
      const matchesSearch = !searchQuery || 
        p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
        p.description?.toLowerCase().includes(searchQuery.toLowerCase());
      const matchesCategory = categoryFilter === 'all' || p.category === categoryFilter;
      return matchesSearch && matchesCategory;
    });

    if (filtered.length === 0) {
      productsContainer.innerHTML = `
        <div class="p-12 text-center">
          <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="bi bi-box-seam text-3xl text-muted-foreground"></i>
          </div>
          <h3 class="text-lg font-semibold mb-2">No products found</h3>
          <p class="text-muted-foreground">Try adjusting your filters or add a new product</p>
        </div>
      `;
      return;
    }

    productsContainer.innerHTML = `
      <!-- Mobile Card View (also works on desktop) -->
      <div class="divide-y">
        ${filtered.map((product: any) => `
          <div 
            class="p-4 hover:bg-muted/30 transition-colors cursor-pointer product-row ${selectedProducts.has(product.$id) ? 'bg-blue-50 dark:bg-blue-900/20' : ''}" 
            data-product-id="${product.$id}"
          >
            <div class="flex items-start gap-3">
              <!-- Checkbox for selection -->
              <div class="pt-1" onclick="event.stopPropagation()">
                <input 
                  type="checkbox" 
                  class="product-checkbox w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary" 
                  data-product-id="${product.$id}"
                  ${selectedProducts.has(product.$id) ? 'checked' : ''}
                />
              </div>
              
              <!-- Product Image -->
              <div class="w-16 h-16 rounded-lg bg-muted overflow-hidden flex-shrink-0">
                <img 
                  src="${product.image || '/placeholder.png'}" 
                  alt="${product.name}"
                  class="w-full h-full object-cover"
                  crossorigin="anonymous"
                />
              </div>
              
              <!-- Product Info -->
              <div class="flex-1 min-w-0">
                <div class="font-medium text-sm truncate">${product.name}</div>
                <div class="text-xs text-muted-foreground truncate mt-0.5">${product.description || ''}</div>
                
                <!-- Price and badges row -->
                <div class="flex items-center gap-2 mt-2 flex-wrap">
                  <div class="font-semibold text-sm">${formatPrice(product.price)}</div>
                  ${product.originalPrice ? `<div class="text-[10px] text-muted-foreground line-through">${formatPrice(product.originalPrice)}</div>` : ''}
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-muted capitalize">
                    ${product.category}
                  </span>
                </div>
                
                <!-- Stock and status row -->
                <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                  <span class="text-[10px] text-muted-foreground">Stock: ${product.stock || 0}</span>
                  <span class="px-2 py-0.5 rounded-full text-[10px] uppercase font-bold ${
                    product.isActive !== false ? 'bg-green-500/10 text-green-500' : 'bg-gray-500/10 text-gray-500'
                  }">
                    ${product.isActive !== false ? 'Active' : 'Inactive'}
                  </span>
                  ${product.featured ? '<span class="px-2 py-0.5 rounded-full text-[10px] uppercase font-bold bg-yellow-500/10 text-yellow-500">Featured</span>' : ''}
                </div>
              </div>
            </div>
          </div>
        `).join('')}
      </div>
    `;

    // Add click handlers to product rows (but not checkbox)
    document.querySelectorAll('.product-row').forEach((row) => {
      row.addEventListener('click', (e) => {
        // Don't trigger if clicking on checkbox
        if ((e.target as HTMLElement).type === 'checkbox') return;
        const productId = (row as HTMLElement).dataset.productId;
        const product = products.find((p: any) => p.$id === productId);
        if (product) showPanel(product);
      });
    });

    // Add checkbox handlers
    document.querySelectorAll('.product-checkbox').forEach((checkbox) => {
      checkbox.addEventListener('change', (e) => {
        const productId = (e.target as HTMLInputElement).dataset.productId;
        if ((e.target as HTMLInputElement).checked) {
          selectedProducts.add(productId);
        } else {
          selectedProducts.delete(productId);
        }
        updateSelectionUI();
      });
    });

    // Select all checkbox handler
    const selectAllCheckbox = document.getElementById('select-all-checkbox') as HTMLInputElement;
    selectAllCheckbox?.addEventListener('change', (e) => {
      if ((e.target as HTMLInputElement).checked) {
        filtered.forEach((p: any) => selectedProducts.add(p.$id));
      } else {
        filtered.forEach((p: any) => selectedProducts.delete(p.$id));
      }
      renderProducts();
    });
    
    // Update select all checkbox state
    if (selectAllCheckbox && filtered.length > 0) {
      const allSelected = filtered.every((p: any) => selectedProducts.has(p.$id));
      selectAllCheckbox.checked = allSelected;
      selectAllCheckbox.indeterminate = selectedProducts.size > 0 && !allSelected;
    }
  }

  // Update selection UI
  function updateSelectionUI() {
    const toolbar = document.getElementById('selection-toolbar');
    const selectedCount = document.getElementById('selected-count');
    const selectAllBtn = document.getElementById('select-all-btn');
    const deselectAllBtn = document.getElementById('deselect-all-btn');
    const deleteBtn = document.getElementById('delete-selected-btn');
    const exportBtn = document.getElementById('export-selected-btn');
    
    if (selectedProducts.size > 0) {
      toolbar?.classList.remove('hidden');
      if (selectedCount) selectedCount.textContent = `${selectedProducts.size} selected`;
      selectAllBtn?.classList.add('hidden');
      deselectAllBtn?.classList.remove('hidden');
    } else {
      toolbar?.classList.add('hidden');
      selectAllBtn?.classList.remove('hidden');
      deselectAllBtn?.classList.add('hidden');
    }
    
    // Update delete button text
    if (deleteBtn) {
      deleteBtn.innerHTML = `<i class="bi bi-trash mr-1.5"></i> Delete (${selectedProducts.size})`;
    }
    
    // Update export button
    if (exportBtn) {
      exportBtn.innerHTML = `<i class="bi bi-download mr-1.5"></i> Export (${selectedProducts.size})`;
    }
  }

  // Export selected products to CSV
  function exportSelectedProducts() {
    const selectedProds = products.filter((p: any) => selectedProducts.has(p.$id));
    
    if (selectedProds.length === 0) {
      alert('No products selected for export');
      return;
    }
    
    // CSV headers
    const headers = ['Name', 'Description', 'Category', 'Brand', 'Price', 'Original Price', 'Stock', 'Active', 'Featured'];
    
    // CSV rows
    const rows = selectedProds.map((p: any) => [
      p.name || '',
      (p.description || '').replace(/,/g, ';'), // Escape commas
      p.category || '',
      p.brand || '',
      p.price || 0,
      p.originalPrice || '',
      p.stock || 0,
      p.isActive !== false ? 'Yes' : 'No',
      p.featured ? 'Yes' : 'No'
    ]);
    
    // Create CSV content
    const csvContent = [
      headers.join(','),
      ...rows.map(row => row.map(cell => `"${cell}"`).join(','))
    ].join('\n');
    
    // Download CSV
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.setAttribute('href', url);
    link.setAttribute('download', `products_export_${new Date().toISOString().split('T')[0]}.csv`);
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // Delete selected products
  async function deleteSelectedProducts() {
    const deleteModal = document.getElementById('delete-modal');
    const deleteCount = document.getElementById('delete-count');
    const cancelDeleteBtn = document.getElementById('cancel-delete-btn');
    const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
    
    if (selectedProducts.size === 0) {
      alert('No products selected for deletion');
      return;
    }
    
    // Show modal
    if (deleteCount) deleteCount.textContent = selectedProducts.size.toString();
    deleteModal?.classList.remove('hidden');
    
    // Cancel handler
    const cancelHandler = () => {
      deleteModal?.classList.add('hidden');
      cancelDeleteBtn?.removeEventListener('click', cancelHandler);
      confirmDeleteBtn?.removeEventListener('click', confirmHandler);
    };
    
    // Confirm handler
    const confirmHandler = async () => {
      deleteModal?.classList.add('hidden');
      cancelDeleteBtn?.removeEventListener('click', cancelHandler);
      confirmDeleteBtn?.removeEventListener('click', confirmHandler);
      
      const deleteBtn = document.getElementById('delete-selected-btn');
      if (deleteBtn) {
        deleteBtn.disabled = true;
        deleteBtn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin mr-1.5"></i> Deleting...';
      }
      
      try {
        const productIds = Array.from(selectedProducts);
        
        for (const productId of productIds) {
          await databases.deleteDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, productId);
        }
        
        // Refresh the product list immediately
        selectedProducts.clear();
        updateSelectionUI();
        await loadProducts();
        
        alert(`Successfully deleted ${productIds.length} product(s)`);
      } catch (error) {
        console.error('Error deleting products:', error);
        alert('Failed to delete products: ' + (error instanceof Error ? error.message : 'Unknown error'));
      } finally {
        if (deleteBtn) {
          deleteBtn.disabled = false;
          deleteBtn.innerHTML = '<i class="bi bi-trash mr-1.5"></i> Delete';
        }
      }
    };
    
    cancelDeleteBtn?.addEventListener('click', cancelHandler);
    confirmDeleteBtn?.addEventListener('click', confirmHandler);
  }

  // Setup event listeners
  document.getElementById('add-new-btn')?.addEventListener('click', () => showPanel());
  document.getElementById('close-panel')?.addEventListener('click', hidePanel);
  document.getElementById('cancel-btn')?.addEventListener('click', hidePanel);
  document.getElementById('panel-overlay')?.addEventListener('click', hidePanel);

  // Selection toolbar event listeners
  document.getElementById('select-all-btn')?.addEventListener('click', () => {
    products.forEach((p: any) => selectedProducts.add(p.$id));
    renderProducts();
    updateSelectionUI();
  });

  document.getElementById('deselect-all-btn')?.addEventListener('click', () => {
    selectedProducts.clear();
    renderProducts();
    updateSelectionUI();
  });

  document.getElementById('export-selected-btn')?.addEventListener('click', exportSelectedProducts);
  document.getElementById('delete-selected-btn')?.addEventListener('click', deleteSelectedProducts);

  // Search and filter
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    // Clear selection when filter changes
    selectedProducts.clear();
    renderProducts();
    updateSelectionUI();
  });

  document.getElementById('category-filter')?.addEventListener('change', (e) => {
    categoryFilter = (e.target as HTMLSelectElement).value;
    // Clear selection when filter changes
    selectedProducts.clear();
    renderProducts();
    updateSelectionUI();
  });


  // File upload
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadArea = document.getElementById('upload-area');
  const uploadLoading = document.getElementById('upload-loading');
  const compressionStats = document.getElementById('compression-stats');
  const uploadProgress = document.getElementById('upload-progress') as HTMLDivElement;
  const uploadProgressText = document.getElementById('upload-progress-text');
  const uploadProgressCount = document.getElementById('upload-progress-count');
  const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLDivElement;
  const pendingUploadsAlert = document.getElementById('pending-uploads-alert');
  const retryUploadBtn = document.getElementById('retry-upload-btn');

  // Check for pending uploads on load
  function checkPendingUploads() {
    if (hasPendingUploads() && !currentProductId) {
      pendingUploadsAlert?.classList.remove('hidden');
    }
  }

  // Retry upload for a single file
  async function retryUpload(index: number) {
    const file = mediaFiles[index];
    if (!file || file.status === 'uploading') return;
    
    uploadProgress?.classList.remove('hidden');
    uploadProgressText!.textContent = `Retrying ${file.type}...`;
    uploadProgressBar!.style.width = '50%';
    
    try {
      file.status = 'uploading';
      renderMediaGrid();
      
      const uploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), file.file!);
      const url = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, uploaded.$id).toString();
      
      let thumbnailUrl = '';
      if (file.type === 'video' && file.thumbnail) {
        const thumbBlob = await fetch(file.thumbnail).then(r => r.blob());
        const thumbFile = new File([thumbBlob], `thumb_${uploaded.$id}.jpg`, { type: 'image/jpeg' });
        const thumbUploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), thumbFile);
        thumbnailUrl = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, thumbUploaded.$id).toString();
      }
      
      file.status = 'completed';
      file.uploadedUrl = url;
      file.data = url;
      if (thumbnailUrl) file.thumbnail = thumbnailUrl;
      
      uploadProgressBar!.style.width = '100%';
      saveToCache(mediaFiles);
      renderMediaGrid();
      
      setTimeout(() => {
        uploadProgress?.classList.add('hidden');
        uploadProgressBar!.style.width = '0%';
      }, 1000);
    } catch (error) {
      console.error('Retry failed:', error);
      file.status = 'failed';
      file.error = error instanceof Error ? error.message : 'Upload failed';
      uploadProgressBar!.style.width = '0%';
      uploadProgress?.classList.add('hidden');
      renderMediaGrid();
      alert('Failed to retry upload: ' + (error instanceof Error ? error.message : 'Unknown error'));
    }
  }

  // Resume all pending uploads
  async function resumePendingUploads() {
    const pendingFiles = mediaFiles.filter(f => f.status === 'pending' || f.status === 'failed');
    if (pendingFiles.length === 0) return;
    
    uploadProgress?.classList.remove('hidden');
    pendingUploadsAlert?.classList.add('hidden');
    
    const result = await uploadFilesSequentially(
      mediaFiles,
      APPWRITE_IMAGES_BUCKET_ID,
      storage,
      ID,
      (file, index, total) => {
        uploadProgressText!.textContent = `Uploading ${file.type} ${index}/${total}...`;
        uploadProgressBar!.style.width = `${(index / total) * 100}%`;
      },
      (file, result) => {
        file.data = result.url;
        file.uploadedUrl = result.url;
        if (result.thumbnailUrl) file.thumbnail = result.thumbnailUrl;
        saveToCache(mediaFiles);
        renderMediaGrid();
      },
      (file, error) => {
        file.status = 'failed';
        file.error = error.message;
        saveToCache(mediaFiles);
        renderMediaGrid();
      }
    );
    
    uploadProgressBar!.style.width = '100%';
    setTimeout(() => {
      uploadProgress?.classList.add('hidden');
      uploadProgressBar!.style.width = '0%';
    }, 1000);
    
    if (result.failed.length > 0) {
      alert(`${result.failed.length} file(s) failed to upload. Click Retry to try again.`);
    }
  }

  retryUploadBtn?.addEventListener('click', resumePendingUploads);

  uploadArea?.addEventListener('click', () => fileInput.click());
  
  fileInput?.addEventListener('change', async () => {
    if (!fileInput.files) return;
    uploadLoading?.classList.remove('hidden');
    
    for (const file of Array.from(fileInput.files)) {
      if (file.type.startsWith('image/')) {
        const compressed = await compressImage(file, { quality: 0.8 });
        
        // Convert base64 to blob then to File
        const response = await fetch(compressed);
        const blob = await response.blob();
        const compressedFile = new File([blob], file.name, { type: 'image/jpeg' });
        
        const newFile = {
          type: 'image' as const,
          data: compressed,
          file: compressedFile,
          isPrimary: mediaFiles.filter(m => m.type === 'image').length === 0,
          status: 'pending' as const,
          createdAt: Date.now()
        };
        mediaFiles.push(newFile);
      } else if (file.type.startsWith('video/')) {
        const videoData = await compressVideo(file);
        mediaFiles.push({
          type: 'video',
          thumbnail: videoData.thumbnail,
          duration: videoData.duration,
          file: file,
          isPrimary: false,
          status: 'pending' as const,
          createdAt: Date.now()
        });
      }
    }
    
    // Save to cache
    saveToCache(mediaFiles);
    
    uploadLoading?.classList.add('hidden');
    compressionStats?.classList.remove('hidden');
    setTimeout(() => compressionStats?.classList.add('hidden'), 3000);
    renderMediaGrid();
    fileInput.value = '';
  });

  // Toggle active status
  const isActiveToggle = document.getElementById('isActive') as HTMLButtonElement;
  isActiveToggle?.addEventListener('click', () => {
    const isActive = isActiveToggle.dataset.currentStatus === 'active';
    isActiveToggle.dataset.currentStatus = isActive ? 'inactive' : 'active';
    isActiveToggle.classList.toggle('bg-primary', !isActive);
    isActiveToggle.classList.toggle('bg-muted', isActive);
    isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-6', !isActive);
    isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-1', isActive);
  });

  // Form submission
  const form = document.getElementById('product-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text');
    const uploadProgress = document.getElementById('upload-progress') as HTMLDivElement;
    const uploadProgressText = document.getElementById('upload-progress-text');
    const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLDivElement;
    
    submitBtn.disabled = true;
    if (submitText) submitText.innerHTML = '<i class="bi bi-arrow-repeat animate-spin mr-2"></i>' + (currentProductId ? 'Updating...' : 'Creating...');

    try {
      const imageUrls: string[] = [];
      let videoUrl = '';
      let videoThumbnailUrl = '';

      // Upload pending media files sequentially
      const pendingFiles = mediaFiles.filter(f => f.status === 'pending' || f.status === 'failed');
      if (pendingFiles.length > 0) {
        uploadProgress?.classList.remove('hidden');
        
        for (let i = 0; i < mediaFiles.length; i++) {
          const media = mediaFiles[i];
          
          if (media.status === 'pending' || media.status === 'failed') {
            if (!media.file) continue;
            
            uploadProgressText!.textContent = `Uploading ${media.type} ${i + 1}/${mediaFiles.length}...`;
            uploadProgressBar!.style.width = `${((i + 1) / mediaFiles.length) * 100}%`;
            
            try {
              const uploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), media.file);
              const url = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, uploaded.$id).toString();
              
              media.status = 'completed';
              media.uploadedUrl = url;
              
              if (media.type === 'image') {
                imageUrls.push(url);
              } else if (media.type === 'video') {
                videoUrl = url;
                
                // Upload thumbnail
                const thumbBlob = await fetch(media.thumbnail!).then(r => r.blob());
                const thumbFile = new File([thumbBlob], `thumb_${uploaded.$id}.jpg`, { type: 'image/jpeg' });
                const thumbUploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), thumbFile);
                videoThumbnailUrl = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, thumbUploaded.$id).toString();
              }
            } catch (uploadError) {
              console.error('Upload failed for:', media, uploadError);
              media.status = 'failed';
              media.error = uploadError instanceof Error ? uploadError.message : 'Upload failed';
            }
          } else if (media.status === 'completed') {
            // Already uploaded or existing
            if (media.type === 'image') {
              imageUrls.push(media.data || media.url || '');
            } else if (media.type === 'video') {
              videoUrl = media.data || media.url || '';
              videoThumbnailUrl = media.thumbnail || '';
            }
          }
        }
        
        uploadProgressBar!.style.width = '100%';
        setTimeout(() => uploadProgress?.classList.add('hidden'), 500);
      } else {
        // No pending files, use existing URLs
        for (const media of mediaFiles) {
          if (media.type === 'image') {
            imageUrls.push(media.data || media.url || '');
          } else if (media.type === 'video') {
            videoUrl = media.data || media.url || '';
            videoThumbnailUrl = media.thumbnail || '';
          }
        }
      }

      const formData = new FormData(form);
      const productData = {
        name: formData.get('name'),
        description: formData.get('description'),
        category: formData.get('category'),
        brand: formData.get('brand'),
        price: parseFloat(formData.get('price') as string),
        originalPrice: parseFloat(formData.get('originalPrice') as string) || null,
        stock: parseInt(formData.get('stock') as string) || 0,
        image: imageUrls[0] || '',
        images: imageUrls,
        video: videoUrl,
        videoThumbnail: videoThumbnailUrl,
        featured: formData.has('featured'),
        verified: formData.has('verified'),
        isUnique: formData.has('isUnique'),
        isActive: isActiveToggle?.dataset.currentStatus === 'active',
        isArchived: false
      };

      let savedProductId = currentProductId;
      if (currentProductId) {
        await databases.updateDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, currentProductId, productData);
      } else {
        const newDoc = await databases.createDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, ID.unique(), productData);
        savedProductId = newDoc.$id;
      }

      // Clear upload cache on successful submission
      clearCache();
      
      hidePanel();
      await loadProducts();
    } catch (error) {
      console.error('Error saving product:', error);
      alert('Failed to save product: ' + (error instanceof Error ? error.message : 'Unknown error'));
    } finally {
      submitBtn.disabled = false;
      if (submitText) submitText.textContent = currentProductId ? 'Update Product' : 'Create Product';
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      hidePanel();
    }
  });

  // Load products on page load
  loadProducts();

  // Reload after view transitions
  document.addEventListener('astro:after-swap', () => {
    loadProducts();
  });
</script>

