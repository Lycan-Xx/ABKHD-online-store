---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { products } from '../../../data/products';

// Get product ID from URL
const { id } = Astro.params;

// Find product
const product = products.find(p => p.id === id);

// Get unique categories
const categories = [...new Set(products.map(p => p.category))];

// If product not found, redirect to products list
if (!product) {
  return Astro.redirect('/admin/products');
}
---

<AdminLayout title={`Edit ${product.name}`}>
  <div class="max-w-4xl mx-auto space-y-6">
    <!-- Page Header -->
    <div class="flex items-center gap-4">
      <a href="/admin/products" class="p-2 rounded-lg hover:bg-muted transition-colors">
        <i class="bi bi-arrow-left text-lg"></i>
      </a>
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">Edit Product</h1>
        <p class="text-muted-foreground mt-1">
          Update product details
        </p>
      </div>
    </div>

    <!-- Product Form -->
    <form id="product-form" class="space-y-6">
      <!-- Basic Info -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Basic Information</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Product Name -->
          <div class="md:col-span-2">
            <label for="name" class="block text-sm font-medium mb-2">
              Product Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              value={product.name}
              required
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Enter product name"
            />
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <label for="description" class="block text-sm font-medium mb-2">
              Description
            </label>
            <textarea
              id="description"
              name="description"
              rows="4"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring resize-none"
              placeholder="Enter product description"
            >{product.description || ''}</textarea>
          </div>

          <!-- Category -->
          <div>
            <label for="category" class="block text-sm font-medium mb-2">
              Category <span class="text-red-500">*</span>
            </label>
            <select
              id="category"
              name="category"
              required
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
            >
              <option value="">Select category</option>
              {categories.map(cat => (
                <option value={cat} selected={product.category === cat}>
                  {cat}
                </option>
              ))}
            </select>
          </div>

          <!-- Brand -->
          <div>
            <label for="brand" class="block text-sm font-medium mb-2">
              Brand
            </label>
            <input
              type="text"
              id="brand"
              name="brand"
              value={product.brand || ''}
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Enter brand name"
            />
          </div>
        </div>
      </div>

      <!-- Pricing -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Pricing</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Price -->
          <div>
            <label for="price" class="block text-sm font-medium mb-2">
              Price (₦) <span class="text-red-500">*</span>
            </label>
            <input
              type="number"
              id="price"
              name="price"
              value={product.price}
              required
              min="0"
              step="0.01"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0.00"
            />
          </div>

          <!-- Original Price (Discount) -->
          <div>
            <label for="originalPrice" class="block text-sm font-medium mb-2">
              Original Price (₦)
            </label>
            <input
              type="number"
              id="originalPrice"
              name="originalPrice"
              value={product.originalPrice || ''}
              min="0"
              step="0.01"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0.00"
            />
            <p class="text-xs text-muted-foreground mt-1">For showing discount</p>
          </div>

          <!-- Stock -->
          <div>
            <label for="stock" class="block text-sm font-medium mb-2">
              Stock Quantity
            </label>
            <input
              type="number"
              id="stock"
              name="stock"
              value={product.stock || 0}
              min="0"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0"
            />
          </div>
        </div>
      </div>

      <!-- Images & Videos -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Images & Videos</h2>
        
        <!-- Compression Stats -->
        <div id="compression-stats" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3 flex items-center justify-between">
          <div class="flex items-center gap-2 text-green-700 dark:text-green-400">
            <i class="bi bi-check-circle-fill"></i>
            <span id="compression-stats-text" class="text-sm"></span>
          </div>
          <span id="compression-savings" class="text-sm font-medium text-green-600 dark:text-green-300"></span>
        </div>

        <!-- Loading State -->
        <div id="loading-state" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3 flex items-center gap-2">
          <i class="bi bi-arrow-repeat animate-spin text-blue-600"></i>
          <span class="text-sm text-blue-700 dark:text-blue-300">
            Compressing images...
          </span>
        </div>

        <!-- Image/Video Grid -->
        <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          <!-- Existing images will be shown here -->
        </div>

        <!-- Upload Area -->
        <div
          id="upload-area"
          class="border-2 border-dashed rounded-lg p-8 text-center cursor-pointer transition-colors hover:border-primary hover:bg-primary/5"
        >
          <input
            type="file"
            id="file-input"
            accept="image/*,video/*"
            multiple
            class="hidden"
          />
          <div class="text-muted-foreground">
            <i class="bi bi-cloud-arrow-up text-3xl mb-3 block"></i>
            <p class="text-sm font-medium">
              Click to upload or drag and drop
            </p>
            <p class="text-xs mt-1">
              Images (PNG, JPG, WEBP) and Videos up to 50MB
            </p>
            <p class="text-xs mt-2 text-blue-600 dark:text-blue-400">
              <i class="bi bi-lightning-charge mr-1"></i>
              Files are automatically compressed
            </p>
          </div>
        </div>

        <!-- Hidden inputs to store media data -->
        <input type="hidden" id="images" name="images" value={product.images ? JSON.stringify(product.images) : (product.image ? JSON.stringify([product.image]) : '[]')} />
        <input type="hidden" id="videos" name="videos" value={product.videos ? JSON.stringify(product.videos) : '[]'} />

        <p class="text-xs text-muted-foreground">
          The first image will be used as the main product image.
          <span class="text-blue-600 dark:text-blue-400">
            <i class="bi bi-info-circle mr-1"></i>
            Images over 1MB are automatically compressed to reduce file size while maintaining quality.
          </span>
        </p>
      </div>

      <!-- Status -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Status</h2>
        
        <!-- Listed (Active) Toggle -->
        <div class="flex items-center gap-3">
          <button
            type="button"
            id="isActive"
            class="toggle-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 bg-primary"
            data-current-status={(product.isActive !== false) ? 'active' : 'inactive'}
          >
            <span class="toggle-indicator inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform translate-x-6"></span>
          </button>
          <div>
            <label for="isActive" class="text-sm font-medium cursor-pointer">
              List product in shop
            </label>
            <p class="text-xs text-muted-foreground">
              If OFF, product will not be shown in the shop
            </p>
          </div>
        </div>

        <!-- Featured -->
        <div class="flex items-center gap-3">
          <input
            type="checkbox"
            id="featured"
            name="featured"
            checked={product.featured || false}
            class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
          />
          <label for="featured" class="text-sm font-medium">
            Featured Product
          </label>
        </div>
        <p class="text-xs text-muted-foreground">
          Featured products appear on the homepage and get highlighted in listings
        </p>
      </div>

      <!-- Submit -->
      <div class="flex items-center gap-4">
        <button
          type="submit"
          class="btn-primary"
        >
          <i class="bi bi-check-lg mr-2"></i>
          Update Product
        </button>
        <a
          href="/admin/products"
          class="btn-secondary"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .btn-primary {
    @apply inline-flex items-center justify-center px-6 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium transition-colors hover:bg-primary/90;
  }
  
  .btn-secondary {
    @apply inline-flex items-center justify-center px-6 py-2.5 rounded-lg border bg-background font-medium transition-colors hover:bg-muted;
  }

  .toggle-btn.active {
    @apply bg-primary;
  }
  
  .toggle-btn.inactive {
    @apply bg-muted;
  }
  
  .toggle-btn.active .toggle-indicator {
    @apply translate-x-6;
  }
  
  .toggle-btn.inactive .toggle-indicator {
    @apply translate-x-1;
  }
</style>

<script>
  // Import compression functions from utils
  import { compressImage, compressVideo, formatFileSize, needsCompression } from '../../../lib/utils';

  // State
  let mediaFiles = []; // Array of { type: 'image'|'video', data: string, isPrimary: boolean }
  let isProcessing = false;

  // DOM Elements
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadArea = document.getElementById('upload-area') as HTMLDivElement;
  const mediaGrid = document.getElementById('media-grid') as HTMLDivElement;
  const imagesInput = document.getElementById('images') as HTMLInputElement;
  const videosInput = document.getElementById('videos') as HTMLInputElement;
  const loadingState = document.getElementById('loading-state') as HTMLDivElement;
  const compressionStats = document.getElementById('compression-stats') as HTMLDivElement;
  const compressionStatsText = document.getElementById('compression-stats-text') as HTMLSpanElement;
  const compressionSavings = document.getElementById('compression-savings') as HTMLSpanElement;

  // Initialize with existing product images
  const initializeExistingMedia = () => {
    const existingImages = imagesInput.value ? JSON.parse(imagesInput.value) : [];
    const existingVideos = videosInput.value ? JSON.parse(videosInput.value) : [];
    
    // Add existing images
    existingImages.forEach((img: string, index: number) => {
      mediaFiles.push({ type: 'image', data: img, isPrimary: index === 0 });
    });
    
    // Add existing videos
    existingVideos.forEach((video: string) => {
      mediaFiles.push({ type: 'video', data: video, isPrimary: false });
    });
    
    renderMediaGrid();
  };

  // Render media grid
  const renderMediaGrid = () => {
    mediaGrid.innerHTML = '';
    
    mediaFiles.forEach((file, index) => {
      const item = document.createElement('div');
      item.className = 'relative group aspect-square rounded-lg overflow-hidden border bg-muted';
      
      if (file.type === 'image') {
        item.innerHTML = `
          <img src="${file.data}" alt="Product image ${index + 1}" class="w-full h-full object-cover" />
          ${file.isPrimary ? '<span class="absolute bottom-2 left-2 px-2 py-0.5 text-xs font-medium bg-primary text-primary-foreground rounded">Main</span>' : ''}
        `;
      } else {
        item.innerHTML = `
          <div class="w-full h-full flex items-center justify-center bg-muted">
            <i class="bi bi-play-circle text-3xl text-muted-foreground"></i>
          </div>
          <span class="absolute bottom-2 left-2 px-2 py-0.5 text-xs font-medium bg-blue-600 text-white rounded">Video</span>
        `;
      }
      
      // Remove button
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-background/90 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background';
      removeBtn.innerHTML = '<i class="bi bi-x-lg text-sm"></i>';
      removeBtn.onclick = () => removeMedia(index);
      item.appendChild(removeBtn);
      
      // Set as primary button (for images only)
      if (file.type === 'image' && !file.isPrimary) {
        const primaryBtn = document.createElement('button');
        primaryBtn.type = 'button';
        primaryBtn.className = 'absolute bottom-2 right-2 px-2 py-0.5 text-xs font-medium bg-background/90 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background';
        primaryBtn.innerHTML = 'Set Main';
        primaryBtn.onclick = () => setAsPrimary(index);
        item.appendChild(primaryBtn);
      }
      
      mediaGrid.appendChild(item);
    });
  };

  // Remove media
  const removeMedia = (index: number) => {
    const wasPrimary = mediaFiles[index].isPrimary;
    mediaFiles.splice(index, 1);
    
    // If removed item was primary, make first image primary
    if (wasPrimary && mediaFiles.length > 0) {
      const firstImageIndex = mediaFiles.findIndex(f => f.type === 'image');
      if (firstImageIndex !== -1) {
        mediaFiles[firstImageIndex].isPrimary = true;
      }
    }
    
    updateHiddenInputs();
    renderMediaGrid();
  };

  // Set as primary image
  const setAsPrimary = (index: number) => {
    if (mediaFiles[index].type !== 'image') return;
    
    mediaFiles.forEach((file, i) => {
      if (file.type === 'image') {
        file.isPrimary = i === index;
      }
    });
    
    updateHiddenInputs();
    renderMediaGrid();
  };

  // Update hidden inputs
  const updateHiddenInputs = () => {
    const images = mediaFiles.filter(f => f.type === 'image').map(f => f.data);
    const videos = mediaFiles.filter(f => f.type === 'video').map(f => f.data);
    
    imagesInput.value = JSON.stringify(images);
    videosInput.value = JSON.stringify(videos);
  };

  // Process files
  const processFiles = async (files: FileList | File[]) => {
    if (isProcessing) return;
    
    const fileArray = Array.from(files);
    if (fileArray.length === 0) return;
    
    isProcessing = true;
    loadingState.classList.remove('hidden');
    uploadArea.classList.add('opacity-50', 'pointer-events-none');
    
    let totalOriginalSize = 0;
    let totalCompressedSize = 0;
    let imageCount = 0;
    let videoCount = 0;
    
    for (const file of fileArray) {
      totalOriginalSize += file.size;
      
      if (file.type.startsWith('image/')) {
        try {
          const compressed = await compressImage(file, {
            maxWidth: 1920,
            maxHeight: 1920,
            quality: 0.8
          });
          
          // Determine if this should be primary (first image)
          const isFirstImage = !mediaFiles.some(f => f.type === 'image');
          mediaFiles.push({ type: 'image', data: compressed, isPrimary: isFirstImage });
          imageCount++;
          
          const compressedSize = Math.round((compressed.length * 3) / 4);
          totalCompressedSize += compressedSize;
          
        } catch (error) {
          console.error('Error compressing image:', error);
          // Fallback to original
          const reader = new FileReader();
          reader.onload = (e) => {
            const isFirstImage = !mediaFiles.some(f => f.type === 'image');
            mediaFiles.push({ type: 'image', data: e.target?.result as string, isPrimary: isFirstImage });
            renderMediaGrid();
            updateHiddenInputs();
          };
          reader.readAsDataURL(file);
        }
      } else if (file.type.startsWith('video/')) {
        try {
          const videoData = await compressVideo(file);
          
          // Add video thumbnail as image preview
          mediaFiles.push({ type: 'video', data: videoData.thumbnail, isPrimary: false });
          videoCount++;
          
          totalCompressedSize += Math.round((videoData.thumbnail.length * 3) / 4);
          
        } catch (error) {
          console.error('Error processing video:', error);
        }
      }
    }
    
    // Show compression stats
    if ((imageCount > 0 || videoCount > 0) && totalOriginalSize > 0) {
      const savings = ((totalOriginalSize - totalCompressedSize) / totalOriginalSize * 100).toFixed(1);
      
      compressionStatsText.textContent = `${imageCount} image(s)${videoCount > 0 ? `, ${videoCount} video(s)` : ''} processed`;
      compressionSavings.textContent = `${savings}% smaller`;
      compressionStats.classList.remove('hidden');
      
      // Clear stats after 5 seconds
      setTimeout(() => {
        compressionStats.classList.add('hidden');
      }, 5000);
    }
    
    loadingState.classList.add('hidden');
    uploadArea.classList.remove('opacity-50', 'pointer-events-none');
    isProcessing = false;
    
    renderMediaGrid();
    updateHiddenInputs();
    
    // Reset file input
    fileInput.value = '';
  };

  // Event listeners
  uploadArea.addEventListener('click', () => fileInput.click());
  
  fileInput.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.files) {
      processFiles(target.files);
    }
  });

  // Drag and drop
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.add('border-primary', 'bg-primary/5');
  });

  uploadArea.addEventListener('dragleave', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.remove('border-primary', 'bg-primary/5');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.remove('border-primary', 'bg-primary/5');
    
    if (e.dataTransfer?.files) {
      processFiles(e.dataTransfer.files);
    }
  });

  // Form submission
  const form = document.getElementById('product-form') as HTMLFormElement;
  const isActiveToggle = document.getElementById('isActive') as HTMLButtonElement;
  
  // Initialize toggle button visual state
  const initToggle = () => {
    if (isActiveToggle) {
      const isActive = isActiveToggle.dataset.currentStatus === 'active';
      if (!isActive) {
        isActiveToggle.classList.remove('bg-primary');
        isActiveToggle.classList.add('bg-muted');
        isActiveToggle.querySelector('.toggle-indicator')?.classList.remove('translate-x-6');
        isActiveToggle.querySelector('.toggle-indicator')?.classList.add('translate-x-1');
      }
    }
  };
  initToggle();
  
  // Toggle button click handler
  isActiveToggle?.addEventListener('click', () => {
    const isActive = isActiveToggle.dataset.currentStatus === 'active';
    const newStatus = !isActive;
    
    if (newStatus) {
      isActiveToggle.classList.add('bg-primary');
      isActiveToggle.classList.remove('bg-muted');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.add('translate-x-6');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.remove('translate-x-1');
      isActiveToggle.dataset.currentStatus = 'active';
    } else {
      isActiveToggle.classList.add('bg-muted');
      isActiveToggle.classList.remove('bg-primary');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.add('translate-x-1');
      isActiveToggle.querySelector('.toggle-indicator')?.classList.remove('translate-x-6');
      isActiveToggle.dataset.currentStatus = 'inactive';
    }
  });
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Collect form data
      const formData = new FormData(form);
      const productData = {
        id: window.location.pathname.split('/').pop(),
        name: formData.get('name'),
        description: formData.get('description'),
        category: formData.get('category'),
        brand: formData.get('brand'),
        price: parseFloat(formData.get('price') as string) || 0,
        originalPrice: parseFloat(formData.get('originalPrice') as string) || null,
        stock: parseInt(formData.get('stock') as string) || 0,
        image: mediaFiles.find(f => f.type === 'image' && f.isPrimary)?.data || null,
        images: mediaFiles.filter(f => f.type === 'image').map(f => f.data),
        videos: mediaFiles.filter(f => f.type === 'video').map(f => f.data),
        featured: formData.has('featured'),
        isActive: isActiveToggle?.dataset.currentStatus === 'active'
      };
      
      console.log('Product data:', productData);
      
      // In a real app, this would save to the backend
      alert('Product updated! (This is a demo - in production, this would save to your backend)');
      
      // Redirect to products list
      window.location.href = '/admin/products';
    });
  }

  // Initialize on load
  initializeExistingMedia();
</script>
