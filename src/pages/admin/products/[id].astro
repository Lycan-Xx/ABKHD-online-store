---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../../../lib/appwrite';
import { parseDescription } from '../../../lib/utils';
import { Query } from 'appwrite';

export async function getStaticPaths() {
  try {
    const response = await databases.listDocuments(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, [Query.limit(100)]);
    return response.documents.map(product => ({
      params: { id: product.$id },
    }));
  } catch (error) {
    console.error('Error in getStaticPaths for admin products:', error);
    return [];
  }
}

const { id } = Astro.params;

// Define the 3 main product categories
const DEFAULT_CATEGORIES = ['Computers', 'Mobile Phones', 'Accessories'];

let product = null;
let categories = [];
try {
  product = await databases.getDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, id);
  const categoriesResponse = await databases.listDocuments(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, [Query.limit(100)]);
  // Filter out undefined/null categories and get unique values
  const existingCategories = [...new Set(
    categoriesResponse.documents
      .map((p: any) => p.category)
      .filter((cat: any) => cat && typeof cat === 'string')
  )];
  // Merge with defaults and remove duplicates
  categories = [...new Set([...DEFAULT_CATEGORIES, ...existingCategories])];
  console.log('Categories loaded:', categories);
} catch (error) {
  console.error('Error fetching product for edit:', error);
  categories = DEFAULT_CATEGORIES;
  console.log('Using default categories:', categories);
}
---

<AdminLayout title={`Edit ${product.name}`}>
  <div class="max-w-4xl mx-auto space-y-6">
    <!-- Page Header -->
    <div class="flex items-center gap-4">
      <a href="/admin/products" class="p-2 rounded-lg hover:bg-muted transition-colors">
        <i class="bi bi-arrow-left text-lg"></i>
      </a>
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">Edit Product</h1>
        <p class="text-muted-foreground mt-1">
          Update product details
        </p>
      </div>
    </div>

    <!-- Product Form -->
    <form id="product-form" class="space-y-6">
      <!-- Basic Info -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Basic Information</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Product Name -->
          <div class="md:col-span-2">
            <label for="name" class="block text-sm font-medium mb-2">
              Product Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              value={product.name}
              required
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Enter product name"
            />
          </div>

          <!-- Description -->
          <div class="md:col-span-2">
            <label for="description" class="block text-sm font-medium mb-2">
              Description
            </label>
            <textarea
              id="description"
              name="description"
              rows="4"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring resize-none"
              placeholder="Enter product description"
            >{product.description || ''}</textarea>
            
            <!-- Description Preview -->
            <div class="mt-4 p-4 rounded-lg border bg-muted/30">
              <p class="text-xs font-medium text-muted-foreground mb-3">
                <i class="bi bi-eye mr-1"></i>Preview (how it will appear)
              </p>
              <div id="description-preview" class="text-sm space-y-3 text-foreground">
                {product.description ? (
                  <div set:html={product.description} />
                ) : (
                  <p class="text-muted-foreground italic">Description preview will appear here...</p>
                )}
              </div>
            </div>
          </div>

          <!-- Category -->
          <div>
            <label for="category" class="block text-sm font-medium mb-2">
              Category <span class="text-red-500">*</span>
            </label>
            <select
              id="category"
              name="category"
              required
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
            >
              <option value="">Select category</option>
              {categories.map(cat => (
                <option value={cat} selected={product.category === cat}>
                  {cat}
                </option>
              ))}
            </select>
          </div>

          <!-- Brand -->
          <div>
            <label for="brand" class="block text-sm font-medium mb-2">
              Brand
            </label>
            <input
              type="text"
              id="brand"
              name="brand"
              value={product.brand || ''}
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Enter brand name"
            />
          </div>
        </div>
      </div>

      <!-- Pricing -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Pricing</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Price -->
          <div>
            <label for="price" class="block text-sm font-medium mb-2">
              Price (₦) <span class="text-red-500">*</span>
            </label>
            <input
              type="number"
              id="price"
              name="price"
              value={product.price}
              required
              min="0"
              step="0.01"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0.00"
            />
          </div>

          <!-- Original Price (Discount) -->
          <div>
            <label for="originalPrice" class="block text-sm font-medium mb-2">
              Original Price (₦)
            </label>
            <input
              type="number"
              id="originalPrice"
              name="originalPrice"
              value={product.originalPrice || ''}
              min="0"
              step="0.01"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0.00"
            />
            <p class="text-xs text-muted-foreground mt-1">For showing discount</p>
            <!-- Discount Percentage Display -->
            <div id="discount-display" class="mt-2 hidden">
              <span class="inline-flex items-center gap-2 px-3 py-1 rounded-lg bg-primary/10 text-primary text-xs font-semibold border border-primary/20">
                <i class="bi bi-percent"></i>
                <span id="discount-value">0</span>% OFF
              </span>
            </div>
          </div>

          <!-- Stock -->
          <div>
            <label for="stock" class="block text-sm font-medium mb-2">
              Stock Quantity
            </label>
            <input
              type="number"
              id="stock"
              name="stock"
              value={product.stock || 0}
              min="0"
              class="w-full px-4 py-2.5 rounded-lg border bg-background text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="0"
            />
          </div>
        </div>
      </div>

      <!-- Images & Videos -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Images & Videos</h2>
        
        <!-- Compression Stats -->
        <div id="compression-stats" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3 flex items-center justify-between">
          <div class="flex items-center gap-2 text-green-700 dark:text-green-400">
            <i class="bi bi-check-circle-fill"></i>
            <span id="compression-stats-text" class="text-sm"></span>
          </div>
          <span id="compression-savings" class="text-sm font-medium text-green-600 dark:text-green-300"></span>
        </div>

        <!-- Loading State -->
        <div id="loading-state" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3 flex items-center gap-2">
          <i class="bi bi-arrow-repeat animate-spin text-blue-600"></i>
          <span class="text-sm text-blue-700 dark:text-blue-300">
            Compressing images...
          </span>
        </div>

        <!-- Upload Progress -->
        <div id="upload-progress" class="hidden bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-blue-700 dark:text-blue-400">
              <i class="bi bi-cloud-arrow-up mr-1 animate-pulse"></i>
              <span id="upload-progress-text">Uploading...</span>
            </span>
            <span id="upload-progress-count" class="text-xs text-blue-600 dark:text-blue-300"></span>
          </div>
          <div class="w-full bg-blue-200 dark:bg-blue-800 rounded-full h-2">
            <div id="upload-progress-bar" class="bg-blue-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
          </div>
        </div>

        <!-- Pending Uploads Alert -->
        <div id="pending-uploads-alert" class="hidden bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 text-amber-700 dark:text-amber-400">
              <i class="bi bi-exclamation-triangle-fill"></i>
              <span class="text-sm">You have pending uploads from a previous session</span>
            </div>
            <button id="retry-upload-btn" type="button" class="text-xs px-3 py-1 bg-amber-500 text-white rounded hover:bg-amber-600 transition-colors">
              Resume Upload
            </button>
          </div>
        </div>

        <!-- Image/Video Grid -->
        <div id="media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          <!-- Existing images will be shown here -->
        </div>

        <!-- Upload Area -->
        <div
          id="upload-area"
          class="border-2 border-dashed rounded-lg p-8 text-center cursor-pointer transition-colors hover:border-primary hover:bg-primary/5"
        >
          <input
            type="file"
            id="file-input"
            accept="image/*,video/*"
            multiple
            class="hidden"
          />
          <div class="text-muted-foreground">
            <i class="bi bi-cloud-arrow-up text-3xl mb-3 block"></i>
            <p class="text-sm font-medium">
              Click to upload or drag and drop
            </p>
            <p class="text-xs mt-1">
              Images (PNG, JPG, WEBP) and Videos up to 50MB
            </p>
            <p class="text-xs mt-2 text-blue-600 dark:text-blue-400">
              <i class="bi bi-lightning-charge mr-1"></i>
              Files are automatically compressed
            </p>
          </div>
        </div>

        <!-- Hidden inputs to store media data -->
        <input type="hidden" id="images" name="images" value={product.images ? JSON.stringify(product.images) : (product.image ? JSON.stringify([product.image]) : '[]')} />
        <input type="hidden" id="video-url-hidden" value={product.video || ''} />
        <input type="hidden" id="video-thumb-hidden" value={product.videoThumbnail || ''} />

        <p class="text-xs text-muted-foreground">
          The first image will be used as the main product image.
          <span class="text-blue-600 dark:text-blue-400">
            <i class="bi bi-info-circle mr-1"></i>
            Images over 1MB are automatically compressed to reduce file size while maintaining quality.
          </span>
        </p>
      </div>

      <!-- Status -->
      <div class="rounded-xl border bg-card p-6 space-y-4">
        <h2 class="text-lg font-semibold">Status</h2>
        
        <!-- Listed (Active) Toggle -->
        <div class="flex items-center gap-3">
          <button
            type="button"
            id="isActive"
            class="toggle-btn relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 bg-primary"
            data-current-status={(product.isActive !== false) ? 'active' : 'inactive'}
          >
            <span class="toggle-indicator inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform translate-x-6"></span>
          </button>
          <div>
            <label for="isActive" class="text-sm font-medium cursor-pointer">
              List product in shop
            </label>
            <p class="text-xs text-muted-foreground">
              If OFF, product will not be shown in the shop
            </p>
          </div>
        </div>

        <!-- Featured -->
        <div class="flex items-center gap-3">
          <input
            type="checkbox"
            id="featured"
            name="featured"
            checked={product.featured || false}
            class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
          />
          <label for="featured" class="text-sm font-medium">
            Featured Product
          </label>
        </div>
        <p class="text-xs text-muted-foreground">
          Featured products appear on the homepage and get highlighted in listings
        </p>
      </div>

      <!-- Submit -->
      <div class="flex items-center gap-4">
        <button
          type="submit"
          class="btn-primary"
        >
          <i class="bi bi-check-lg mr-2"></i>
          Update Product
        </button>
        <a
          href="/admin/products"
          class="btn-secondary"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .btn-primary {
    @apply inline-flex items-center justify-center px-6 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium transition-colors hover:bg-primary/90;
  }
  
  .btn-secondary {
    @apply inline-flex items-center justify-center px-6 py-2.5 rounded-lg border bg-background font-medium transition-colors hover:bg-muted;
  }

  .toggle-btn.active {
    @apply bg-primary;
  }
  
  .toggle-btn.inactive {
    @apply bg-muted;
  }
  
  .toggle-btn.active .toggle-indicator {
    @apply translate-x-6;
  }
  
  .toggle-btn.inactive .toggle-indicator {
    @apply translate-x-1;
  }
</style>

<script>
  import { databases, storage, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, APPWRITE_IMAGES_BUCKET_ID, ID } from '../../../lib/appwrite';
  import { compressImage, compressVideo, parseDescription } from '../../../lib/utils';
  import { 
    saveToCache, 
    loadFromCache, 
    clearCache, 
    hasPendingUploads
  } from '../../../lib/upload-cache';

  let mediaFiles: any[] = [];
  const productId = window.location.pathname.split('/').pop();

  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadArea = document.getElementById('upload-area') as HTMLDivElement;
  const mediaGrid = document.getElementById('media-grid') as HTMLDivElement;
  const loadingState = document.getElementById('loading-state') as HTMLDivElement;
  const form = document.getElementById('product-form') as HTMLFormElement;
  const isActiveToggle = document.getElementById('isActive') as HTMLButtonElement;
  const imagesInput = document.getElementById('images') as HTMLInputElement;
  
  // Description Preview Elements
  const descriptionField = document.getElementById('description') as HTMLTextAreaElement;
  const descriptionPreview = document.getElementById('description-preview') as HTMLDivElement;
  
  // Discount Display Elements
  const priceInput = document.getElementById('price') as HTMLInputElement;
  const originalPriceInput = document.getElementById('originalPrice') as HTMLInputElement;
  const discountDisplay = document.getElementById('discount-display') as HTMLDivElement;
  const discountValue = document.getElementById('discount-value') as HTMLSpanElement;

  // Real-time description preview update
  const updateDescriptionPreview = () => {
    const text = descriptionField.value.trim();
    if (text) {
      descriptionPreview.innerHTML = parseDescription(text);
    } else {
      descriptionPreview.innerHTML = '<p class="text-muted-foreground italic">Description preview will appear here...</p>';
    }
  };

  // Real-time discount calculation update
  const updateDiscountDisplay = () => {
    const price = parseFloat(priceInput.value || '0');
    const originalPrice = parseFloat(originalPriceInput.value || '0');
    
    if (originalPrice > 0 && originalPrice > price) {
      const discount = Math.round((1 - price / originalPrice) * 100);
      discountValue.textContent = discount.toString();
      discountDisplay.classList.remove('hidden');
    } else {
      discountDisplay.classList.add('hidden');
    }
  };

  // Attach event listeners
  descriptionField?.addEventListener('input', updateDescriptionPreview);
  priceInput?.addEventListener('input', updateDiscountDisplay);
  originalPriceInput?.addEventListener('input', updateDiscountDisplay);
  
  // Initialize preview on page load
  updateDescriptionPreview();
  updateDiscountDisplay();

  const renderMediaGrid = () => {
    mediaGrid.innerHTML = '';
    mediaFiles.forEach((file, index) => {
      const item = document.createElement('div');
      item.className = 'relative group aspect-square rounded-lg overflow-hidden border bg-muted';
      
      // Status indicator
      let statusBadge = '';
      if (file.status === 'uploading') {
        statusBadge = '<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-blue-500 text-white rounded animate-pulse">Uploading...</span>';
      } else if (file.status === 'failed') {
        statusBadge = `<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-red-500 text-white rounded cursor-pointer hover:bg-red-600 retry-item" data-index="${index}">Retry</span>`;
      } else if (file.status === 'completed') {
        statusBadge = '<span class="absolute top-2 left-2 px-2 py-0.5 text-xs font-medium bg-green-500 text-white rounded">Uploaded</span>';
      }
      
      if (file.type === 'video') {
        item.innerHTML = `
          <div class="relative w-full h-full">
            <img src="${file.thumbnail || file.data}" class="w-full h-full object-cover" />
            <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
              <i class="bi bi-play-circle-fill text-3xl text-white"></i>
            </div>
            <span class="absolute bottom-2 right-2 px-1.5 py-0.5 text-[10px] font-bold bg-black/60 text-white rounded">
              VIDEO
            </span>
            ${statusBadge}
          </div>
          <button type="button" class="remove-btn absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-background/90 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background">
            <i class="bi bi-x-lg text-sm"></i>
          </button>
        `;
      } else {
        item.innerHTML = `
          <img src="${file.data}" class="w-full h-full object-cover" />
          ${file.isPrimary ? '<span class="absolute bottom-2 left-2 px-2 py-0.5 text-xs font-medium bg-primary text-primary-foreground rounded">Main</span>' : ''}
          ${statusBadge}
          <button type="button" class="remove-btn absolute top-2 right-2 w-7 h-7 flex items-center justify-center rounded-full bg-background/90 text-red-500 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-background">
            <i class="bi bi-x-lg text-sm"></i>
          </button>
        `;
      }
      item.querySelector('.remove-btn').onclick = () => {
        mediaFiles.splice(index, 1);
        if (file.isPrimary && mediaFiles.length > 0) mediaFiles[0].isPrimary = true;
        saveToCache(mediaFiles);
        renderMediaGrid();
      };
      
      // Retry failed upload
      const retryBtn = item.querySelector('.retry-item');
      if (retryBtn) {
        retryBtn.onclick = async (e) => {
          e.stopPropagation();
          await retryUpload(index);
        };
      }
      
      mediaGrid.appendChild(item);
    });
  };

  const initMedia = () => {
    const images = JSON.parse(imagesInput.value || '[]');
    mediaFiles = images.map((url, i) => ({ 
      type: 'image', 
      data: url, 
      isPrimary: i === 0,
      status: 'completed',
      createdAt: Date.now()
    }));
    
    // Check for video
    const videoUrl = (document.getElementById('video-url-hidden') as HTMLInputElement)?.value;
    const videoThumb = (document.getElementById('video-thumb-hidden') as HTMLInputElement)?.value;
    
    if (videoUrl) {
      mediaFiles.push({
        type: 'video',
        data: videoUrl,
        thumbnail: videoThumb,
        isPrimary: false,
        status: 'completed',
        createdAt: Date.now()
      });
    }
    
    // Check for pending uploads from cache
    if (hasPendingUploads()) {
      const pendingAlert = document.getElementById('pending-uploads-alert');
      pendingAlert?.classList.remove('hidden');
      
      const cachedFiles = loadFromCache();
      if (cachedFiles.length > 0) {
        // Merge cached files with existing
        mediaFiles = [...mediaFiles, ...cachedFiles];
      }
    }
    
    renderMediaGrid();
  };

  uploadArea.onclick = () => fileInput.click();
  fileInput.onchange = async () => {
    if (!fileInput.files) return;
    loadingState.classList.remove('hidden');
    
    for (const file of Array.from(fileInput.files)) {
      if (file.type.startsWith('image/')) {
        const compressed = await compressImage(file, { quality: 0.8 });
        mediaFiles.push({
          type: 'image',
          data: compressed,
          file: file,
          isPrimary: mediaFiles.length === 0,
          status: 'pending',
          createdAt: Date.now()
        });
      } else if (file.type.startsWith('video/')) {
        const videoData = await compressVideo(file);
        mediaFiles.push({
          type: 'video',
          thumbnail: videoData.thumbnail,
          duration: videoData.duration,
          file: file,
          isPrimary: false,
          status: 'pending',
          createdAt: Date.now()
        });
      }
    }
    
    // Save to cache
    saveToCache(mediaFiles);
    
    loadingState.classList.add('hidden');
    renderMediaGrid();
  };

  isActiveToggle?.addEventListener('click', () => {
    const isActive = isActiveToggle.dataset.currentStatus === 'active';
    isActiveToggle.dataset.currentStatus = isActive ? 'inactive' : 'active';
    isActiveToggle.classList.toggle('bg-primary', !isActive);
    isActiveToggle.classList.toggle('bg-muted', isActive);
    isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-6', !isActive);
    isActiveToggle.querySelector('.toggle-indicator')?.classList.toggle('translate-x-1', isActive);
  });

  // Retry upload for a single file
  async function retryUpload(index: number) {
    const file = mediaFiles[index];
    if (!file || file.status === 'uploading' || !file.file) return;
    
    const uploadProgress = document.getElementById('upload-progress');
    const uploadProgressText = document.getElementById('upload-progress-text');
    const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLDivElement;
    
    uploadProgress?.classList.remove('hidden');
    uploadProgressText!.textContent = `Retrying ${file.type}...`;
    uploadProgressBar!.style.width = '50%';
    
    try {
      file.status = 'uploading';
      renderMediaGrid();
      
      const uploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), file.file);
      const url = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, uploaded.$id).toString();
      
      let thumbnailUrl = '';
      if (file.type === 'video' && file.thumbnail) {
        const thumbBlob = await fetch(file.thumbnail).then(r => r.blob());
        const thumbFile = new File([thumbBlob], `thumb_${uploaded.$id}.jpg`, { type: 'image/jpeg' });
        const thumbUploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), thumbFile);
        thumbnailUrl = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, thumbUploaded.$id).toString();
      }
      
      file.status = 'completed';
      file.uploadedUrl = url;
      file.data = url;
      if (thumbnailUrl) file.thumbnail = thumbnailUrl;
      
      uploadProgressBar!.style.width = '100%';
      saveToCache(mediaFiles);
      renderMediaGrid();
      
      setTimeout(() => {
        uploadProgress?.classList.add('hidden');
        uploadProgressBar!.style.width = '0%';
      }, 1000);
    } catch (error) {
      console.error('Retry failed:', error);
      file.status = 'failed';
      file.error = error instanceof Error ? error.message : 'Upload failed';
      uploadProgressBar!.style.width = '0%';
      uploadProgress?.classList.add('hidden');
      renderMediaGrid();
      alert('Failed to retry upload: ' + (error instanceof Error ? error.message : 'Unknown error'));
    }
  }

  // Resume all pending uploads
  async function resumePendingUploads() {
    const pendingFiles = mediaFiles.filter(f => f.status === 'pending' || f.status === 'failed');
    if (pendingFiles.length === 0) return;
    
    const uploadProgress = document.getElementById('upload-progress');
    const uploadProgressText = document.getElementById('upload-progress-text');
    const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLDivElement;
    const pendingAlert = document.getElementById('pending-uploads-alert');
    
    uploadProgress?.classList.remove('hidden');
    pendingAlert?.classList.add('hidden');
    
    for (let i = 0; i < mediaFiles.length; i++) {
      const file = mediaFiles[i];
      
      if (file.status === 'pending' || file.status === 'failed') {
        if (!file.file) continue;
        
        uploadProgressText!.textContent = `Uploading ${file.type} ${i + 1}/${mediaFiles.length}...`;
        uploadProgressBar!.style.width = `${((i + 1) / mediaFiles.length) * 100}%`;
        
        try {
          file.status = 'uploading';
          renderMediaGrid();
          
          const uploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), file.file);
          const url = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, uploaded.$id).toString();
          
          file.status = 'completed';
          file.uploadedUrl = url;
          file.data = url;
          
          if (file.type === 'video' && file.thumbnail) {
            const thumbBlob = await fetch(file.thumbnail).then(r => r.blob());
            const thumbFile = new File([thumbBlob], `thumb_${uploaded.$id}.jpg`, { type: 'image/jpeg' });
            const thumbUploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), thumbFile);
            file.thumbnail = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, thumbUploaded.$id).toString();
          }
          
          saveToCache(mediaFiles);
          renderMediaGrid();
        } catch (error) {
          console.error('Upload failed:', error);
          file.status = 'failed';
          file.error = error instanceof Error ? error.message : 'Upload failed';
          saveToCache(mediaFiles);
          renderMediaGrid();
        }
      }
    }
    
    uploadProgressBar!.style.width = '100%';
    setTimeout(() => {
      uploadProgress?.classList.add('hidden');
      uploadProgressBar!.style.width = '0%';
    }, 1000);
    
    const failedCount = mediaFiles.filter(f => f.status === 'failed').length;
    if (failedCount > 0) {
      alert(`${failedCount} file(s) failed to upload. Click Retry to try again.`);
    }
  }

  // Setup retry button listener
  document.getElementById('retry-upload-btn')?.addEventListener('click', resumePendingUploads);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Updating...';

    const uploadProgress = document.getElementById('upload-progress');
    const uploadProgressText = document.getElementById('upload-progress-text');
    const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLDivElement;

    try {
      const imageUrls: string[] = [];
      let videoUrl = (document.getElementById('video-url-hidden') as HTMLInputElement)?.value || '';
      let videoThumbnailUrl = (document.getElementById('video-thumb-hidden') as HTMLInputElement)?.value || '';

      // Upload pending media files sequentially
      const pendingFiles = mediaFiles.filter(f => (f.status === 'pending' || f.status === 'failed') && f.file);
      
      if (pendingFiles.length > 0) {
        uploadProgress?.classList.remove('hidden');
        
        for (let i = 0; i < mediaFiles.length; i++) {
          const media = mediaFiles[i];
          
          if (media.status === 'pending' || media.status === 'failed') {
            if (!media.file) continue;
            
            uploadProgressText!.textContent = `Uploading ${media.type} ${i + 1}/${mediaFiles.length}...`;
            uploadProgressBar!.style.width = `${((i + 1) / mediaFiles.length) * 100}%`;
            
            try {
              media.status = 'uploading';
              renderMediaGrid();
              
              const uploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), media.file);
              const url = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, uploaded.$id).toString();
              
              media.status = 'completed';
              media.uploadedUrl = url;
              
              if (media.type === 'image') {
                imageUrls.push(url);
              } else if (media.type === 'video') {
                videoUrl = url;
                
                // Upload thumbnail
                const thumbBlob = await fetch(media.thumbnail!).then(r => r.blob());
                const thumbFile = new File([thumbBlob], `thumb_${uploaded.$id}.jpg`, { type: 'image/jpeg' });
                const thumbUploaded = await storage.createFile(APPWRITE_IMAGES_BUCKET_ID, ID.unique(), thumbFile);
                videoThumbnailUrl = storage.getFileView(APPWRITE_IMAGES_BUCKET_ID, thumbUploaded.$id).toString();
              }
            } catch (uploadError) {
              console.error('Upload failed for:', media, uploadError);
              media.status = 'failed';
              media.error = uploadError instanceof Error ? uploadError.message : 'Upload failed';
            }
          } else if (media.status === 'completed') {
            // Already uploaded or existing
            if (media.type === 'image') {
              imageUrls.push(media.data || media.url || media.uploadedUrl || '');
            } else if (media.type === 'video') {
              videoUrl = media.data || media.url || media.uploadedUrl || '';
              videoThumbnailUrl = media.thumbnail || '';
            }
          } else {
            // No file, use data URL (existing media)
            if (media.type === 'image') {
              imageUrls.push(media.data || media.url || '');
            } else if (media.type === 'video') {
              videoUrl = media.data || media.url || '';
              videoThumbnailUrl = media.thumbnail || '';
            }
          }
        }
        
        uploadProgressBar!.style.width = '100%';
        setTimeout(() => uploadProgress?.classList.add('hidden'), 500);
      } else {
        // No pending files, use existing URLs
        for (const media of mediaFiles) {
          if (media.type === 'image') {
            imageUrls.push(media.data || media.url || '');
          } else if (media.type === 'video') {
            videoUrl = media.data || media.url || '';
            videoThumbnailUrl = media.thumbnail || '';
          }
        }
      }

      const formData = new FormData(form);
      const adminUser = (window as any).adminUser;
      const updateData = {
        name: formData.get('name'),
        description: formData.get('description'),
        category: formData.get('category'),
        brand: formData.get('brand'),
        price: parseFloat(formData.get('price') as string),
        originalPrice: parseFloat(formData.get('originalPrice') as string) || null,
        stock: parseInt(formData.get('stock') as string) || 0,
        image: imageUrls[0] || '',
        images: imageUrls,
        video: videoUrl,
        videoThumbnail: videoThumbnailUrl,
        featured: formData.has('featured'),
        isActive: isActiveToggle?.dataset.currentStatus === 'active',
        updatedBy: adminUser?.id || 'unknown',
        updatedByName: adminUser?.name || adminUser?.email || 'Unknown Admin'
      };

      await databases.updateDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, productId, updateData);
      
      // Clear cache on successful submission
      clearCache();
      
      window.location.href = '/admin/products';
    } catch (error) {
      console.error('Update failed:', error);
      alert('Update failed: ' + (error instanceof Error ? error.message : 'Unknown error'));
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Update Product';
    }
  });

  initMedia();
</script>
