---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { formatPrice } from '../../lib/utils';
---

<AdminLayout title="Orders - ABKHD Admin">
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">Orders</h1>
        <p class="text-muted-foreground mt-1">Manage customer orders</p>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
      <p class="mt-4 text-muted-foreground">Loading orders...</p>
    </div>

    <!-- Orders Stats -->
    <div id="stats-section" class="hidden grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-xl border bg-card p-5 transition-all hover:shadow-md">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-medium text-muted-foreground">Total Revenue</p>
            <p id="total-revenue" class="text-3xl font-bold mt-2">₦0</p>
            <p class="text-xs text-muted-foreground mt-1">From all orders</p>
          </div>
          <div class="p-3 rounded-lg bg-green-500/10">
            <i class="bi bi-currency-naira text-xl text-green-500"></i>
          </div>
        </div>
      </div>

      <div class="rounded-xl border bg-card p-5 transition-all hover:shadow-md">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-medium text-muted-foreground">Completed Orders</p>
            <p id="completed-orders" class="text-3xl font-bold mt-2">0</p>
            <p class="text-xs text-muted-foreground mt-1">Total orders</p>
          </div>
          <div class="p-3 rounded-lg bg-blue-500/10">
            <i class="bi bi-bag-check text-xl text-blue-500"></i>
          </div>
        </div>
      </div>

      <div class="rounded-xl border bg-card p-5 transition-all hover:shadow-md">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-medium text-muted-foreground">Average Order Value</p>
            <p id="avg-value" class="text-3xl font-bold mt-2">₦0</p>
            <p class="text-xs text-muted-foreground mt-1">Per order</p>
          </div>
          <div class="p-3 rounded-lg bg-yellow-500/10">
            <i class="bi bi-graph-up text-xl text-yellow-500"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Orders List -->
    <div id="orders-section" class="hidden rounded-xl border bg-card overflow-hidden">
      <div class="p-4 sm:p-6 border-b">
        <h2 class="text-lg font-semibold">All Completed Orders</h2>
        <p class="text-sm text-muted-foreground">Click on an order to view details</p>
      </div>
      
      <div id="orders-container"></div>
    </div>

    <!-- Order Details Slide-in Panel -->
    <div id="order-details-panel" class="fixed inset-y-0 right-0 w-full max-w-2xl bg-card shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
      <div class="sticky top-0 bg-card border-b p-6 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold">Order Details</h2>
          <p class="text-sm text-muted-foreground" id="detail-order-ref"></p>
        </div>
        <button id="close-details" class="p-2 hover:bg-muted rounded-lg transition-colors">
          <i class="bi bi-x text-2xl"></i>
        </button>
      </div>
      
      <div id="order-details-content" class="p-6 space-y-6">
        <!-- Content will be populated dynamically -->
      </div>
    </div>

    <!-- Overlay for slide-in panel -->
    <div id="details-overlay" class="fixed inset-0 bg-black/50 z-40 hidden"></div>

    <!-- Error State -->
    <div id="error-state" class="hidden p-12 text-center rounded-xl border bg-card">
      <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="bi bi-exclamation-triangle text-3xl text-red-500"></i>
      </div>
      <h3 class="text-lg font-semibold mb-2">Failed to load orders</h3>
      <p class="text-muted-foreground mb-4" id="error-message"></p>
      <button onclick="location.reload()" class="btn-primary px-6 py-2">
        Retry
      </button>
    </div>
  </div>
</AdminLayout>

<script>
  import { databases, APPWRITE_DB_ID, APPWRITE_ORDERS_COLLECTION_ID } from '../../lib/appwrite';
  import { Query } from 'appwrite';

  function formatPrice(price: number): string {
    return '₦' + price.toLocaleString();
  }

  function showOrderDetails(order: any) {
    const panel = document.getElementById('order-details-panel');
    const overlay = document.getElementById('details-overlay');
    const content = document.getElementById('order-details-content');
    const orderRef = document.getElementById('detail-order-ref');

    if (!panel || !overlay || !content || !orderRef) return;

    // Parse items
    let items = [];
    try {
      items = JSON.parse(order.items || '[]');
    } catch (e) {
      console.error('Failed to parse items:', e);
    }

    // Set order reference
    orderRef.textContent = `Reference: ${order.paymentRef || order.paymentReference || 'N/A'}`;

    // Populate content
    content.innerHTML = `
      <!-- Customer Information -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold flex items-center gap-2">
          <i class="bi bi-person-circle text-primary"></i>
          Customer Information
        </h3>
        <div class="grid grid-cols-2 gap-4 p-4 rounded-lg bg-muted/30">
          <div>
            <p class="text-xs text-muted-foreground">Name</p>
            <p class="font-medium">${order.customerName || 'N/A'}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Email</p>
            <p class="font-medium">${order.customerEmail || 'N/A'}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Phone</p>
            <p class="font-medium">${order.customerPhone || 'N/A'}</p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground">Order Date</p>
            <p class="font-medium">${new Date(order.$createdAt).toLocaleString()}</p>
          </div>
        </div>
      </div>

      <!-- Shipping Address -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold flex items-center gap-2">
          <i class="bi bi-geo-alt text-primary"></i>
          Shipping Address
        </h3>
        <div class="p-4 rounded-lg bg-muted/30">
          <p class="font-medium">${order.address || 'N/A'}</p>
          <p class="text-sm text-muted-foreground">
            ${order.city || 'N/A'}, ${order.state || 'N/A'} ${order.postalCode || ''}
          </p>
        </div>
      </div>

      <!-- Order Items -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold flex items-center gap-2">
          <i class="bi bi-bag text-primary"></i>
          Order Items (${items.length})
        </h3>
        <div class="space-y-3">
          ${items.map((item: any) => `
            <div class="flex items-center gap-4 p-4 rounded-lg border bg-background">
              <img 
                src="${item.image || '/placeholder.png'}" 
                alt="${item.name}"
                class="w-16 h-16 object-cover rounded-lg"
                crossorigin="anonymous"
              />
              <div class="flex-1">
                <p class="font-medium">${item.name}</p>
                <p class="text-sm text-muted-foreground">Qty: ${item.quantity}</p>
                <p class="text-sm font-semibold text-primary">${formatPrice(item.price)} each</p>
              </div>
              <div class="text-right">
                <p class="font-bold">${formatPrice(item.price * item.quantity)}</p>
              </div>
            </div>
          `).join('')}
        </div>
      </div>

      <!-- Payment Information -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold flex items-center gap-2">
          <i class="bi bi-credit-card text-primary"></i>
          Payment Information
        </h3>
        <div class="p-4 rounded-lg bg-muted/30 space-y-3">
          <div class="flex justify-between">
            <span class="text-muted-foreground">Payment Method</span>
            <span class="font-medium capitalize">${order.paymentMethod || 'N/A'}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Transaction Reference</span>
            <span class="font-mono text-sm">${order.paymentRef || order.paymentReference || 'N/A'}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-muted-foreground">Status</span>
            <span class="px-2 py-1 rounded-full text-xs uppercase font-bold ${
              order.status === 'paid' ? 'bg-green-500/10 text-green-500' : 'bg-yellow-500/10 text-yellow-500'
            }">
              ${order.status || 'pending'}
            </span>
          </div>
          <div class="border-t pt-3 flex justify-between items-center">
            <span class="text-lg font-semibold">Total Amount</span>
            <span class="text-2xl font-bold text-primary">${formatPrice(order.totalAmount || order.total || 0)}</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3">
        <button 
          onclick="window.print()" 
          class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg border border-border hover:bg-muted transition-colors"
        >
          <i class="bi bi-printer"></i>
          Print Order
        </button>
        <button 
          onclick="navigator.clipboard.writeText('${order.paymentRef || order.paymentReference || ''}')" 
          class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg border border-border hover:bg-muted transition-colors"
        >
          <i class="bi bi-clipboard"></i>
          Copy Reference
        </button>
      </div>
    `;

    // Show panel and overlay
    overlay.classList.remove('hidden');
    setTimeout(() => {
      panel.classList.remove('translate-x-full');
    }, 10);
  }

  function hideOrderDetails() {
    const panel = document.getElementById('order-details-panel');
    const overlay = document.getElementById('details-overlay');

    if (panel && overlay) {
      panel.classList.add('translate-x-full');
      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300);
    }
  }

  async function loadOrders() {
    const loadingState = document.getElementById('loading-state');
    const statsSection = document.getElementById('stats-section');
    const ordersSection = document.getElementById('orders-section');
    const errorState = document.getElementById('error-state');
    const ordersContainer = document.getElementById('orders-container');

    try {
      console.log('Fetching orders...');
      const response = await databases.listDocuments(
        APPWRITE_DB_ID,
        APPWRITE_ORDERS_COLLECTION_ID,
        [
          Query.orderDesc('$createdAt'),
          Query.limit(100)
        ]
      );

      const orders = response.documents;
      console.log('Orders fetched:', orders.length);

      // Hide loading
      loadingState?.classList.add('hidden');

      if (orders.length === 0) {
        // Show empty state
        if (ordersContainer) {
          ordersContainer.innerHTML = `
            <div class="p-12 text-center">
              <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-bag-x text-3xl text-muted-foreground"></i>
              </div>
              <h3 class="text-lg font-semibold mb-2">No orders yet</h3>
              <p class="text-muted-foreground">Completed orders will appear here</p>
            </div>
          `;
        }
        ordersSection?.classList.remove('hidden');
        return;
      }

      // Calculate stats
      const totalRevenue = orders.reduce((sum, o: any) => sum + (o.totalAmount || o.total || 0), 0);
      const avgValue = totalRevenue / orders.length;

      // Update stats
      const totalRevenueEl = document.getElementById('total-revenue');
      const completedOrdersEl = document.getElementById('completed-orders');
      const avgValueEl = document.getElementById('avg-value');
      
      if (totalRevenueEl) totalRevenueEl.textContent = formatPrice(totalRevenue);
      if (completedOrdersEl) completedOrdersEl.textContent = orders.length.toString();
      if (avgValueEl) avgValueEl.textContent = formatPrice(avgValue);

      // Render orders table
      if (ordersContainer) {
        ordersContainer.innerHTML = `
          <!-- Mobile Card View -->
          <div class="divide-y">
            ${orders.map((order: any, index: number) => `
              <div 
                class="p-4 hover:bg-muted/30 transition-colors cursor-pointer order-row" 
                data-order-index="${index}"
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-sm truncate">${order.customerName || 'N/A'}</div>
                    <div class="text-xs text-muted-foreground truncate">${order.customerEmail || 'N/A'}</div>
                    <div class="text-xs text-muted-foreground mt-1">${new Date(order.$createdAt).toLocaleDateString()}</div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="font-semibold text-sm">${formatPrice(order.totalAmount || order.total || 0)}</div>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] uppercase font-bold ${
                      order.status === 'paid' ? 'bg-green-500/10 text-green-500' : 'bg-yellow-500/10 text-yellow-500'
                    }">
                      ${order.status || 'pending'}
                    </span>
                  </div>
                </div>
                <div class="text-[10px] text-muted-foreground font-mono mt-2 truncate">
                  Ref: ${order.paymentRef || order.paymentReference || 'N/A'}
                </div>
              </div>
            `).join('')}
          </div>
        `;

        // Add click handlers to order rows
        document.querySelectorAll('.order-row').forEach((row) => {
          row.addEventListener('click', () => {
            const index = parseInt((row as HTMLElement).dataset.orderIndex || '0');
            showOrderDetails(orders[index]);
          });
        });
      }

      // Show sections
      statsSection?.classList.remove('hidden');
      ordersSection?.classList.remove('hidden');

    } catch (error) {
      console.error('Error loading orders:', error);
      loadingState?.classList.add('hidden');
      errorState?.classList.remove('hidden');
      
      const errorMessage = document.getElementById('error-message');
      if (errorMessage) {
        errorMessage.textContent = error instanceof Error ? error.message : 'Unknown error occurred';
      }
    }
  }

  // Load orders on page load
  loadOrders();

  // Setup close button and overlay
  const setupCloseHandlers = () => {
    const closeBtn = document.getElementById('close-details');
    const overlay = document.getElementById('details-overlay');
    
    if (closeBtn) {
      closeBtn.onclick = hideOrderDetails;
    }
    
    if (overlay) {
      overlay.onclick = hideOrderDetails;
    }
  };

  // Close on Escape key
  const handleEscape = (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      hideOrderDetails();
    }
  };

  document.addEventListener('keydown', handleEscape);

  // Initial setup
  setupCloseHandlers();

  // Reload after view transitions
  document.addEventListener('astro:after-swap', () => {
    loadOrders();
    setupCloseHandlers();
  });
</script>
