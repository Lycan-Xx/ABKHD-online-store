---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ProductGrid from '../components/ui/ProductGrid.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../lib/appwrite';
import { Query } from 'appwrite';

let featuredProducts = [];
try {
  const response = await databases.listDocuments(
    APPWRITE_DB_ID,
    APPWRITE_PRODUCTS_COLLECTION_ID,
    [
      Query.equal('featured', true),
      Query.equal('isActive', true),
      Query.equal('isArchived', false),
      Query.limit(8)
    ]
  );
  featuredProducts = response.documents.map(doc => ({ ...doc, id: doc.$id }));
} catch (error) {
  console.error('Error fetching featured products:', error);
}
---

<Layout title="Featured – ABKHD Store" description="Hand-picked, tested tech at smarter prices. Browse this week's featured devices.">
  <Header slot="header" />

  <!-- ═══════════════════════════════════════════════
       HERO — Full-bleed gradient, bold CTA
  ═══════════════════════════════════════════════ -->
  <section class="hero-section relative overflow-hidden">
    <!-- Background gradient blobs -->
    <div class="blob blob-1" aria-hidden="true"></div>
    <div class="blob blob-2" aria-hidden="true"></div>
    <div class="blob blob-3" aria-hidden="true"></div>

    <div class="container relative z-10 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Eyebrow pill -->
        <div class="eyebrow-pill">
          <i class="bi bi-stars text-primary text-sm"></i>
          <span>This Week's Featured Drop</span>
        </div>

        <h1 class="hero-headline">
          Premium Tech.<br />
          <span class="text-primary">Smarter Prices.</span>
        </h1>

        <p class="hero-sub">
          UK &amp; China-sourced devices, rigorously tested and transparently
          disclosed&mdash;quality you can trust at prices that actually make sense.
        </p>

        <div class="hero-actions">
          <a href="/shop" class="btn-hero-primary">
            <i class="bi bi-bag text-lg"></i>
            Browse the Store
          </a>
          <a href="/about" class="btn-hero-ghost">
            How we certify
            <i class="bi bi-arrow-right"></i>
          </a>
        </div>

        <!-- Social proof strip -->
        <div class="trust-strip">
          <span class="trust-item"><i class="bi bi-shield-check text-primary"></i> Tested devices</span>
          <span class="trust-dot" aria-hidden="true">·</span>
          <span class="trust-item"><i class="bi bi-eye text-primary"></i> Defects disclosed</span>
          <span class="trust-dot" aria-hidden="true">·</span>
          <span class="trust-item"><i class="bi bi-patch-check text-primary"></i> Real warranty</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURED PRODUCTS
  ═══════════════════════════════════════════════ -->
  <section class="container py-14 md:py-20">
    <!-- Section heading -->
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Hand-picked &amp; ready to ship</p>
        <h2 class="section-title">Featured Products</h2>
      </div>
      <a href="/shop" class="see-all-link">
        See all <i class="bi bi-arrow-right"></i>
      </a>
    </div>

    {featuredProducts.length > 0
      ? <ProductGrid products={featuredProducts} />
      : (
        <div class="empty-state">
          <i class="bi bi-stars text-4xl text-muted-foreground block mb-3"></i>
          <p class="font-semibold text-lg mb-1">Featured picks coming soon</p>
          <p class="text-sm text-muted-foreground mb-5">Check back shortly — we update weekly!</p>
          <a href="/shop" class="btn-hero-primary text-sm px-6 py-2.5">Browse all products</a>
        </div>
      )
    }
  </section>

  <!-- ═══════════════════════════════════════════════
       TRUST PILLARS
  ═══════════════════════════════════════════════ -->
  <section class="trust-section">
    <div class="container py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="trust-card">
          <div class="trust-icon"><i class="bi bi-shield-check text-primary text-2xl"></i></div>
          <h3 class="trust-name">Rigorously Tested</h3>
          <p class="trust-desc">Every device passes a multi-point inspection before it leaves us.</p>
        </div>
        <div class="trust-card">
          <div class="trust-icon"><i class="bi bi-eye text-primary text-2xl"></i></div>
          <h3 class="trust-name">Fully Transparent</h3>
          <p class="trust-desc">All defects disclosed upfront with photos and detailed condition notes.</p>
        </div>
        <div class="trust-card">
          <div class="trust-icon"><i class="bi bi-patch-check text-primary text-2xl"></i></div>
          <h3 class="trust-name">Real Warranties</h3>
          <p class="trust-desc">Enforceable guarantees backed by responsive, honest support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════════════ -->
  <section class="container pb-20">
    <div class="cta-banner">
      <div class="cta-blob" aria-hidden="true"></div>
      <div class="relative z-10 text-center">
        <h2 class="text-2xl md:text-3xl font-black mb-3">Ready to Upgrade?</h2>
        <p class="text-muted-foreground mb-7 max-w-sm mx-auto">
          Browse the full inventory — laptops, phones, accessories, all tested &amp; ready.
        </p>
        <a href="/shop" class="btn-hero-primary">
          <i class="bi bi-bag text-base"></i>
          View All Products
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style is:global>
  /* ── Hero ── */
  .hero-section {
    background: hsl(var(--background));
    border-bottom: 1px solid hsl(var(--border));
  }

  /* Gradient blobs */
  .blob { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(70px); opacity: 0.35; }
  .blob-1 { width: 500px; height: 500px; background: hsl(var(--primary) / 0.25); top: -120px; left: -180px; animation: blob-drift 14s ease-in-out infinite alternate; }
  .blob-2 { width: 400px; height: 400px; background: hsl(173 80% 55% / 0.18); top: 60px; right: -140px; animation: blob-drift 18s ease-in-out infinite alternate-reverse; }
  .blob-3 { width: 300px; height: 300px; background: hsl(var(--primary) / 0.12); bottom: -60px; left: 40%; animation: blob-drift 22s ease-in-out infinite alternate; }
  @keyframes blob-drift {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(30px, 20px) scale(1.05); }
  }

  .eyebrow-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 16px; border-radius: 999px;
    background: hsl(var(--primary) / 0.1);
    border: 1px solid hsl(var(--primary) / 0.28);
    font-size: 13px; font-weight: 600;
    color: hsl(var(--primary));
    margin-bottom: 20px;
  }

  .hero-headline {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 900; line-height: 1.1;
    letter-spacing: -0.02em;
    color: hsl(var(--foreground));
    margin-bottom: 18px;
  }

  .hero-sub {
    font-size: 1.05rem; line-height: 1.7;
    color: hsl(var(--muted-foreground));
    max-width: 560px; margin: 0 auto 28px;
  }

  .hero-actions {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; flex-wrap: wrap; margin-bottom: 28px;
  }

  .btn-hero-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 28px; border-radius: 10px;
    background: hsl(var(--primary)); color: hsl(var(--primary-foreground));
    font-weight: 700; font-size: 15px; text-decoration: none;
    box-shadow: 0 4px 18px hsl(var(--primary) / 0.38);
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .btn-hero-primary:hover { background: hsl(var(--primary)/0.88); transform: translateY(-2px); box-shadow: 0 8px 28px hsl(var(--primary)/0.45); }

  .btn-hero-ghost {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 13px 22px; border-radius: 10px;
    border: 1.5px solid hsl(var(--border));
    background: transparent; color: hsl(var(--foreground));
    font-weight: 600; font-size: 15px; text-decoration: none;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  .btn-hero-ghost:hover { border-color: hsl(var(--primary)/0.5); background: hsl(var(--accent)); transform: translateY(-2px); }

  .trust-strip {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap; gap: 10px 4px;
    font-size: 12px; color: hsl(var(--muted-foreground));
  }
  .trust-item { display: inline-flex; align-items: center; gap: 5px; }
  .trust-dot  { opacity: 0.4; }

  /* ── Section header ── */
  .section-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 28px; gap: 12px; flex-wrap: wrap;
  }
  .section-eyebrow { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: hsl(var(--primary)/0.7); margin-bottom: 4px; }
  .section-title   { font-size: 1.8rem; font-weight: 900; letter-spacing: -0.01em; color: hsl(var(--foreground)); }
  .see-all-link {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 13px; font-weight: 600; color: hsl(var(--primary));
    text-decoration: none; border-bottom: 1px solid hsl(var(--primary)/0.3);
    padding-bottom: 1px;
    transition: border-color 0.15s, opacity 0.15s;
    white-space: nowrap;
  }
  .see-all-link:hover { opacity: 0.75; border-color: hsl(var(--primary)); }

  /* ── Empty state ── */
  .empty-state {
    text-align: center; padding: 60px 20px;
    border: 1.5px dashed hsl(var(--border)); border-radius: 14px;
  }

  /* ── Trust section ── */
  .trust-section { background: hsl(var(--muted)/0.35); border-top: 1px solid hsl(var(--border)); border-bottom: 1px solid hsl(var(--border)); }
  .trust-card {
    padding: 28px 24px; border-radius: 12px;
    background: hsl(var(--card)); border: 1.5px solid hsl(var(--border));
    text-align: center;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .trust-card:hover { border-color: hsl(var(--primary)/0.4); box-shadow: 0 6px 20px hsl(var(--primary)/0.1); }
  .trust-icon { width: 52px; height: 52px; border-radius: 12px; background: hsl(var(--primary)/0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
  .trust-name { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
  .trust-desc { font-size: 13px; color: hsl(var(--muted-foreground)); line-height: 1.6; }

  /* ── CTA banner ── */
  .cta-banner {
    position: relative; overflow: hidden;
    padding: 56px 24px; border-radius: 16px;
    background: linear-gradient(135deg, hsl(var(--card)) 0%, hsl(var(--primary)/0.07) 100%);
    border: 1.5px solid hsl(var(--primary)/0.2);
  }
  .cta-blob {
    position: absolute; width: 400px; height: 400px;
    border-radius: 50%; pointer-events: none;
    background: hsl(var(--primary)/0.12); filter: blur(80px);
    top: -100px; right: -100px;
  }
</style>