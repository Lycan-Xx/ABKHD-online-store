---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductGrid from '../components/ProductGrid.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../lib/appwrite';
import { Query } from 'appwrite';

let featuredProducts = [];
try {
  const response = await databases.listDocuments(
    APPWRITE_DB_ID,
    APPWRITE_PRODUCTS_COLLECTION_ID,
    [
      Query.equal('featured', true),
      Query.equal('isActive', true),
      Query.equal('isArchived', false),
      Query.limit(6)
    ]
  );
  featuredProducts = response.documents.map(doc => ({
    ...doc,
    id: doc.$id
  }));
} catch (error) {
  console.error('Error fetching featured products:', error);
}
---

<Layout title="ABKHD | store">
  <Header slot="header" />
  
  <div class="space-y-20">
    <!-- Hero Section - Clean & Minimal
    <section class="container pt-16 md:pt-24">
      <div class="max-w-3xl mx-auto text-center space-y-6">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight">
          Premium Tech.
          <br />
          <span class="text-primary">Smarter Prices.</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed">
          UK and China-sourced devices, rigorously tested and transparently disclosed. 
          Quality you can trust at prices that make sense.
        </p>
      </div>
    </section> -->

    <!-- Featured Products - THE MAIN FOCUS -->
    <section class="container pt-16 md:pt-24">
      <div class="text-center mb-12">

        <h2 class="text-3xl md:text-4xl font-bold mb-3">Featured Products</h2>
                <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium mb-4">
          This Week Only
        </div>

        <p class="text-muted-foreground">
          Hand-picked, tested, and ready to ship
        </p>
      </div>
      
      <ProductGrid products={featuredProducts} />
    </section>

    <section class="container pb-16">
      <div class="max-w-2xl mx-auto text-center p-10 rounded-xl border border-border bg-card/50">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">
          Ready to Upgrade?
        </h2>
        <p class="text-muted-foreground mb-6">
          Browse our full inventory of tested devices
        </p>
        <a href="/shop" class="btn-primary px-8 py-3">
          View our products 
        </a>
      </div>
    </section>

    <!-- Trust Pillars - Concise -->
    <section class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <i class="bi bi-shield-check text-primary text-2xl"></i>
          </div>
          <h3 class="font-semibold mb-2">Rigorously Tested</h3>
          <p class="text-sm text-muted-foreground">
            Every device passes multi-point inspection before sale
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <i class="bi bi-eye text-primary text-2xl"></i>
          </div>
          <h3 class="font-semibold mb-2">Fully Transparent</h3>
          <p class="text-sm text-muted-foreground">
            All defects disclosed upfront with photos and details
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <i class="bi bi-patch-check text-primary text-2xl"></i>
          </div>
          <h3 class="font-semibold mb-2">Real Warranties</h3>
          <p class="text-sm text-muted-foreground">
            Enforceable guarantees with responsive support
          </p>
        </div>
      </div>
    </section>

    <!-- How We Certify - Simple Visual -->
    <section class="container">
      <div class="text-center mb-8">
        <a href="/about" class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors">
          Learn more about our process
          <i class="bi bi-arrow-right ml-2"></i>
        </a>
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</Layout>