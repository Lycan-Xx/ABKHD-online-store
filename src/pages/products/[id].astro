---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { databases, APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID } from '../../lib/appwrite';
import { Query } from 'appwrite';
import { formatPrice, parseDescription, calculateDiscount } from '../../lib/utils';

export const prerender = false;

// For SSR: fetch product directly instead of using getStaticPaths
const { id } = Astro.params;

let product = null;
let relatedProducts = [];

try {
  product = await databases.getDocument(APPWRITE_DB_ID, APPWRITE_PRODUCTS_COLLECTION_ID, id);
  
  // Get related products (same category, excluding current product)
  const relatedResponse = await databases.listDocuments(
    APPWRITE_DB_ID,
    APPWRITE_PRODUCTS_COLLECTION_ID,
    [
      Query.equal('category', product.category),
      Query.notEqual('$id', product.$id),
      Query.equal('isActive', true),
      Query.equal('isArchived', false),
      Query.limit(4)
    ]
  );
  relatedProducts = relatedResponse.documents.map(p => ({
    ...p,
    id: p.$id
  }));
} catch (error) {
  console.error('Error fetching product:', error);
  return Astro.redirect('/404');
}

// Category data matching ShopPage
const getCategoryData = (categoryName: string) => {
  const categories = [
    { name: 'Computers', icon: 'bi-laptop', value: 'computers' },
    { name: 'Mobile Phones', icon: 'bi-phone', value: 'mobile phones' },
    { name: 'Accessories', icon: 'bi-headphones', value: 'accessories' }
  ];
  return categories.find(cat => cat.value === categoryName) || categories[0];
};

const categoryData = getCategoryData(product.category);

// Calculate discount percentage
const discount = calculateDiscount(product.price, product.originalPrice || 0);

// Get the first image for OG tags
const ogImage = product.images?.[0] || product.image;
const ogDescription = product.description || `Buy ${product.name} for ₦${product.price.toLocaleString()}`;
---

<Layout 
  title={`${product.name} - ABKHD Store`} 
  description={ogDescription}
  ogImage={ogImage}
  ogType="product"
>
  <Header slot="header" />
  
  <div class="container py-4 md:py-8">
    <!-- Navigation -->
    <nav class="flex items-center space-x-2 text-xs md:text-sm text-muted-foreground mb-4 md:mb-8">
      <button id="back-btn" class="flex items-center hover:text-foreground">
        <i class="bi bi-arrow-left-short text-lg md:text-xl mr-1"></i>
        <span>Shop</span>
      </button>
      <i class="bi bi-chevron-right"></i>
      <span class="text-foreground truncate max-w-[150px] md:max-w-none">{product.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12">
      <!-- Product Images -->
      <div class="space-y-4">
        <div class="aspect-square overflow-hidden rounded-lg bg-muted relative">
          <img
            id="main-image"
            src={product.images?.[0] || product.image}
            alt={product.name}
            class="w-full h-full object-cover"
            crossorigin="anonymous"
          />
          {product.video && (
            <video
              id="main-video"
              src={product.video}
              class="hidden w-full h-full object-cover"
              controls
              playsinline
            />
          )}
        </div>
        {( (product.images && product.images.length > 1) || product.video ) && (
          <div class="flex space-x-2 overflow-x-auto pb-2">
            {product.images?.map((image, index) => (
              <button
                key={index}
                class="thumbnail-btn flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 border-transparent"
                data-type="image"
                data-url={image}
                data-index={index}
              >
                <img
                  src={image}
                  alt={`${product.name} ${index + 1}`}
                  class="w-full h-full object-cover"
                  crossorigin="anonymous"
                />
              </button>
            ))}
            {product.video && (
              <button
                class="thumbnail-btn flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 border-transparent relative"
                data-type="video"
                data-url={product.video}
              >
                <img
                  src={product.videoThumbnail || product.image}
                  alt={`${product.name} video`}
                  class="w-full h-full object-cover"
                  crossorigin="anonymous"
                />
                <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                  <i class="bi bi-play-circle-fill text-2xl text-white"></i>
                </div>
              </button>
            )}
          </div>
        )}
      </div>

      <!-- Product Info -->
      <div class="space-y-6">
        <div>
          <h1 class="text-lg md:text-3xl font-bold mb-2 text-foreground leading-tight">{product.name}</h1>
            <div class="flex items-center flex-wrap gap-2 md:gap-3 mb-4">
              <div class="flex items-center space-x-2">
                <span class="text-xl md:text-4xl font-extrabold text-primary">{formatPrice(product.price)}</span>
                {product.originalPrice && (
                  <>
                    <span class="text-base md:text-lg text-muted-foreground line-through">
                      {formatPrice(product.originalPrice)}
                    </span>
                    {discount && (
                      <span class="px-2 py-0.5 rounded-md bg-red-500/10 text-red-500 text-xs md:text-sm font-bold border border-red-500/20">
                        -{discount}% OFF
                      </span>
                    )}
                  </>
                )}
              </div>
              {product.verified && (
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-blue-500/10 text-blue-500 border border-blue-500/20">
                <i class="bi bi-patch-check-fill"></i>
                Verified
              </span>
            )}
          </div>

          <!-- Stock Status -->
          {product.stock !== undefined && product.stock !== null && (
            <div class="mb-3 md:mb-4">
              <span class={`inline-flex items-center gap-1.5 md:gap-2 px-2 md:px-3 py-1 md:py-1.5 rounded-lg text-xs md:text-sm font-semibold ${
                product.stock === 0 ? 'bg-red-500/10 text-red-500 border border-red-500/20' :
                product.stock <= 5 ? 'bg-yellow-500/10 text-yellow-500 border border-yellow-500/20' :
                'bg-green-500/10 text-green-500 border border-green-500/20'
              }`}>
                <i class={`bi ${product.stock === 0 ? 'bi-x-circle-fill' : 'bi-check-circle-fill'} text-xs md:text-sm`}></i>
                {product.stock === 0 ? 'Out of Stock' : 
                 product.isUnique ? 'Unique Item - Only 1 Available' :
                 `${product.stock} Available`}
              </span>
            </div>
          )}
          
          <!-- Product Description -->
          <div class="border-t pt-6">
            <h3 class="font-semibold mb-3">Description</h3>
            <div class="text-muted-foreground">
              {product.description ? (
                <div class="space-y-3" set:html={parseDescription(product.description)} />
              ) : (
                <p class="leading-relaxed">No description available</p>
              )}
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        {product.stock !== 0 ? (
          <div class="grid grid-cols-2 gap-3 md:gap-4">
            <button
              id="add-to-cart-btn"
              class="btn-secondary py-2.5 md:py-3 text-sm md:text-base border-2 border-muted-foreground/20 hover:border-muted-foreground/40 shadow-md hover:scale-105 transition-transform duration-200 focus:ring-2 focus:ring-muted-foreground/60"
              data-product-id={product.id}
            >
              Add to Cart
            </button>
            <button
              id="buy-now-btn"
              class="btn-primary py-2.5 md:py-3 text-sm md:text-base border-2 border-primary shadow-md hover:scale-105 transition-transform duration-200 dark:border-primary/80 focus:ring-2 focus:ring-primary/60"
              data-product-id={product.id}
            >
              Buy Now
            </button>
          </div>
        ) : (
          <div class="p-3 md:p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-center">
            <p class="text-red-500 text-sm md:text-base font-semibold">This item is currently out of stock</p>
          </div>
        )}

        <!-- Share Button -->
        <button
          id="share-btn"
          class="w-full py-2.5 md:py-3 text-sm md:text-base border-2 border-muted-foreground/20 hover:border-muted-foreground/40 shadow-md hover:scale-105 transition-transform duration-200 focus:ring-2 focus:ring-muted-foreground/60 flex items-center justify-center gap-2"
        >
          <i class="bi bi-share"></i>
          <span>Share Product</span>
        </button>

        <!-- Product Details -->
        <div class="border-t pt-6">
          <div class="space-y-3">
            <!-- Category Tag -->
            <div class="w-full flex items-center justify-between p-4 rounded-lg border border-border bg-card">
              <div class="flex items-center space-x-3">
                <i class={`${categoryData.icon} text-lg text-muted-foreground`}></i>
                <span class="font-medium text-muted-foreground">
                  {categoryData.name}
                </span>
              </div>
              <div class="flex items-center space-x-2">
                <span class="text-xs text-muted-foreground bg-muted px-2 py-1 rounded">
                  Category
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <div class="mt-10 md:mt-16">
        <h2 class="text-xl md:text-2xl font-bold mb-4 md:mb-8">Related Products</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6">
          {relatedProducts.map((relatedProduct) => {
            const relatedDiscount = calculateDiscount(relatedProduct.price, relatedProduct.originalPrice || 0);
            return (
              <a
                key={relatedProduct.id}
                href={`/products/${relatedProduct.id}`}
                class="product-card block"
              >
                <div class="relative aspect-square overflow-hidden rounded-lg bg-muted">
                  <img
                    src={relatedProduct.image}
                    alt={relatedProduct.name}
                    class="product-image"
                    crossorigin="anonymous"
                  />
                  {relatedDiscount && (
                    <div class="absolute top-2 right-2">
                      <span class="px-1.5 py-0.5 rounded bg-red-500 text-white text-[10px] font-bold">
                        -{relatedDiscount}%
                      </span>
                    </div>
                  )}
                </div>
                <div class="p-3 space-y-1">
                  <h3 class="font-medium text-xs line-clamp-2">{relatedProduct.name}</h3>
                  <div class="flex items-center flex-wrap gap-1.5">
                    <span class="font-semibold text-sm">{formatPrice(relatedProduct.price)}</span>
                    {relatedProduct.originalPrice && (
                      <span class="text-xs text-muted-foreground line-through">
                        {formatPrice(relatedProduct.originalPrice)}
                      </span>
                    )}
                  </div>
                  {relatedProduct.stock !== undefined && relatedProduct.stock !== null && relatedProduct.stock > 0 && (
                    <span class="text-[10px] text-muted-foreground">
                      {relatedProduct.isUnique ? 'Unique' : `${relatedProduct.stock} left`}
                    </span>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <Footer slot="footer" />
</Layout>

<script define:vars={{ product, formattedPrice: formatPrice(product.price) }}>
  // Format price helper for share functionality
  const formatPrice = (price) => {
    return new Intl.NumberFormat('en-NG', {
      style: 'currency',
      currency: 'NGN',
    }).format(price)
  };

  // Image gallery functionality
  const mainImage = document.getElementById('main-image');
  const mainVideo = document.getElementById('main-video');
  const thumbnailBtns = document.querySelectorAll('.thumbnail-btn');
  
  thumbnailBtns.forEach((btn, index) => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const url = btn.dataset.url;
      
      // Update active thumbnail
      thumbnailBtns.forEach(b => b.classList.remove('border-primary'));
      btn.classList.add('border-primary');

      if (type === 'video') {
        if (mainVideo) {
          mainImage.classList.add('hidden');
          mainVideo.classList.remove('hidden');
          mainVideo.src = url || '';
          mainVideo.play().catch(e => console.warn('Autoplay failed:', e));
        }
      } else {
        mainImage.classList.remove('hidden');
        if (mainVideo) {
          mainVideo.classList.add('hidden');
          mainVideo.pause();
        }
        if (mainImage && url) mainImage.src = url;
      }
    });
  });
  
  // Set first thumbnail as active
  if (thumbnailBtns.length > 0) {
    thumbnailBtns[0].classList.add('border-primary');
  }

  // Back button functionality
  const backBtn = document.getElementById('back-btn');
  if (backBtn) {
    backBtn.addEventListener('click', () => {
      // Check if we came from home page
      if (document.referrer.includes(window.location.origin) && document.referrer.endsWith('/')) {
        window.location.href = '/';
      } else {
        window.location.href = '/shop';
      }
    });
  }

  // Add to cart functionality - dispatch event for cart update
  const addToCartBtn = document.getElementById('add-to-cart-btn');
  const buyNowBtn = document.getElementById('buy-now-btn');
  const shareBtn = document.getElementById('share-btn');
  
  // Share functionality
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: product.name,
        text: `Check out ${product.name} - ${formatPrice(product.price)}`,
        url: window.location.href
      };
      
      // Check if Web Share API is available (native mobile sharing)
      if (typeof navigator.share === 'function') {
        try {
          console.log('Attempting to share via Web Share API...');
          await navigator.share(shareData);
          console.log('Share successful');
        } catch (err) {
          // User cancelled or error
          if (err.name === 'AbortError') {
            console.log('Share cancelled by user');
          } else if (err.name === 'TypeError') {
            // This can happen on iOS if share data is invalid
            console.error('TypeError during share:', err);
            // Fallback to clipboard
            copyToClipboard();
          } else {
            console.error('Error sharing:', err);
            // Fallback to clipboard on error
            copyToClipboard();
          }
        }
      } else {
        console.log('Web Share API not available, using clipboard fallback');
        copyToClipboard();
      }
      
      // Clipboard fallback function
      function copyToClipboard() {
        // Try modern clipboard API first
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(window.location.href).then(() => {
            showCopiedFeedback();
          }).catch(() => {
            fallbackCopy();
          });
        } else {
          // Older browsers
          fallbackCopy();
        }
      }
      
      function fallbackCopy() {
        const textarea = document.createElement('textarea');
        textarea.value = window.location.href;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        
        try {
          document.execCommand('copy');
          showCopiedFeedback();
        } catch (copyErr) {
          // Final fallback - show URL in prompt
          prompt('Copy this link to share:', window.location.href);
        }
        
        document.body.removeChild(textarea);
      }
      
      function showCopiedFeedback() {
        shareBtn.innerHTML = '<i class="bi bi-check-lg"></i> Link Copied!';
        shareBtn.classList.add('bg-green-500', 'border-green-500', 'text-white');
        setTimeout(() => {
          shareBtn.innerHTML = '<i class="bi bi-share"></i> <span>Share Product</span>';
          shareBtn.classList.remove('bg-green-500', 'border-green-500', 'text-white');
        }, 2000);
      }
    });
  }
  
  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', () => {
      // Ensure product.id exists for cart compatibility
      const productToCart = { ...product, id: product.$id };
      
      // Dispatch custom event for cart drawer
      window.dispatchEvent(new CustomEvent('add-to-cart', {
        detail: { product: productToCart, quantity: 1 }
      }));
      // Show feedback
      const originalText = addToCartBtn.textContent;
      addToCartBtn.textContent = 'Added! ✓';
      addToCartBtn.classList.add('bg-green-500', 'border-green-500');
      setTimeout(() => {
        addToCartBtn.textContent = originalText;
        addToCartBtn.classList.remove('bg-green-500', 'border-green-500');
      }, 1500);
    });
  }
  
  if (buyNowBtn) {
    buyNowBtn.addEventListener('click', () => {
      // Ensure product.id exists for cart compatibility
      const productToCart = { ...product, id: product.$id };
      
      // Add to cart and navigate to checkout
      window.dispatchEvent(new CustomEvent('add-to-cart', {
        detail: { product: productToCart, quantity: 1 }
      }));
      window.location.href = '/checkout';
    });
  }

  // Scroll to top on page load
  window.scrollTo({ top: 0, behavior: 'smooth' });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>