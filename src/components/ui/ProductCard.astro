---
import { formatPrice } from '../../lib/utils';

interface Props {
  product: {
    id: string;
    name: string;
    price: number;
    originalPrice?: number;
    category?: string;
    description?: string;
    image?: string;
    images?: string[];
    video?: string;
    videoThumbnail?: string;
    stock?: number;
    featured?: boolean;
    isActive?: boolean;
    isUnique?: boolean;
    verified?: boolean;
    brand?: string;
  };
}

const { product } = Astro.props;
---

<a href={`/products/${product.id}`} class="product-card group block">
  <div class="relative aspect-square overflow-hidden rounded-t-xl bg-muted">
    <img
      src={product.image || 'https://images.pexels.com/photos/607812/pexels-photo-607812.jpeg?auto=compress&cs=tinysrgb&w=800'}
      alt={product.name}
      class="product-image group-hover:scale-105"
      crossorigin="anonymous"
    />
    <!-- Video Indicator -->
    {product.video && (
      <div class="absolute top-3 left-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-black/50 text-white backdrop-blur-sm">
          <i class="bi bi-play-fill text-lg"></i>
        </span>
      </div>
    )}
    <!-- Verified Badge -->
    {product.verified && (
      <div class="absolute top-3 right-3">
        <span class="verified-badge">
          <i class="bi bi-patch-check-fill"></i>
          Verified
        </span>
      </div>
    )}
    <!-- Stock Badge -->
    {product.stock !== undefined && product.stock !== null && (
      <div class="absolute bottom-3 left-3">
        <span class={`px-2 py-1 rounded-full text-xs font-bold backdrop-blur-sm ${
          product.stock === 0 ? 'bg-red-500/90 text-white' :
          product.stock <= 5 ? 'bg-yellow-500/90 text-white' :
          'bg-green-500/90 text-white'
        }`}>
          {product.stock === 0 ? 'Out of Stock' : 
           product.isUnique ? 'Unique Item' :
           `${product.stock} in stock`}
        </span>
      </div>
    )}
    <!-- Quick Add Button -->
    {product.stock !== 0 && (
      <button
        class="quick-add-btn absolute bottom-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity"
        data-product-id={product.id}
        data-product-name={product.name}
        data-product-price={product.price}
        data-product-image={product.image}
        aria-label={`Add ${product.name} to cart`}
      >
        <i class="bi bi-bag-plus"></i>
      </button>
    )}
  </div>
  <div class="p-4 space-y-2">
    <h3 class="font-medium text-sm line-clamp-2 group-hover:text-primary transition-colors">
      {product.name}
    </h3>
    <p class="text-xs text-muted-foreground line-clamp-2">{product.description}</p>
    <div class="flex items-center gap-2 pt-1">
      <span class="font-semibold">{formatPrice(product.price)}</span>
      {product.originalPrice && (
        <span class="text-sm text-muted-foreground line-through">
          {formatPrice(product.originalPrice)}
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .quick-add-btn {
    @apply w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center shadow-lg hover:bg-primary/90 transition-colors;
  }
</style>

<script>
  // Handle quick add to cart
  document.querySelectorAll('.quick-add-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      const target = e.currentTarget as HTMLButtonElement;
      const product = {
        id: target.dataset.productId || '0',
        name: target.dataset.productName || '',
        price: parseFloat(target.dataset.productPrice || '0'),
        image: target.dataset.productImage || ''
      };
      
      // Dispatch event for cart drawer
      window.dispatchEvent(new CustomEvent('add-to-cart', {
        detail: { product, quantity: 1 }
      }));
      
      // Visual feedback
      const originalHTML = target.innerHTML;
      target.innerHTML = '<i class="bi bi-check-lg"></i>';
      target.classList.add('bg-green-500');
      setTimeout(() => {
        target.innerHTML = originalHTML;
        target.classList.remove('bg-green-500');
      }, 1500);
    });
  });
</script>