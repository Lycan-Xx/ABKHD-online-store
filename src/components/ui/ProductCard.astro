---
import { formatPrice, calculateDiscount, parseDescription } from '../../lib/utils';

interface Props {
  product: {
    id: string;
    name: string;
    price: number;
    originalPrice?: number;
    category?: string;
    description?: string;
    image?: string;
    images?: string[];
    video?: string;
    videoThumbnail?: string;
    stock?: number;
    featured?: boolean;
    isActive?: boolean;
    isUnique?: boolean;
    verified?: boolean;
    brand?: string;
  };
}

const { product } = Astro.props;
const discount = calculateDiscount(product.price, product.originalPrice || 0);
---

<a href={`/products/${product.id}`} class="product-card group block" aria-label={product.name}>
  <div class="card-inner">

    <!-- ── Image Container ── -->
    <div class="relative aspect-square overflow-hidden pc-img-wrap bg-muted">
      <img
        src={product.image || product.videoThumbnail || 'https://images.pexels.com/photos/607812/pexels-photo-607812.jpeg?auto=compress&cs=tinysrgb&w=800'}
        alt={product.name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-108"
        crossorigin="anonymous"
        loading="lazy"
      />
      <div class="shimmer-overlay"></div>

      <!-- Verified top-right -->
      {product.verified && (
        <div class="absolute top-2.5 right-2.5">
          <span class="badge-glass badge-verified">
            <i class="bi bi-patch-check-fill text-[10px]"></i>
            <span class="text-[10px] font-semibold">Verified</span>
          </span>
        </div>
      )}

      <!-- Video top-left -->
      {product.video && (
        <div class="absolute top-2.5 left-2.5">
          <span class="badge-glass">
            <i class="bi bi-play-fill text-[10px]"></i>
            <span class="text-[10px] font-semibold">Video</span>
          </span>
        </div>
      )}

      <!-- Stock bottom-left -->
      {product.stock !== undefined && product.stock !== null && (
        <div class="absolute bottom-2.5 left-2.5">
          <span class={`badge-glass ${
            product.stock === 0 ? 'badge-out' :
            product.stock <= 5 ? 'badge-low' :
            'badge-stock'
          }`}>
            <i class={`bi ${
              product.stock === 0 ? 'bi-x-circle-fill' :
              product.stock <= 5 ? 'bi-exclamation-circle-fill' :
              'bi-check-circle-fill'
            } text-[10px]`}></i>
            <span class="text-[10px] font-semibold">
              {product.stock === 0 ? 'Out of Stock' :
               product.isUnique ? 'Unique' :
               `${product.stock} left`}
            </span>
          </span>
        </div>
      )}

      <!-- Discount badge bottom-right on image -->
      {discount && (
        <div class="absolute bottom-2.5 right-2.5">
          <span class="badge-discount">-{discount}%</span>
        </div>
      )}
    </div>

    <!-- ── Card Body ── -->
    <div class="card-body">
      {product.brand && (
        <p class="brand-label">{product.brand}</p>
      )}
      <h3 class="product-title group-hover:text-primary">{product.name}</h3>
      {/* Description with formatting - hidden on mobile, 1-line on sm+ */}
      {product.description ? (
        <div class="product-desc hidden sm:block" set:html={parseDescription(product.description)} />
      ) : null}

      <!-- Price row -->
      <div class="price-col">
        <span class="price-main">{formatPrice(product.price)}</span>
        {product.originalPrice && (
          <span class="price-original">{formatPrice(product.originalPrice)}</span>
        )}
      </div>

      <!-- Actions row: featured pill + add-to-cart -->
      <div class="card-actions">
        {product.featured && (
          <span class="feat-pill">
            <i class="bi bi-star-fill text-[9px]"></i>
            <span class="hidden sm:inline">Featured</span>
            <span class="sm:hidden">★</span>
          </span>
        )}
        {product.stock !== 0 && (
          <button
            class="quick-add-btn ml-auto"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
            data-product-image={product.image}
            aria-label={`Add ${product.name} to cart`}
          >
            <i class="bi bi-bag-plus"></i>
          </button>
        )}
      </div>
    </div>

  </div>
</a>

<style is:global>
  /* ── Card shell ── */
  .product-card {
    display: block;
    border-radius: 10px;          /* reduced roundness */
    background: hsl(var(--card));
    border: 1.5px solid hsl(var(--border));
    overflow: hidden;
    transition: transform 0.22s cubic-bezier(.22,.68,0,1.15),
                box-shadow 0.22s ease,
                border-color 0.18s ease;
    will-change: transform;
  }
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 36px -10px hsl(var(--primary) / 0.16), 0 4px 10px -4px rgba(0,0,0,0.1);
    border-color: hsl(var(--primary) / 0.38);
  }
  .card-inner { display: flex; flex-direction: column; height: 100%; }

  /* ── Image ── */
  .pc-img-wrap { overflow: hidden; position: relative; border-radius: 10px 10px 0 0; }

  .shimmer-overlay {
    position: absolute; inset: 0; pointer-events: none; opacity: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.09) 50%, transparent 60%);
    background-size: 200% 100%;
    transition: opacity 0.3s;
  }
  .product-card:hover .shimmer-overlay {
    opacity: 1;
    animation: shimmer 1.1s ease forwards;
  }
  @keyframes shimmer {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
  }

  /* ── Badges ── */
  .badge-glass {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 2px 7px; border-radius: 6px;   /* rectangular-ish, not full pill */
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    background: rgba(0,0,0,0.40); color: #fff;
    border: 1px solid rgba(255,255,255,0.14);
    white-space: nowrap;
  }
  .badge-verified { background: rgba(34,197,94,0.48);  border-color: rgba(34,197,94,0.4); }
  .badge-stock    { background: rgba(34,197,94,0.42);  border-color: rgba(34,197,94,0.35); }
  .badge-low      { background: rgba(234,179,8,0.50);  border-color: rgba(234,179,8,0.4); }
  .badge-out      { background: rgba(239,68,68,0.52);  border-color: rgba(239,68,68,0.4); }

  .badge-discount {
    display: inline-block; padding: 2px 6px;
    border-radius: 5px;
    background: hsl(var(--primary)); color: hsl(var(--primary-foreground));
    font-size: 10px; font-weight: 800; letter-spacing: 0.03em;
  }

  /* ── Body ── */
  .card-body {
    padding: 10px 11px 12px;
    display: flex; flex-direction: column; gap: 3px; flex: 1;
  }
  .brand-label {
    font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: hsl(var(--primary) / 0.65); margin-bottom: 1px;
  }
  .product-title {
    font-size: 12px; font-weight: 600; line-height: 1.35;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    color: hsl(var(--foreground));
    transition: color 0.15s;
  }
  .product-desc {
    font-size: 11px; color: hsl(var(--muted-foreground));
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
    margin-top: 1px; margin-bottom: 1px;
  }
  /* Styles for formatted description content */
  .product-desc p, 
  .product-desc ul {
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1.3;
  }
  .product-desc li {
    margin: 0 !important;
    padding-left: 16px !important;
  }

  /* ── Price row ── */
  .price-col {
    display: flex; align-items: baseline; gap: 4px;
    min-width: 0; margin-top: 5px;
    overflow: hidden;
  }
  .price-main  { font-size: 13px; font-weight: 700; color: hsl(var(--foreground)); white-space: nowrap; }
  .price-original { font-size: 10px; color: hsl(var(--muted-foreground)); text-decoration: line-through; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* ── Actions row ── */
  .card-actions {
    display: flex; align-items: center; gap: 5px;
    margin-top: 6px;
  }

  /* Featured pill — in body */
  .feat-pill {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 2px 7px; border-radius: 5px;
    background: hsl(var(--primary) / 0.12);
    color: hsl(var(--primary));
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    border: 1px solid hsl(var(--primary) / 0.25);
    white-space: nowrap;
  }

  /* Quick-add ── always visible, compact on mobile */
  .quick-add-btn {
    width: 30px; height: 30px; border-radius: 8px;
    background: hsl(var(--primary)); color: hsl(var(--primary-foreground));
    display: flex; align-items: center; justify-content: center;
    border: none; cursor: pointer; font-size: 14px;
    box-shadow: 0 2px 8px hsl(var(--primary) / 0.32);
    transition: background 0.13s, transform 0.13s, box-shadow 0.13s;
    flex-shrink: 0;
  }
  .quick-add-btn:hover  { background: hsl(var(--primary)/0.85); transform: scale(1.08); box-shadow: 0 4px 14px hsl(var(--primary)/0.45); }
  .quick-add-btn:active { transform: scale(0.94); }
</style>

<script>
  document.querySelectorAll('.quick-add-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const target = e.currentTarget as HTMLButtonElement;
      window.dispatchEvent(new CustomEvent('add-to-cart', {
        detail: { product: {
          id: target.dataset.productId || '0',
          name: target.dataset.productName || '',
          price: parseFloat(target.dataset.productPrice || '0'),
          image: target.dataset.productImage || ''
        }, quantity: 1 }
      }));
      const orig = target.innerHTML;
      target.innerHTML = '<i class="bi bi-check-lg"></i>';
      target.classList.add('!bg-green-500');
      setTimeout(() => { target.innerHTML = orig; target.classList.remove('!bg-green-500'); }, 1500);
    });
  });
</script>