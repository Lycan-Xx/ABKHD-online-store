---
const steps = [
  { icon: 'bi-globe', title: 'Source', desc: 'Trusted UK & China suppliers' },
  { icon: 'bi-search', title: 'Test', desc: 'Multi-point inspection' },
  { icon: 'bi-file-text', title: 'Disclose', desc: 'Document all defects' },
  { icon: 'bi-check-circle', title: 'Deliver', desc: 'Quality guaranteed' },
];
---

<div id="certification-container" class="relative py-8" data-intersect="false">
  {/* Desktop: Horizontal */}
  <div class="hidden md:block">
    <svg 
      viewBox="0 0 800 120" 
      class="w-full h-auto certification-svg"
    >
      {/* Connection lines */}
      {[0, 1, 2].map((i) => (
        <g>
          <line
            x1={100 + i * 200 + 50}
            y1="60"
            x2={100 + (i + 1) * 200 - 50}
            y2="60"
            class="stroke-border"
            stroke-width="2"
          />
          <line
            x1={100 + i * 200 + 50}
            y1="60"
            x2={100 + (i + 1) * 200 - 50}
            y2="60"
            class="stroke-primary certification-line"
            stroke-width="2"
            stroke-dasharray="8 8"
            style={`animation-delay: ${i * 2}s;`}
          />
        </g>
      ))}

      {/* Nodes */}
      {steps.map((step, i) => (
        <g>
          <circle
            cx={100 + i * 200}
            cy="60"
            r="40"
            class="fill-card stroke-border certification-node"
            stroke-width="2"
            style={`animation-delay: ${i * 2}s;`}
          />
          <circle
            cx={100 + i * 200}
            cy="60"
            r="40"
            class="fill-transparent stroke-primary certification-pulse"
            stroke-width="2"
            style={`animation-delay: ${i * 2}s;`}
          />
        </g>
      ))}
    </svg>

    {/* Labels below SVG */}
    <div class="grid grid-cols-4 gap-4 mt-4">
      {steps.map((step, i) => (
        <div 
          class="text-center certification-label"
          style={`animation-delay: ${i * 2}s;`}
        >
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-2">
            <i class={`bi ${step.icon} text-primary text-xl`}></i>
          </div>
          <h4 class="font-semibold text-sm">{step.title}</h4>
          <p class="text-xs text-muted-foreground mt-1">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>

  {/* Mobile: Vertical */}
  <div class="md:hidden space-y-0">
    {steps.map((step, i) => (
      <div class="relative">
        <div 
          class="flex items-start gap-4 certification-label"
          style={`animation-delay: ${i * 2}s;`}
        >
          <div class="relative flex flex-col items-center">
            <div 
              class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center z-10 certification-node"
              style={`animation-delay: ${i * 2}s;`}
            >
              <i class={`bi ${step.icon} text-primary text-xl`}></i>
            </div>
            {i < steps.length - 1 && (
              <div class="w-0.5 h-16 bg-border relative overflow-hidden">
                <div 
                  class="absolute inset-0 bg-primary certification-line-vertical"
                  style={`animation-delay: ${i * 2}s;`}
                />
              </div>
            )}
          </div>
          <div class="pt-2 pb-6">
            <h4 class="font-semibold">{step.title}</h4>
            <p class="text-sm text-muted-foreground">{step.desc}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* Loop indicator */}
  <div class="hidden md:block absolute -bottom-2 left-1/2 -translate-x-1/2">
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      <i class="bi bi-arrow-repeat text-primary animate-spin" style="animation-duration: 3s;"></i>
      <span>Continuous quality cycle</span>
    </div>
  </div>
</div>

<style>
  /* Base styles for animations */
  .certification-line,
  .certification-node,
  .certification-pulse,
  .certification-label,
  .certification-line-vertical {
    animation-play-state: paused;
  }

  [data-intersect="true"] .certification-line,
  [data-intersect="true"] .certification-node,
  [data-intersect="true"] .certification-pulse,
  [data-intersect="true"] .certification-label,
  [data-intersect="true"] .certification-line-vertical {
    animation-play-state: running;
  }

  /* Keyframe animations (reused from original components) */
  .certification-line {
    stroke-dashoffset: 16;
    animation: dash 2s linear infinite;
  }

  @keyframes dash {
    to {
      stroke-dashoffset: 0;
    }
  }

  .certification-node {
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .certification-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.1);
      opacity: 0;
    }
  }

  .certification-label {
    animation: slideUp 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(10px);
  }

  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .certification-line-vertical {
    height: 0;
    animation: grow 1s ease-out forwards;
  }

  @keyframes grow {
    to {
      height: 100%;
    }
  }
</style>

<script>
  const initObserver = () => {
    const container = document.getElementById('certification-container');
    if (!container) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        container.setAttribute('data-intersect', entry.isIntersecting.toString());
      },
      { threshold: 0.2 }
    );

    observer.observe(container);
  };

  // Run on initial load
  initObserver();

  // Re-run after view transitions
  document.addEventListener('astro:after-swap', initObserver);
</script>
