---
import CartDrawer from '../cart/CartDrawer.astro';
import MobileMenu from './MobileMenu.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (path: string) => {
  const normalizedPath = path.replace(/\/$/, '') || '/';
  return currentPath === normalizedPath;
};
---

<header class="sticky top-0 z-40 w-full border-b border-border/60 bg-background/90 backdrop-blur-md supports-[backdrop-filter]:bg-background/75 shadow-sm">
  <div class="container flex h-16 items-center justify-between gap-4">

    <!-- Mobile: Hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -ml-2 hover:bg-accent rounded-lg transition-colors"
      aria-label="Open menu"
    >
      <i class="bi bi-list text-xl"></i>
    </button>

    <!-- Logo -->
    <a href="/" class="flex items-center gap-1.5 shrink-0 group" aria-label="ABKHD Home">
      <span class="font-black text-xl tracking-tight transition-colors group-hover:text-primary">ABKHD</span>
      <span class="font-light text-xl tracking-tight text-muted-foreground transition-colors group-hover:text-primary/70">Store</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-1 flex-1 ml-4">
      <a
        href="/"
        class={`nav-link ${isActive('/') ? 'nav-link--active' : ''}`}
      >
        <i class="bi bi-stars text-xs mr-1.5 opacity-70"></i>
        Featured
      </a>
      <a
        href="/shop"
        class={`nav-link nav-link--shop ${isActive('/shop') ? 'nav-link--active' : ''}`}
      >
        <i class="bi bi-bag text-xs mr-1.5 opacity-70"></i>
        Shop
      </a>
      <a
        href="/about"
        class={`nav-link ${isActive('/about') ? 'nav-link--active' : ''}`}
      >
        About
      </a>
      <a
        href="/contact"
        class={`nav-link ${isActive('/contact') ? 'nav-link--active' : ''}`}
      >
        Contact
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Dark Mode Toggle (Desktop) -->
      <button
        id="dark-mode-toggle"
        class="hidden md:flex p-2 hover:bg-accent rounded-lg transition-colors"
        aria-label="Toggle dark mode"
      >
        <i id="dark-mode-icon" class="bi bi-moon text-lg"></i>
      </button>

      <!-- Cart -->
      <button
        id="cart-toggle"
        class="relative p-2 hover:bg-accent rounded-lg transition-colors"
        aria-label="Open cart"
      >
        <i class="bi bi-bag text-lg"></i>
        <span id="cart-count" class="absolute -top-0.5 -right-0.5 bg-primary text-primary-foreground text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center hidden">
          0
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<MobileMenu />

<!-- Cart Drawer -->
<CartDrawer />

<style>
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 8px;
    color: hsl(var(--muted-foreground));
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: hsl(var(--foreground));
    background: hsl(var(--accent));
  }
  .nav-link--active {
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.1);
    font-weight: 600;
    border-bottom: 2px solid hsl(var(--primary));
  }
  /* Shop gets a subtle accent so it reads as a CTA */
  .nav-link--shop:not(.nav-link--active) {
    color: hsl(var(--foreground));
    background: hsl(var(--primary) / 0.07);
    border: 1px solid hsl(var(--primary) / 0.2);
  }
  .nav-link--shop:not(.nav-link--active):hover {
    background: hsl(var(--primary) / 0.14);
    border-color: hsl(var(--primary) / 0.35);
  }
</style>

<script is:inline>
  // Initialize dark mode immediately
  (function() {
    const savedTheme = localStorage.getItem('darkMode');
    const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = savedTheme !== null ? savedTheme === 'true' : systemPrefersDark;
    if (isDark) document.documentElement.classList.add('dark');
  })();

  // Mobile menu handler - runs immediately
  function setupMobileMenu() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const menuOverlay = document.getElementById('menu-overlay');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuClose = document.getElementById('menu-close');

    if (!mobileMenuBtn || !menuOverlay || !mobileMenu || !menuClose) {
      console.warn('Mobile menu elements not found');
      return;
    }

    function openMenu() {
      menuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('-translate-x-full');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menuOverlay.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('-translate-x-full');
      document.body.style.overflow = '';
    }

    mobileMenuBtn.addEventListener('click', openMenu);
    menuClose.addEventListener('click', closeMenu);
    menuOverlay.addEventListener('click', closeMenu);

    // Close menu when clicking links
    document.querySelectorAll('.menu-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  // Cart handler
  function setupCart() {
    const cartToggle = document.getElementById('cart-toggle');
    if (cartToggle) {
      cartToggle.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-cart'));
      });
    }
  }

  // Dark mode handler
  function setupDarkMode() {
    const darkToggle = document.getElementById('dark-mode-toggle');
    if (darkToggle) {
      darkToggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('darkMode', 'false');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('darkMode', 'true');
        }
        updateDarkModeIcon();
      });
    }
  }

  function updateDarkModeIcon() {
    const icon = document.getElementById('dark-mode-icon');
    const isDark = document.documentElement.classList.contains('dark');
    if (icon) {
      icon.className = isDark ? 'bi bi-sun text-lg' : 'bi bi-moon text-lg';
    }
  }

  // Run setup when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupMobileMenu();
      setupCart();
      setupDarkMode();
      updateDarkModeIcon();
    });
  } else {
    setupMobileMenu();
    setupCart();
    setupDarkMode();
    updateDarkModeIcon();
  }

  // Handle view transitions
  document.addEventListener('astro:after-swap', () => {
    setupMobileMenu();
    setupCart();
    setupDarkMode();
    updateDarkModeIcon();
  });
</script>

<script>
  import { $cartItems, getCartCount, openCart } from '../../stores/cart';
  import { createInitializer } from '../../lib/init';

  createInitializer(() => {
    function updateCartBadge() {
      const el = document.getElementById('cart-count');
      if (el) {
        const count = getCartCount();
        el.textContent = count.toString();
        el.classList.toggle('hidden', count === 0);
      }
    }
    updateCartBadge();
    const unsubCart = $cartItems.subscribe(() => updateCartBadge());

    // Listen for cart open event
    window.addEventListener('open-cart', () => openCart());

    return () => {
      unsubCart();
    };
  });
</script>
