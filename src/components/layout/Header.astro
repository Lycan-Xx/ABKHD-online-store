---
import CartDrawer from '../cart/CartDrawer.astro';
import MobileMenu from './MobileMenu.astro';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path;
const isHome = currentPath === '/';
---

<header class="sticky top-0 z-40 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
  <div class="container flex h-16 items-center justify-between">
    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -ml-2 hover:bg-accent rounded-lg transition-colors"
      aria-label="Open menu"
    >
      <i class="bi bi-list text-xl"></i>
    </button>

    <!-- Logo -->
    <a 
      href="/" 
      class={`flex items-center gap-2 px-3 py-1.5 rounded-lg transition-all ${
        isHome 
          ? 'bg-primary/10 ring-1 ring-primary/30' 
          : 'hover:bg-accent'
      }`}
    >
      <span class={`font-bold text-xl tracking-tight transition-colors ${isHome ? 'text-primary' : ''}`}>
        ABKHD
      </span>
      {isHome && <i class="bi bi-house-fill text-primary text-sm"></i>}
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-1">
      <a 
        href="/shop" 
        class={`px-4 py-2 text-sm rounded-lg transition-all ${
          isActive('/shop') 
            ? 'text-primary bg-primary/15 font-semibold border-b-2 border-primary' 
            : 'text-muted-foreground font-medium hover:text-foreground hover:bg-accent'
        }`}
      >
        Shop
      </a>
      <a 
        href="/about" 
        class={`px-4 py-2 text-sm rounded-lg transition-all ${
          isActive('/about') 
            ? 'text-primary bg-primary/15 font-semibold border-b-2 border-primary' 
            : 'text-muted-foreground font-medium hover:text-foreground hover:bg-accent'
        }`}
      >
        About
      </a>
      <a 
        href="/contact" 
        class={`px-4 py-2 text-sm rounded-lg transition-all ${
          isActive('/contact') 
            ? 'text-primary bg-primary/15 font-semibold border-b-2 border-primary' 
            : 'text-muted-foreground font-medium hover:text-foreground hover:bg-accent'
        }`}
      >
        Contact
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Dark Mode Toggle (Desktop) -->
      <button
        id="dark-mode-toggle"
        class="hidden md:flex p-2 hover:bg-accent rounded-lg transition-colors"
        aria-label="Toggle dark mode"
      >
        <i id="dark-mode-icon" class="bi bi-moon text-lg"></i>
      </button>

      <!-- Cart -->
      <button
        id="cart-toggle"
        class="relative p-2 hover:bg-accent rounded-lg transition-colors"
        aria-label="Open cart"
      >
        <i class="bi bi-bag text-lg"></i>
        <span id="cart-count" class="absolute -top-0.5 -right-0.5 bg-primary text-primary-foreground text-xs font-medium rounded-full w-5 h-5 flex items-center justify-center hidden">
          0
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Native Astro Mobile Menu -->
<MobileMenu />

<!-- Native Astro Cart Drawer -->
<CartDrawer />

<script>
  import { initDarkMode, toggleDarkMode, $isDarkMode } from '../../stores/dark-mode';
  import { $cartItems, getCartCount, openCart } from '../../stores/cart';
  import { createInitializer } from '../../lib/init';

  createInitializer(() => {
    // Dark mode
    initDarkMode();
    
    function updateDarkModeIcon() {
      const icon = document.getElementById('dark-mode-icon');
      if (icon) {
        icon.className = $isDarkMode.get() ? 'bi bi-sun text-lg' : 'bi bi-moon text-lg';
      }
    }
    updateDarkModeIcon();

    const unsubDark = $isDarkMode.subscribe(() => updateDarkModeIcon());

    // Cart count
    function updateCartBadge() {
      const el = document.getElementById('cart-count');
      if (el) {
        const count = getCartCount();
        el.textContent = count.toString();
        el.classList.toggle('hidden', count === 0);
      }
    }
    updateCartBadge();
    const unsubCart = $cartItems.subscribe(() => updateCartBadge());

    // Event listeners
    const darkToggle = document.getElementById('dark-mode-toggle');
    const cartToggle = document.getElementById('cart-toggle');

    const handleDark = () => toggleDarkMode();
    const handleCart = () => openCart();

    darkToggle?.addEventListener('click', handleDark);
    cartToggle?.addEventListener('click', handleCart);

    // Cleanup
    return () => {
      unsubDark();
      unsubCart();
      darkToggle?.removeEventListener('click', handleDark);
      cartToggle?.removeEventListener('click', handleCart);
    };
  });
</script>
