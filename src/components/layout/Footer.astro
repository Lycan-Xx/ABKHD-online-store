---
const whatsappNumber = import.meta.env.VITE_WHATSAPP_NUMBER || '2348085657927';
---

<footer class="border-t bg-background">
  <div class="container py-10 flex flex-col items-center justify-center text-center space-y-5">
    <a href="/" class="inline-block">
      <span class="font-bold text-2xl tracking-tight">ABKHD</span>
    </a>
    
    <p class="text-sm text-muted-foreground max-w-md">
      Premium tech at smarter prices. Every device tested & certified.
      <br class="hidden sm:block" /> Based in Jimeta, Yola • Nigeria.
    </p>

    <div class="flex items-center gap-6 pt-2">
      <a
        href={`https://wa.me/${whatsappNumber}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-all hover:scale-110"
        aria-label="WhatsApp"
      >
        <i class="bi bi-whatsapp text-lg"></i>
      </a>
      <a 
        href="https://www.facebook.com/share/1NSyGvuCYP/" 
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-all hover:scale-110"
        aria-label="Facebook"
      >
        <i class="bi bi-facebook text-lg"></i>
      </a>
    </div>

    <p class="text-xs text-muted-foreground/60 pt-2">
      &copy; {new Date().getFullYear()} ABKHD. All rights reserved.
    </p>
  </div>
</footer>