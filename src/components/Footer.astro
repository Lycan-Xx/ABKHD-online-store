---
const whatsappNumber = import.meta.env.VITE_WHATSAPP_NUMBER || '2348012345678';
---

<footer class="border-t bg-background">
  <div class="container py-12">
    <div class="flex flex-col md:flex-row md:justify-between gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="inline-block">
          <span class="font-bold text-xl tracking-tight">ABKHD</span>
        </a>
        <p class="text-sm text-muted-foreground">
          Premium tech at smarter prices. Every device tested & certified.
        </p>
      </div>

      <!-- Connect - Moved to far right -->
      <div class="space-y-4">
        <h3 class="font-semibold">Connect</h3>
        <div class="flex gap-4">
          <a
            href={`https://wa.me/${whatsappNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground transition-colors"
            aria-label="WhatsApp"
          >
            <i class="bi bi-whatsapp text-xl"></i>
          </a>
          <a href="#" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Instagram">
            <i class="bi bi-instagram text-xl"></i>
          </a>
          <a href="#" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Twitter">
            <i class="bi bi-twitter-x text-xl"></i>
          </a>
        </div>
        <p class="text-sm text-muted-foreground">
          Jimeta, Yola • Nigeria
        </p>
      </div>
    </div>

    <div class="border-t mt-8 pt-8 text-center text-sm text-muted-foreground">
      <p>&copy; {new Date().getFullYear()} ABKHD. All rights reserved.</p>
    </div>
  </div>
</footer>