# Copy this file to .env and update the values

# App Configuration
VITE_APP_NAME=Your Store Name
VITE_APP_VERSION=1.0.0

# WhatsApp Configuration
VITE_WHATSAPP_PHONE_NUMBER=+1234567890

# Development Configuration
NODE_ENV=development

# Appwrite Configuration
PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
PUBLIC_APPWRITE_PROJECT_ID=your_project_id
PUBLIC_APPWRITE_DATABASE_ID=abkhd_db
PUBLIC_APPWRITE_COLLECTION_PRODUCTS=products
PUBLIC_APPWRITE_COLLECTION_ORDERS=orders
PUBLIC_APPWRITE_BUCKET_IMAGES=product-images

# Squad Payment Configuration
# Get your keys from https://dashboard.squadco.com
PUBLIC_SQUAD_PUBLIC_KEY=your_squad_public_key_here
SQUAD_SECRET_KEY=your_squad_secret_key_here
# For Cloudflare Pages, you might also need to set this as PUBLIC_ variable:
PUBLIC_SQUAD_SECRET_KEY=your_squad_secret_key_here

# ============================================
# CLOUDFLARE PAGES SETUP INSTRUCTIONS
# ============================================
# 
# For Cloudflare Pages deployment:
# 1. Go to Cloudflare Pages dashboard
# 2. Select your project
# 3. Go to Settings > Environment variables
# 4. Add these variables:
#    - SQUAD_SECRET_KEY: your_squad_secret_key_here
#    - PUBLIC_SQUAD_PUBLIC_KEY: your_squad_public_key_here
# 5. Make sure they are available to "Production" environment
# 6. Redeploy after adding/changing variables
#
# Note: In Cloudflare Pages, non-PUBLIC_ variables might not be accessible
# to server-side functions. If SQUAD_SECRET_KEY doesn't work, try setting
# it as PUBLIC_SQUAD_SECRET_KEY instead.
# ============================================