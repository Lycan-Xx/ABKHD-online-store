# Cloudflare Pages Headers

# Cache purge API - NO CACHE
/api/purge-cache
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache

# API routes - allow CORS for frontend calls
/api/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, PATCH, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
  Access-Control-Max-Age: 86400

# Cache control for static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Edge Cache Control for Dynamic HTML
# We use max-age=0 to ensure Cloudflare checks the Worker (origin) every time for freshness
/*
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate

# Security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# SPA fallback for single-page app behavior (if needed)
/*_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Appwrite API CORS - Allow requests from production domain
# These headers help with Cloudflare proxying
/../v1/*
  Access-Control-Allow-Origin: https://abkhd.pages.dev
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, PATCH, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-Appwrite-Project, X-Appwrite-Key, X-Appwrite-Response-Format, client-native, client-web, mode, source
  Access-Control-Expose-Headers: Content-Type, X-Filename
